        const DEFAULT_STATUS_REJECT_TEMPLATE = `Halo {{nama}}, terima kasih sudah melamar di Sencha House.

Setelah kami tinjau, untuk posisi ini saat ini kami belum bisa bekerja sama dengan Anda. Keputusan ini terkait kebutuhan tim kami, bukan penilaian negatif terhadap diri Anda.

Semoga bisa bekerja sama di lain waktu.

— Tim HRD Sencha House`;

        function getStatusRejectTemplate() {
            return String(state.statusRejectTemplate || DEFAULT_STATUS_REJECT_TEMPLATE).trim() || DEFAULT_STATUS_REJECT_TEMPLATE;
        }
        function renderStatusRejectTemplate(nama) {
            const n = String(nama || 'Pelamar').trim() || 'Pelamar';
            return getStatusRejectTemplate().split('{{nama}}').join(n);
        }
        function buildStatusRejectChatMessage(nama) {
            return renderStatusRejectTemplate(nama);
        }
        async function confirmStatusRejectNotif(applicantName) {
            const preview = buildStatusRejectChatMessage(applicantName);
            const ok = await Swal.fire({
                title: 'Kirim pesan chat ke pelamar?',
                html: `<p class="text-sm text-left mb-3">Pelamar akan menerima <strong>pesan chat</strong> dari HRD dengan teks berikut:</p>
                    <div class="text-left text-xs bg-slate-50 border border-slate-200 rounded-xl p-3 whitespace-pre-wrap leading-relaxed max-h-48 overflow-y-auto">${escapeHtml(preview)}</div>`,
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: 'Ya, kirim chat',
                cancelButtonText: 'Batal',
                confirmButtonColor: '#2563eb',
                width: 480
            });
            return ok.isConfirmed;
        }
        async function sendStatusRejectChatMessage(applicantId, applicantName) {
            const chatText = buildStatusRejectChatMessage(applicantName);
            await addDoc(collection(db, COL_APPLICANTS, applicantId, SUB_MESSAGES), {
                from: 'hrd',
                type: 'status_notif',
                text: chatText,
                createdAt: serverTimestamp()
            });
            await touchChatThread(applicantId, 'hrd', chatText.slice(0, 280));
            try {
                await writeActivityLog({
                    type: 'status_tidak_diterima',
                    applicantId,
                    applicantName,
                    posisi: getPosisiDisplay(state.applicants.find((x) => x.id === applicantId) || {}),
                    page: 'hrd',
                    source: 'hrd'
                });
            } catch (e) {
                console.warn('writeActivityLog status_tidak_diterima', e);
            }
        }
        async function applyApplicantStatusUpdate(applicantId, newStatus, prevStatus, applicantName) {
            const st = normalizeStatus(newStatus);
            const prev = normalizeStatus(prevStatus);
            if (st === 'tidak_cocok' && prev !== 'tidak_cocok') {
                const ok = await confirmStatusRejectNotif(applicantName);
                if (!ok) return false;
                Swal.fire({ title: 'Mengirim chat...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
                try {
                    await updateDoc(doc(db, COL_APPLICANTS, applicantId), {
                        status: st,
                        updatedAt: serverTimestamp()
                    });
                    await sendStatusRejectChatMessage(applicantId, applicantName);
                    Swal.close();
                    showToast('Status diperbarui & pesan chat terkirim');
                    return true;
                } catch (e) {
                    Swal.close();
                    Swal.fire('Gagal', firestoreErrHint(e), 'error');
                    return false;
                }
            }
            try {
                await updateDoc(doc(db, COL_APPLICANTS, applicantId), {
                    status: st,
                    updatedAt: serverTimestamp()
                });
                showToast('Status diperbarui');
                return true;
            } catch (e) {
                Swal.fire('Gagal', e.message || 'Tidak bisa menyimpan', 'error');
                return false;
            }
        }

