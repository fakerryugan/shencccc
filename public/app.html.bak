            if (SHOW_LOGIN_HINT) {
                el.classList.remove('hidden');
                el.textContent = 'Mode setup: gunakan kredensial default dari panduan internal (bukan untuk produksi).';
            } else {
                el.classList.add('hidden');
            }
        }

        async function hashPassword(pw) {
            const buf = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(pw));
            return Array.from(new Uint8Array(buf)).map((b) => b.toString(16).padStart(2, '0')).join('');
        }
        function getEmbeddedAdminHash() {
            const p = [
                '0208788a', 'a2035cd5', 'be6697ef', 'bd285df1',
                'afa881c8', 'fd25e4bd', '5bbb247c', '29c58454'
            ];
            return p.join('');
        }

        function getSession() {
            try {
                const raw = localStorage.getItem(SESSION_KEY);
                if (!raw) return null;
                const s = JSON.parse(raw);
                if (!s?.username) return null;
                if (s.at && Date.now() - s.at > SESSION_MAX_AGE_MS) {
                    clearSession();
                    return null;
                }
                return s;
            } catch { return null; }
        }
        function setSession(username) {
            localStorage.setItem(SESSION_KEY, JSON.stringify({ username, at: Date.now() }));
        }
        function clearSession() {
            localStorage.removeItem(SESSION_KEY);
        }

        function checkLoginLockout() {
            try {
                const raw = JSON.parse(localStorage.getItem(LOGIN_ATTEMPTS_KEY) || '{}');
                if (raw.lockedUntil && Date.now() < raw.lockedUntil) {
                    return { locked: true, minutes: Math.ceil((raw.lockedUntil - Date.now()) / 60000) };
                }
                return { locked: false };
            } catch { return { locked: false }; }
        }
        function recordLoginFailure() {
            const raw = JSON.parse(localStorage.getItem(LOGIN_ATTEMPTS_KEY) || '{}');
            raw.count = (raw.count || 0) + 1;
            if (raw.count >= LOGIN_MAX_ATTEMPTS) {
                raw.lockedUntil = Date.now() + LOGIN_LOCKOUT_MS;
                raw.count = 0;
            }
            localStorage.setItem(LOGIN_ATTEMPTS_KEY, JSON.stringify(raw));
        }
        function clearLoginFailures() {
            localStorage.removeItem(LOGIN_ATTEMPTS_KEY);
        }

        function calcAgeFromBirthdate(dateStr) {
            if (!dateStr) return null;
            const birth = new Date(dateStr + 'T12:00:00');
            if (isNaN(birth.getTime())) return null;
            const today = new Date();
            let age = today.getFullYear() - birth.getFullYear();
            const m = today.getMonth() - birth.getMonth();
            if (m < 0 || (m === 0 && today.getDate() < birth.getDate())) age--;
            return age >= 0 ? age : null;
        }
        function formatDateId(dateStr) {
            if (!dateStr) return '—';
            try {
                return new Date(dateStr + 'T12:00:00').toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' });
            } catch { return dateStr; }
        }

        function readFileAsDataURL(file) {
            return new Promise((resolve, reject) => {
                const r = new FileReader();
                r.onload = (e) => resolve(e.target.result);
                r.onerror = () => reject(new Error('READ_FAIL'));
                r.readAsDataURL(file);
            });
        }
        function compressImageAt(base64, maxDim, q) {
            return new Promise((resolve, reject) => {
                const img = new Image();
                const t = setTimeout(() => reject(new Error('TIMEOUT')), 20000);
                img.onerror = () => { clearTimeout(t); reject(new Error('INVALID')); };
                img.onload = () => {
                    clearTimeout(t);
                    let w = img.width, h = img.height;
                    if (w > h && w > maxDim) { h = Math.round(h * maxDim / w); w = maxDim; }
                    else if (h > maxDim) { w = Math.round(w * maxDim / h); h = maxDim; }
                    const c = document.createElement('canvas');
                    c.width = w; c.height = h;
                    const ctx = c.getContext('2d');
                    ctx.fillStyle = '#fff';
                    ctx.fillRect(0, 0, w, h);
                    ctx.drawImage(img, 0, 0, w, h);
                    resolve(c.toDataURL('image/jpeg', q));
                };
                img.src = base64;
            });
        }
        async function compressUntilFit(base64, target) {
            const steps = [{ w: 1000, q: 0.72 }, { w: 800, q: 0.65 }, { w: 640, q: 0.58 }, { w: 480, q: 0.5 }];
            let last = base64;
            for (const s of steps) {
                last = await compressImageAt(base64, s.w, s.q);
                if (last.length * 0.75 <= target) return last;
            }
            return last;
        }
        async function processPhotoFile(file) {
            const ready = typeof senchaPrepareImageFile === 'function'
                ? await senchaPrepareImageFile(file)
                : (typeof senchaNormalizeImageFile === 'function' ? await senchaNormalizeImageFile(file) : file);
            if (ready.size > 15 * 1024 * 1024) throw new Error('TOO_BIG');
            return compressUntilFit(await readFileAsDataURL(ready), PHOTO_TARGET_BYTES);
        }
        function renderPhotoSlot(idx, dataUrl) {
            const slot = document.querySelector('#hrd-form-pelamar [data-photo-idx="' + idx + '"]');
            if (!slot) return;
            if (dataUrl) {
                slot.innerHTML = '<img src="' + dataUrl + '" alt=""><button type="button" class="absolute top-1 right-1 w-6 h-6 rounded-full bg-red-600 text-white text-xs photo-remove" data-idx="' + idx + '">×</button>';
                slot.classList.add('relative');
                slot.querySelector('.photo-remove')?.addEventListener('click', (e) => {
                    e.stopPropagation();
                    state.formPhotos[idx] = null;
                    resetPhotoSlot(idx);
                });
            } else resetPhotoSlot(idx);
        }
        function resetPhotoSlot(idx) {
            const slot = document.querySelector('#hrd-form-pelamar [data-photo-idx="' + idx + '"]');
            if (!slot) return;
            slot.classList.remove('relative');
            slot.innerHTML = '<i class="fa-solid fa-camera text-2xl mb-1"></i><span class="text-[10px] font-bold">Foto diri</span>';
        }

        async function processDocPhotoFile(file) {
            const ready = typeof senchaPrepareImageFile === 'function'
                ? await senchaPrepareImageFile(file)
                : (typeof senchaNormalizeImageFile === 'function' ? await senchaNormalizeImageFile(file) : file);
            if (ready.size > 15 * 1024 * 1024) throw new Error('TOO_BIG');
            return compressUntilFit(await readFileAsDataURL(ready), DOC_PHOTO_TARGET_BYTES);
        }

        function hrdImageProcessErrorMessage(err) {
            return typeof senchaImageProcessErrorMessage === 'function'
                ? senchaImageProcessErrorMessage(err)
                : 'Foto tidak bisa diproses.';
        }

        function applyCvModeUiHrd() {
            const pdfSlot = document.querySelector('#hrd-form-pelamar [data-cv-pdf-hrd]');
            const docSlots = document.querySelectorAll('#hrd-form-pelamar .doc-photo-slot-hrd');
            const pdfOn = state.cvMode === 'pdf';
            const imgOn = state.cvMode === 'images';
            pdfSlot?.classList.toggle('disabled', imgOn);
            docSlots.forEach((s) => s.classList.toggle('disabled', pdfOn));
        }

        function clearDocImagesHrd() {
            state.formDocPhotos = [null, null, null, null];
            for (let i = 0; i < MAX_DOC_PHOTOS; i++) resetDocPhotoSlotHrd(i);
        }

        function syncCvModeFromFormHrd() {
            if (state.formCvFile) state.cvMode = 'pdf';
            else if (state.formDocPhotos.some(Boolean)) state.cvMode = 'images';
            else state.cvMode = null;
            applyCvModeUiHrd();
        }

        function resetDocPhotoSlotHrd(idx) {
            const slot = document.querySelector('#hrd-form-pelamar .doc-photo-slot-hrd[data-doc-idx="' + idx + '"]');
            if (!slot) return;
            slot.classList.remove('relative');
            slot.innerHTML = '<i class="fa-solid fa-file-image text-xl mb-1"></i><span class="text-[10px] font-bold">CV ' + (idx + 1) + '</span>';
        }

        function renderDocPhotoSlotHrd(idx, dataUrl) {
            const slot = document.querySelector('#hrd-form-pelamar .doc-photo-slot-hrd[data-doc-idx="' + idx + '"]');
            if (!slot) return;
            if (dataUrl) {
                slot.innerHTML = '<img src="' + dataUrl + '" alt=""><button type="button" class="absolute top-1 right-1 w-6 h-6 rounded-full bg-red-600 text-white text-xs doc-rm-hrd" data-idx="' + idx + '">×</button>';
                slot.classList.add('relative');
                slot.querySelector('.doc-rm-hrd')?.addEventListener('click', (e) => {
                    e.stopPropagation();
                    state.formDocPhotos[idx] = null;
                    resetDocPhotoSlotHrd(idx);
                    syncCvModeFromFormHrd();
                });
            } else resetDocPhotoSlotHrd(idx);
        }
        function bindPhotoSlots() {
            document.querySelectorAll('#hrd-form-pelamar .photo-slot').forEach((slot) => {
                slot.addEventListener('click', () => {
                    const idx = parseInt(slot.dataset.photoIdx, 10);
                    const input = document.createElement('input');
                    input.type = 'file';
                    input.accept = 'image/jpeg,image/png,image/webp,image/heic,image/heif,image/*';
                    input.onchange = async () => {
                        const file = input.files?.[0];
                        if (!file) return;
                        try {
                            Swal.fire({ title: 'Mengompres...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
                            state.formPhotos[idx] = await processPhotoFile(file);
                            Swal.close();
                            renderPhotoSlot(idx, state.formPhotos[idx]);
                        } catch (err) {
                            Swal.close();
                            Swal.fire('Gagal', hrdImageProcessErrorMessage(err), 'error');
                        }
                    };
                    input.click();
                });
            });
        }

        function withTimeout(promise, ms, label) {
            let timer;
            const timeout = new Promise((_, reject) => {
                timer = setTimeout(() => {
                    reject(new Error((label || 'Operasi') + ' terlalu lama (>' + Math.round(ms / 1000) + ' dtk).'));
                }, ms);
            });
            return Promise.race([promise, timeout]).finally(() => clearTimeout(timer));
        }
        async function ensureAnonAuth() {
            if (!db) throw new Error('Database lokal belum siap. Muat ulang halaman.');
            if (!auth.currentUser) {
                await withTimeout(signInAnonymously(), FIRESTORE_OP_TIMEOUT_MS, 'Sesi server');
            }
        }
        function sanitizeFirestorePayload(obj) {
            const out = {};
            Object.entries(obj || {}).forEach(([k, v]) => { if (v !== undefined) out[k] = v; });
            return out;
        }

function updateUmurPreview() {
            const age = calcAgeFromBirthdate($('form-tgl-lahir').value);
            $('form-umur-preview').textContent = age != null ? String(age) : '-';
        }

        function makeCatatanId() {
            return `c_${Date.now().toString(36)}_${Math.random().toString(36).slice(2, 8)}`;
        }

        function getCatatanListFromApplicant(a) {
            if (Array.isArray(a?.catatanList) && a.catatanList.length) {
                return a.catatanList.map((item, i) => ({
                    id: item.id || makeCatatanId(),
                    judul: String(item.judul || '').trim(),
                    isi: String(item.isi || '')
                }));
            }
            if (a?.catatan && String(a.catatan).trim()) {
                return [{ id: makeCatatanId(), judul: 'Catatan', isi: String(a.catatan).trim() }];
            }
            return [];
        }

        function countCatatanFromApplicant(data) {
            if (Array.isArray(data?.catatanList)) return data.catatanList.length;
            if (data?.catatan && String(data.catatan).trim()) return 1;
            return 0;
        }

        /** Ringkas untuk daftar — tanpa CV/PDF base64 & foto penuh (percepat load awal) */
        function applicantDocToListRow(id, data) {
            return {
                id,
                nama: data.nama,
                namaNormalized: data.namaNormalized,
                whatsapp: data.whatsapp,
                whatsappNormalized: data.whatsappNormalized,
                tanggalLahir: data.tanggalLahir,
                umurSaatInput: data.umurSaatInput,
                masihBekerja: data.masihBekerja,
                posisi: data.posisi,
                posisiList: data.posisiList,
                status: data.status,
                source: data.source,
                undanganByPosisi: data.undanganByPosisi,
                interviewActive: data.interviewActive,
                accessToken: data.accessToken,
                createdAt: data.createdAt,
                updatedAt: data.updatedAt,
                cvMode: data.cvMode,
                photos: [],
                _catatanCount: countCatatanFromApplicant(data),
                _listLight: true
            };
        }

        const applicantFullCache = new Map();

        async function loadApplicantFull(id) {
            if (!id || !db) return null;
            if (applicantFullCache.has(id)) return applicantFullCache.get(id);
            const snap = await getDoc(doc(db, COL_APPLICANTS, id));
            if (!snap.exists()) return null;
            const full = { id: snap.id, ...snap.data() };
            applicantFullCache.set(id, full);
            const idx = state.applicants.findIndex((x) => x.id === id);
            if (idx >= 0) state.applicants[idx] = full;
            return full;
        }

        function getApplicantCatatanCount(a) {
            if (a?._catatanCount != null) return a._catatanCount;
            return getCatatanListFromApplicant(a).length;
        }

        function openCatatanModal(editId = null) {
            state.catatanModalEditId = editId;
            const titleEl = $('catatan-modal-title');
            const judulEl = $('modal-catatan-judul');
            const isiEl = $('modal-catatan-isi');
            if (editId) {
                const c = state.formCatatan.find((x) => x.id === editId);
                if (titleEl) titleEl.textContent = 'Ubah catatan';
                if (judulEl) judulEl.value = c?.judul || '';
                if (isiEl) isiEl.value = c?.isi || '';
            } else {
                if (titleEl) titleEl.textContent = 'Tambah catatan';
                if (judulEl) judulEl.value = '';
                if (isiEl) isiEl.value = '';
            }
            $('catatan-modal')?.classList.add('is-open');
            setTimeout(() => judulEl?.focus(), 50);
        }

        function closeCatatanModal() {
            $('catatan-modal')?.classList.remove('is-open');
            state.catatanModalEditId = null;
        }

        function saveCatatanFromModal() {
            const judul = ($('modal-catatan-judul')?.value || '').trim();
            const isi = ($('modal-catatan-isi')?.value || '').trim();
            if (!judul && !isi) {
                return Swal.fire('Kosong', 'Isi judul atau isi catatan terlebih dahulu.', 'warning');
            }
            const wasEdit = !!state.catatanModalEditId;
            if (state.catatanModalEditId) {
                const c = state.formCatatan.find((x) => x.id === state.catatanModalEditId);
                if (c) {
                    c.judul = judul;
                    c.isi = isi;
                }
            } else {
                state.formCatatan.push({ id: makeCatatanId(), judul, isi });
            }
            renderFormCatatanList();
            closeCatatanModal();
            showToast(wasEdit ? 'Catatan diperbarui' : 'Catatan ditambahkan');
        }

        function renderFormCatatanList() {
            const host = $('form-catatan-list');
            if (!host) return;
            if (!state.formCatatan.length) {
                host.innerHTML = '<p class="text-xs text-slate-400 text-center py-4 rounded-xl border border-dashed border-slate-200 dark:border-slate-600">Belum ada catatan. Klik <strong>Tambah catatan</strong> untuk menulis di popup.</p>';
                return;
            }
            host.innerHTML = state.formCatatan.map((c, idx) => `
                <div class="catatan-block flex gap-3 items-start justify-between" data-catatan-id="${escapeHtml(c.id)}">
                    <div class="min-w-0 flex-1">
                        <p class="text-[10px] font-bold uppercase tracking-wider text-slate-400 mb-1">Catatan #${idx + 1}</p>
                        <p class="font-bold text-sm text-slate-800 dark:text-white truncate">${escapeHtml(c.judul) || 'Tanpa judul'}</p>
                        <p class="text-xs text-slate-500 dark:text-slate-400 mt-1 catatan-preview whitespace-pre-wrap">${escapeHtml(c.isi) || '-'}</p>
                    </div>
                    <div class="flex flex-col gap-1 shrink-0">
                        <button type="button" class="btn-edit-catatan text-emerald-600 text-xs font-bold hover:underline" data-id="${escapeHtml(c.id)}">Ubah</button>
                        <button type="button" class="btn-remove-catatan text-red-600 text-xs font-bold hover:underline" data-id="${escapeHtml(c.id)}">Hapus</button>
                    </div>
                </div>
            `).join('');
        }

        function removeFormCatatanBlock(id) {
            state.formCatatan = state.formCatatan.filter((c) => c.id !== id);
            renderFormCatatanList();
        }

        function collectFormCatatanForSave() {
            return state.formCatatan
                .map((c) => ({ judul: String(c.judul || '').trim(), isi: String(c.isi || '').trim() }))
                .filter((c) => c.judul || c.isi);
        }

        function bindCatatanModal() {
            $('btn-tambah-catatan')?.addEventListener('click', () => openCatatanModal());
            $('catatan-modal-save')?.addEventListener('click', saveCatatanFromModal);
            $('catatan-modal-cancel')?.addEventListener('click', closeCatatanModal);
            $('catatan-modal-close')?.addEventListener('click', closeCatatanModal);
            $('catatan-modal')?.addEventListener('click', (e) => {
                if (e.target.id === 'catatan-modal') closeCatatanModal();
            });
            $('form-catatan-list')?.addEventListener('click', (e) => {
                const editBtn = e.target.closest('.btn-edit-catatan');
                const delBtn = e.target.closest('.btn-remove-catatan');
                if (editBtn?.dataset?.id) openCatatanModal(editBtn.dataset.id);
                if (delBtn?.dataset?.id) removeFormCatatanBlock(delBtn.dataset.id);
            });
        }

        function renderCatatanDetailHtml(a) {
            const notes = getCatatanListFromApplicant(a);
            if (!notes.length) {
                return '<p class="text-slate-400 text-sm">Belum ada catatan.</p>';
            }
            return notes.map((n) => `
                <div class="catatan-block mb-3">
                    <p class="font-bold text-blue-700 dark:text-blue-400 text-sm mb-2">${escapeHtml(n.judul) || 'Tanpa judul'}</p>
                    <p class="text-sm whitespace-pre-wrap text-slate-700 dark:text-slate-200 leading-relaxed">${escapeHtml(n.isi) || '-'}</p>
                </div>
            `).join('');
        }

        function normalizeWhatsapp(raw) {
            let d = String(raw || '').replace(/\D/g, '');
            if (!d) return '';
            if (d.startsWith('0')) d = '62' + d.slice(1);
            if (!d.startsWith('62')) d = '62' + d;
            return d;
        }
        function parseMasihBekerjaSelect(val) {
            if (val === 'ya') return true;
            if (val === 'tidak') return false;
            return null;
        }
        function masihBekerjaToSelectValue(v) {
            if (v === true || v === 'ya') return 'ya';
            if (v === false || v === 'tidak') return 'tidak';
            return '';
        }
        function formatMasihBekerjaLabel(v) {
            if (v === true || v === 'ya') return 'Ya';
            if (v === false || v === 'tidak') return 'Tidak';
            return '—';
        }

        function formatWaUrl(raw, text) {
            const d = normalizeWhatsapp(raw);
            if (!d) return '';
            const base = `https://wa.me/${d}`;
            const t = String(text || '').trim();
            return t ? `${base}?text=${encodeURIComponent(t)}` : base;
        }

        function getUndanganByPosisi(a) {
            const raw = a?.undanganByPosisi;
            return raw && typeof raw === 'object' ? raw : {};
        }

        function getUndanganEntry(a, posisiName) {
            const key = normalizePosisiName(posisiName);
            if (!key) return null;
            const e = getUndanganByPosisi(a)[key];
            return e && typeof e === 'object' ? e : null;
        }

        function getUndanganTemplate() {
            return String(state.undanganTemplate || DEFAULT_UNDANGAN_TEMPLATE).trim() || DEFAULT_UNDANGAN_TEMPLATE;
        }

        function renderUndanganTemplate(vars) {
            let t = getUndanganTemplate();
            Object.entries(vars || {}).forEach(([k, v]) => {
                t = t.split(`{{${k}}}`).join(String(v ?? ''));
            });
            return t;
        }

        function formatUndanganJam(jam) {
            const j = String(jam || '').trim();
            if (!j) return '—';
            if (/WIB/i.test(j)) return j;
            return j + ' WIB';
        }

        function buildUndanganTextForApplicant(a, posisiName, entry) {
            const e = entry || getUndanganEntry(a, posisiName);
            let tglMulai = '—';
            let tglAkhir = '—';
            if (e?.periodId) {
                const p = state.interviewPeriods.find((x) => x.id === e.periodId);
                if (p) {
                    tglMulai = formatDateIdShort(p.tanggalMulai) || '—';
                    tglAkhir = formatDateIdShort(p.tanggalAkhir) || '—';
                }
            }
            return renderUndanganTemplate({
                nama: a?.nama || 'Pelamar',
                posisi: posisiName || '—',
                tanggalMulai: tglMulai,
                tanggalAkhir: tglAkhir,
                lokasi: e?.lokasi || UNDANGAN_LOKASI
            });
        }

        function getWaUndanganPosisiForApplicant(a, preferPosisi) {
            const pref = normalizePosisiName(preferPosisi);
            const list = getPosisiListFromApplicant(a);
            if (pref) {
                const e = getUndanganEntry(a, pref);
                if (e?.fase === 'undangan') return pref;
            }
            for (const p of list) {
                const e = getUndanganEntry(a, p);
                if (e?.fase === 'undangan') return p;
            }
            return '';
        }

        function getWaPrefillText(a, preferPosisi) {
            const pos = getWaUndanganPosisiForApplicant(a, preferPosisi);
            if (!pos) return '';
            return buildUndanganTextForApplicant(a, pos, getUndanganEntry(a, pos));
        }

        function waChatButtonHtml(whatsapp, label = 'WA', applicant = null, preferPosisi = '') {
            const prefill = applicant ? getWaPrefillText(applicant, preferPosisi || $('filter-posisi')?.value) : '';
            const url = formatWaUrl(whatsapp, prefill);
            if (!url) return '';
            const title = prefill ? 'WhatsApp dengan teks undangan' : 'Chat WhatsApp';
            return `<a href="${url}" target="_blank" rel="noopener" class="inline-flex items-center gap-1 px-2.5 py-1 rounded-lg bg-[#25D366] text-white text-[10px] font-bold hover:opacity-90" title="${escapeHtml(title)}"><i class="fa-brands fa-whatsapp"></i> ${label}</a>`;
        }

        function rsvpLabel(rsvp) {
            if (rsvp === 'hadir') return 'Hadir';
            if (rsvp === 'tidak_hadir') return 'Tidak bisa hadir';
            return 'Menunggu konfirmasi';
        }

        function renderUndanganBadgesHtml(a) {
            const list = getPosisiListFromApplicant(a);
            if (!list.length) return '';
            const parts = list.map((p) => {
                const e = getUndanganEntry(a, p);
                if (!e?.fase) return '';
                let cls = 'undangan-pill';
                if (e.fase === 'undangan_selesai') cls += ' selesai';
                if (e.rsvp === 'hadir') cls += ' rsvp-hadir';
                if (e.rsvp === 'tidak_hadir') cls += ' rsvp-tidak';
                const faseLabel = e.fase === 'undangan' ? 'Undangan' : 'Und. selesai';
                const rsvp = e.fase === 'undangan' && e.rsvp && e.rsvp !== 'menunggu' ? ` · ${rsvpLabel(e.rsvp)}` : '';
                return `<span class="${cls}">${escapeHtml(faseLabel)}: ${escapeHtml(p)}${escapeHtml(rsvp)}</span>`;
            }).filter(Boolean);
            return parts.length ? `<div class="flex flex-wrap gap-1 mt-1">${parts.join('')}</div>` : '';
        }

        /** Ringkasan singkat di kolom kanan kartu pelamar */
        function renderPelamarUndanganStatusHtml(a) {
            const list = getPosisiListFromApplicant(a);
            const lines = [];
            for (const p of list) {
                const e = getUndanganEntry(a, p);
                if (!e?.fase) continue;
                const fase = e.fase === 'undangan' ? 'Undangan' : 'Und. selesai';
                const rsvp = e.fase === 'undangan' && e.rsvp && e.rsvp !== 'menunggu'
                    ? ` · ${rsvpLabel(e.rsvp)}` : '';
                lines.push(`${fase}: ${p}${rsvp}`);
            }
            if (!lines.length) return '';
            return `<span class="block text-[9px] font-bold text-violet-700 dark:text-violet-300 mt-0.5 max-w-[9rem] text-right leading-tight" title="${escapeHtml(lines.join(' | '))}">${escapeHtml(lines.join(' · '))}</span>`;
        }

        async function promptUndanganPosisiForApplicant(a) {
            const list = getPosisiListFromApplicant(a);
            if (!list.length) {
                await Swal.fire('Posisi kosong', 'Pelamar belum punya posisi lamaran.', 'warning');
                return null;
            }
            const filterPos = normalizePosisiName($('filter-posisi')?.value || '');
            if (filterPos && list.some((p) => normalizePosisiName(p) === filterPos)) {
                return list.find((p) => normalizePosisiName(p) === filterPos) || filterPos;
            }
            if (list.length === 1) return list[0];
            const inputOptions = {};
            list.forEach((p) => { inputOptions[normalizePosisiName(p)] = p; });
            const { value, isConfirmed } = await Swal.fire({
                title: 'Pilih posisi untuk undangan',
                input: 'select',
                inputOptions,
                inputPlaceholder: 'Posisi',
                showCancelButton: true,
                confirmButtonText: 'Lanjut',
                cancelButtonText: 'Batal',
                confirmButtonColor: '#7c3aed'
            });
            return isConfirmed ? value : null;
        }

        function getUndanganJadwalPanelValues() {
            const tanggal = ($('hrd-undangan-tanggal')?.value || $('undangan-tanggal')?.value || '').trim();
            const jam = ($('hrd-undangan-jam')?.value || $('undangan-jam')?.value || '').trim();
            return { tanggal, jam };
        }

        function buildUndanganJadwalSwalHtml() {
            return `<div class="undangan-jadwal-form">
                <div class="undangan-jadwal-lokasi">
                    <i class="fa-solid fa-location-dot" aria-hidden="true"></i>
                    <span><strong>Lokasi:</strong> ${escapeHtml(UNDANGAN_LOKASI)}</span>
                </div>
                <p class="undangan-jadwal-hint">Tentukan jadwal wawancara. Jika sudah diisi di menu Undangan per divisi, nilai tersebut akan terisi otomatis.</p>
                <div class="undangan-jadwal-grid">
                    <div>
                        <label for="swal-undang-tgl">Tanggal <span class="req">*</span></label>
                        <input type="date" id="swal-undang-tgl" autocomplete="off">
                    </div>
                    <div>
                        <label for="swal-undang-jam">Jam <span class="req">*</span></label>
                        <input type="time" id="swal-undang-jam" autocomplete="off">
                    </div>
                </div>
            </div>`;
        }

        async function resolveUndanganJadwal() {
            const panel = getUndanganJadwalPanelValues();
            if (panel.tanggal && panel.jam) return panel;
            const res = await Swal.fire({
                title: 'Atur jadwal wawancara',
                html: buildUndanganJadwalSwalHtml(),
                customClass: { popup: 'swal-undangan-jadwal' },
                showCancelButton: true,
                confirmButtonText: 'Lanjut',
                cancelButtonText: 'Batal',
                confirmButtonColor: '#7c3aed',
                reverseButtons: true,
                focusConfirm: false,
                didOpen: () => {
                    const t = $('swal-undang-tgl');
                    const j = $('swal-undang-jam');
                    const pref = getUndanganJadwalPanelValues();
                    if (t) {
                        if (!t.value && pref.tanggal) t.value = pref.tanggal;
                        t.min = todayYmdLocal();
                    }
                    if (j && !j.value && pref.jam) j.value = pref.jam;
                    setTimeout(() => t?.focus(), 80);
                },
                preConfirm: () => {
                    const t = ($('swal-undang-tgl')?.value || '').trim();
                    const j = ($('swal-undang-jam')?.value || '').trim();
                    if (!t || !j) {
                        Swal.showValidationMessage('Tanggal dan jam wajib diisi');
                        return false;
                    }
                    if (t < todayYmdLocal()) {
                        Swal.showValidationMessage('Tanggal tidak boleh di masa lalu');
                        return false;
                    }
                    return { tanggal: t, jam: j };
                }
            });
            if (!res.isConfirmed || !res.value) return null;
            return res.value;
        }

        async function undangPelamarManual(applicantId) {
            const a = state.applicants.find((x) => x.id === applicantId);
            if (!a || !db) return;
            if (normalizeStatus(a.status) !== 'belum_dinilai') {
                await Swal.fire('Tidak bisa', 'Undangan manual hanya untuk pelamar <strong>Belum Dinilai</strong>.', 'info');
                return;
            }
            const posisi = await promptUndanganPosisiForApplicant(a);
            if (!posisi) return;
            const period = findActivePeriodForPosisi(posisi);
            if (!period) {
                await Swal.fire('Belum ada gelombang', 'Buat gelombang wawancara untuk posisi ini di menu <strong>Wawancara</strong> terlebih dahulu.', 'info');
                return;
            }
            const key = normalizePosisiName(posisi);
            const existing = getUndanganEntry(a, key);
            const preview = renderUndanganTemplate({
                nama: a.nama || 'Pelamar',
                posisi,
                tanggalMulai: formatDateIdShort(period.tanggalMulai),
                tanggalAkhir: formatDateIdShort(period.tanggalAkhir),
                lokasi: UNDANGAN_LOKASI
            });
            const ok = await Swal.fire({
                title: 'Undang via chat web?',
                html: `<p class="text-sm text-left mb-2"><strong>${escapeHtml(a.nama)}</strong> · ${escapeHtml(posisi)}</p>
                    <pre class="text-left text-[10px] bg-slate-50 dark:bg-slate-900 p-2 rounded-lg max-h-32 overflow-y-auto whitespace-pre-wrap">${escapeHtml(preview)}</pre>
                    <p class="text-xs text-slate-500 mt-2 text-left">Undangan dikirim ke chat portal pelamar (bukan WhatsApp).</p>`,
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: 'Kirim undangan',
                cancelButtonText: 'Batal',
                confirmButtonColor: '#7c3aed',
                width: 420
            });
            if (!ok.isConfirmed) return;
            const nowIso = new Date().toISOString();
            const map = { ...getUndanganByPosisi(a) };
            map[key] = {
                fase: 'undangan',
                periodId: period.id,
                lokasi: UNDANGAN_LOKASI,
                rsvp: existing?.rsvp === 'hadir' || existing?.rsvp === 'tidak_hadir' ? existing.rsvp : 'menunggu',
                undanganDimulaiAt: map[key]?.undanganDimulaiAt || nowIso
            };
            try {
                Swal.fire({ title: 'Mengirim...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
                await updateDoc(doc(db, COL_APPLICANTS, applicantId), {
                    undanganByPosisi: map,
                    updatedAt: serverTimestamp()
                });
                await sendUndanganChatMessage(applicantId, posisi, map[key]);
                await writeActivityLog({
                    type: 'undangan_mulai',
                    applicantId,
                    applicantName: a.nama,
                    posisi,
                    page: 'pelamar',
                    source: 'hrd'
                });
                Swal.close();
                showToast(`Undangan dikirim ke chat — ${a.nama}`);
                renderPelamarTable();
            } catch (e) {
                Swal.close();
                Swal.fire('Gagal', e.message || 'Undangan tidak terkirim', 'error');
            }
        }

        function getUndanganFilterPositions(a) {
            const posFilter = normalizePosisiName($('filter-posisi')?.value || '');
            const list = getPosisiListFromApplicant(a);
            if (posFilter) return list.filter((p) => normalizePosisiName(p) === posFilter);
            return list;
        }

        function applicantMatchesFaseUndanganFilter(a) {
            const fase = $('filter-fase-undangan')?.value || '';
            const list = getPosisiListFromApplicant(a);
            const checkPos = (p) => {
                const e = getUndanganEntry(a, p);
                const fk = e?.fase || '';
                if (fase === 'undangan') return fk === 'undangan';
                if (fase === 'undangan_selesai') return fk === 'undangan_selesai';
                if (fase === 'belum_diundang') return !fk;
                return true;
            };
            if (!fase) return true;
            const positions = getUndanganFilterPositions(a);
            if (!positions.length && $('filter-posisi')?.value) return fase === 'belum_diundang';
            return positions.length ? positions.some(checkPos) : list.some(checkPos);
        }

        /** Filter konfirmasi: hadir / tidak hadir / belum jawab (undangan aktif) */
        function applicantMatchesRsvpUndanganFilter(a) {
            const rsvpF = $('filter-rsvp-undangan')?.value || '';
            if (!rsvpF) return true;
            const positions = getUndanganFilterPositions(a);
            const pool = positions.length ? positions : getPosisiListFromApplicant(a);
            if (!pool.length) return false;
            return pool.some((p) => {
                const e = getUndanganEntry(a, p);
                if (!e?.fase) return false;
                const r = e.rsvp || 'menunggu';
                if (rsvpF === 'hadir') return r === 'hadir';
                if (rsvpF === 'tidak_hadir') return r === 'tidak_hadir';
                if (rsvpF === 'tidak_merespon') {
                    return e.fase === 'undangan' && r !== 'hadir' && r !== 'tidak_hadir';
                }
                return true;
            });
        }

        function renderMessageBubbleHtml(m, side, applicantId) {
            if (m?.type === 'undangan_wawancara') {
                const a = applicantId ? state.applicants.find((x) => x.id === applicantId) : null;
                const key = m.inviteKey || normalizePosisiName(m.posisi);
                const fromApp = a ? getUndanganEntry(a, key)?.rsvp : '';
                const rsvp = (fromApp && fromApp !== 'menunggu') ? fromApp : (m.rsvp || 'menunggu');
                const rsvpDone = rsvp === 'hadir' || rsvp === 'tidak_hadir';
                const rsvpBlock = side === 'pelamar' && !rsvpDone
                    ? `<p class="text-[10px] font-bold mt-2 mb-1">Konfirmasi kehadiran:</p>
                       <div class="flex flex-wrap gap-1" data-invite-pos="${escapeHtml(m.inviteKey || m.posisi || '')}">
                         <button type="button" class="btn-rsvp-undangan px-2 py-1 rounded-lg bg-emerald-600 text-white text-[10px] font-bold" data-rsvp="hadir">Saya hadir</button>
                         <button type="button" class="btn-rsvp-undangan px-2 py-1 rounded-lg bg-red-600 text-white text-[10px] font-bold" data-rsvp="tidak_hadir">Tidak bisa hadir</button>
                       </div>`
                    : (rsvpDone ? `<p class="text-[10px] font-bold mt-2 opacity-90">o" ${escapeHtml(rsvpLabel(rsvp))}</p>` : '');
                return `<div class="invite-card-hrd max-w-[95%] text-xs ${side === 'hrd' ? 'text-slate-800 dark:text-slate-100' : ''}">
                    <p class="font-bold text-violet-700 dark:text-violet-300 text-[10px] uppercase mb-1">Undangan wawancara · ${escapeHtml(m.posisi || '')}</p>
                    <p class="whitespace-pre-wrap leading-relaxed">${escapeHtml(m.text || '')}</p>${rsvpBlock}</div>`;
            }
            if (m?.type === 'undangan_rsvp') {
                return `<p class="italic opacity-90">${escapeHtml(m.text || rsvpLabel(m.rsvp))}</p>`;
            }
            return `<p>${escapeHtml(m.text || '')}</p>`;
        }

        async function sendUndanganChatMessage(applicantId, posisiName, entry) {
            const a = state.applicants.find((x) => x.id === applicantId);
            if (!a || !db) return;
            const text = buildUndanganTextForApplicant(a, posisiName, entry);
            const key = normalizePosisiName(posisiName);
            const msgRef = doc(db, COL_APPLICANTS, applicantId, SUB_MESSAGES, undanganMessageDocId('invite', key));
            await setDoc(msgRef, {
                type: 'undangan_wawancara',
                from: 'hrd',
                text,
                posisi: posisiName,
                inviteKey: key,
                periodId: entry.periodId || '',
                lokasi: entry.lokasi || UNDANGAN_LOKASI,
                rsvp: 'menunggu',
                createdAt: serverTimestamp()
            }, { merge: true });
            await touchChatThread(applicantId, 'hrd', `Undangan wawancara: ${posisiName}`);
        }

        function getSelectedUndanganPosisiList() {
            return [...document.querySelectorAll('#hrd-undangan-posisi-chks .undangan-pos-chk:checked')]
                .map((el) => normalizePosisiName(el.value)).filter(Boolean);
        }

        function countAffectedUndanganApplicants(posisiList, mode) {
            return state.applicants.filter((a) => {
                if (normalizeStatus(a.status) !== 'belum_dinilai') return false;
                const matched = getPosisiListFromApplicant(a).filter((p) => posisiList.includes(normalizePosisiName(p)));
                if (!matched.length) return false;
                if (mode === 'mulai') return true;
                return matched.some((p) => getUndanganEntry(a, p)?.fase === 'undangan');
            }).length;
        }

        function updateUndanganPreview() {
            const box = $('hrd-undangan-preview');
            if (!box) return;
            const tglMulai = $('hrd-wawancara-tgl-mulai')?.value || '';
            const tglAkhir = $('hrd-wawancara-tgl-akhir')?.value || '';
            const posisi = getSelectedUndanganPosisiList()[0] || 'POSISI';
            box.textContent = renderUndanganTemplate({
                nama: 'Nama Pelamar',
                posisi,
                tanggalMulai: formatDateIdShort(tglMulai) || '—',
                tanggalAkhir: formatDateIdShort(tglAkhir) || '—',
                lokasi: UNDANGAN_LOKASI
            });
            const hint = $('hrd-undangan-batch-hint');
            if (hint) {
                const n = countAffectedUndanganApplicants(getSelectedUndanganPosisiList(), 'mulai');
                hint.textContent = getSelectedUndanganPosisiList().length
                    ? `Perkiraan ${n} pelamar Belum Dinilai akan terdampak (terbitkan gelombang).`
                    : 'Centang minimal satu divisi.';
            }
        }

        function renderUndanganPosisiCheckboxes() {
            const host = $('hrd-undangan-posisi-chks');
            if (!host) return;
            const sorted = [...state.positions]
                .filter((p) => !isPositionDeleted(p.name))
                .sort((a, b) => (a.name || '').localeCompare(b.name || '', 'id'));
            if (!sorted.length) {
                host.innerHTML = '<p class="text-xs text-slate-400">Belum ada posisi di master.</p>';
                return;
            }
            host.innerHTML = sorted.map((p) => {
                const n = normalizePosisiName(p.name);
                const cnt = state.applicants.filter((a) =>
                    normalizeStatus(a.status) === 'belum_dinilai' && applicantMatchesPosisi(a, n)
                ).length;
                return `<label class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg border text-xs font-semibold cursor-pointer hover:bg-violet-50 dark:hover:bg-slate-700">
                    <input type="checkbox" class="undangan-pos-chk rounded" value="${escapeHtml(n)}"> ${escapeHtml(n)} <span class="text-slate-400">(${cnt})</span></label>`;
            }).join('');
            host.querySelectorAll('.undangan-pos-chk').forEach((el) => {
                el.addEventListener('change', updateUndanganPreview);
            });
            updateUndanganPreview();
        }

        async function saveUndanganTemplate() {
            if (!db) return;
            const tpl = ($('hrd-undangan-template')?.value || '').trim() || DEFAULT_UNDANGAN_TEMPLATE;
            await setDoc(doc(db, COL_META, META_DOC), {
                undanganTemplate: tpl,
                updatedAt: serverTimestamp()
            }, { merge: true });
            state.undanganTemplate = tpl;
            showToast('Template undangan disimpan');
            updateUndanganPreview();
        }

        async function mulaiUndanganBatch() {
            const posisiList = getSelectedUndanganPosisiList();
            const tanggal = $('undangan-tanggal')?.value || '';
            const jam = $('undangan-jam')?.value || '';
            const kirimChat = $('undangan-kirim-chat')?.checked !== false;
            if (!posisiList.length) {
                Swal.fire('Pilih divisi', 'Centang minimal satu posisi.', 'warning');
                return;
            }
            if (!tanggal || !jam) {
                Swal.fire('Jadwal', 'Isi tanggal dan jam wawancara.', 'warning');
                return;
            }
            const n = countAffectedUndanganApplicants(posisiList, 'mulai');
            const ok = await Swal.fire({
                title: 'Mulai undangan?',
                html: `<p>${n} pelamar <strong>Belum Dinilai</strong> pada posisi terpilih akan masuk fase <strong>Undangan</strong>.</p>${kirimChat ? '<p class="text-sm mt-2">Undangan akan dikirim ke chat web pelamar.</p>' : ''}`,
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: 'Ya, mulai',
                confirmButtonColor: '#7c3aed'
            });
            if (!ok.isConfirmed) return;
            const nowIso = new Date().toISOString();
            let updated = 0;
            let chats = 0;
            try {
                for (const a of state.applicants) {
                    if (normalizeStatus(a.status) !== 'belum_dinilai') continue;
                    const matched = getPosisiListFromApplicant(a).filter((p) => posisiList.includes(normalizePosisiName(p)));
                    if (!matched.length) continue;
                    const map = { ...getUndanganByPosisi(a) };
                    for (const p of matched) {
                        const key = normalizePosisiName(p);
                        map[key] = {
                            fase: 'undangan',
                            tanggal,
                            jam,
                            lokasi: UNDANGAN_LOKASI,
                            rsvp: 'menunggu',
                            undanganDimulaiAt: nowIso
                        };
                    }
                    await updateDoc(doc(db, COL_APPLICANTS, a.id), {
                        undanganByPosisi: map,
                        updatedAt: serverTimestamp()
                    });
                    updated++;
                    if (kirimChat) {
                        for (const p of matched) {
                            try {
                                await sendUndanganChatMessage(a.id, p, map[normalizePosisiName(p)]);
                                chats++;
                            } catch (msgErr) {
                                console.warn('sendUndanganChatMessage', a.id, p, msgErr);
                            }
                        }
                    }
                    for (const p of matched) {
                        await writeActivityLog({
                            type: 'undangan_mulai',
                            applicantId: a.id,
                            applicantName: a.nama,
                            posisi: p,
                            page: 'undangan',
                            source: 'hrd'
                        });
                    }
                }
                await writeActivityLog({
                    type: 'undangan_gelombang',
                    applicantName: posisiList.join(', '),
                    posisi: posisiList.join(', '),
                    page: 'undangan',
                    source: 'hrd'
                });
                showToast(`Undangan aktif: ${updated} pelamar${kirimChat ? `, ${chats} pesan chat` : ''}`);
                renderPelamarTable();
                updateUndanganPreview();
            } catch (e) {
                Swal.fire('Gagal', e.message || 'Tidak bisa menyimpan', 'error');
            }
        }

        function enumerateYmdRange(fromYmd, toYmd) {
            const out = [];
            if (!fromYmd || !toYmd || fromYmd > toYmd) return out;
            const d = new Date(fromYmd + 'T12:00:00');
            const end = new Date(toYmd + 'T12:00:00');
            while (d <= end) {
                out.push(`${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`);
                d.setDate(d.getDate() + 1);
            }
            return out;
        }

        function getWawancaraSessionTemplates() {
            const dual = $('hrd-iv-dual-session')?.checked;
            if (dual) {
                return [
                    {
                        slot: 'sesi1',
                        label: ($('hrd-iv-label-sesi1')?.value || 'Pagi').trim() || 'Pagi',
                        jamMulai: $('hrd-iv-jam-mulai-1')?.value,
                        jamSelesai: $('hrd-iv-jam-selesai-1')?.value,
                        kuotaMax: Math.max(1, parseInt($('hrd-wawancara-kuota-sesi1')?.value, 10) || 10)
                    },
                    {
                        slot: 'sesi2',
                        label: ($('hrd-iv-label-sesi2')?.value || 'Sore').trim() || 'Sore',
                        jamMulai: $('hrd-iv-jam-mulai-2')?.value,
                        jamSelesai: $('hrd-iv-jam-selesai-2')?.value,
                        kuotaMax: Math.max(1, parseInt($('hrd-wawancara-kuota-sesi2')?.value, 10) || 10)
                    }
                ];
            }
            return [{
                slot: 'utama',
                label: ($('hrd-iv-label-utama')?.value || 'Interview').trim() || 'Interview',
                jamMulai: $('hrd-iv-jam-mulai')?.value,
                jamSelesai: $('hrd-iv-jam-selesai')?.value,
                kuotaMax: Math.max(1, parseInt($('hrd-wawancara-kuota-utama')?.value, 10) || 10)
            }];
        }

        function findActivePeriodForPosisi(posisiName) {
            const pk = normalizePosisiName(posisiName);
            return state.interviewPeriods.find((p) =>
                p.status !== 'selesai' && (p.posisiList || []).some((x) => normalizePosisiName(x) === pk)
            );
        }

        async function publishWawancaraGelombang() {
            const posisiList = getSelectedUndanganPosisiList();
            const tanggalMulai = $('hrd-wawancara-tgl-mulai')?.value || '';
            const tanggalAkhir = $('hrd-wawancara-tgl-akhir')?.value || '';
            const kirimChat = $('hrd-undangan-kirim-chat')?.checked !== false;
            const templates = getWawancaraSessionTemplates();
            if (!posisiList.length) {
                Swal.fire('Pilih divisi', 'Centang minimal satu posisi.', 'warning');
                return;
            }
            if (!tanggalMulai || !tanggalAkhir) {
                Swal.fire('Jadwal', 'Isi tanggal mulai dan berakhir.', 'warning');
                return;
            }
            if (tanggalMulai > tanggalAkhir) {
                Swal.fire('Jadwal', 'Tanggal berakhir harus setelah atau sama dengan tanggal mulai.', 'warning');
                return;
            }
            for (const sl of templates) {
                const err = validateJamRange(sl.jamMulai, sl.jamSelesai);
                if (err) return Swal.fire('Jam', `${sl.label}: ${err}`, 'warning');
            }
            const dates = enumerateYmdRange(tanggalMulai, tanggalAkhir);
            if (!dates.length) return Swal.fire('Jadwal', 'Rentang tanggal tidak valid.', 'warning');
            const n = countAffectedUndanganApplicants(posisiList, 'mulai');
            const ok = await Swal.fire({
                title: 'Terbitkan gelombang wawancara?',
                html: `<p>${n} pelamar <strong>Belum Dinilai</strong> akan diundang.</p>
                    <p class="text-sm mt-2">${dates.length} hari × ${templates.length} sesi = <strong>${dates.length * templates.length}</strong> slot.</p>
                    ${kirimChat ? '<p class="text-sm mt-1">Undangan dikirim ke chat portal pelamar.</p>' : ''}`,
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: 'Ya, terbitkan',
                confirmButtonColor: '#7c3aed'
            });
            if (!ok.isConfirmed) return;
            const periodId = `p_${Date.now()}`;
            const nowIso = new Date().toISOString();
            Swal.fire({ title: 'Menerbitkan gelombang…', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
            let updated = 0;
            let chats = 0;
            try {
                await setDoc(doc(db, COL_INTERVIEW_PERIODS, periodId), {
                    tanggalMulai,
                    tanggalAkhir,
                    posisiList,
                    lokasi: UNDANGAN_LOKASI,
                    sessionTemplates: templates.map(({ slot, label, jamMulai, jamSelesai, kuotaMax }) =>
                        ({ slot, label, jamMulai, jamSelesai, kuotaMax })),
                    status: 'aktif',
                    createdAt: serverTimestamp(),
                    updatedAt: serverTimestamp()
                });
                for (const tanggal of dates) {
                    for (const sl of templates) {
                        const id = interviewSessionDocId(tanggal, sl.slot);
                        const ref = doc(db, COL_INTERVIEW_SESSIONS, id);
                        const snap = await getDoc(ref);
                        const payload = {
                            tanggal,
                            slot: sl.slot,
                            label: sl.label,
                            jamMulai: sl.jamMulai,
                            jamSelesai: sl.jamSelesai,
                            posisiList,
                            periodId,
                            kuotaMax: sl.kuotaMax,
                            registrationClosed: false,
                            updatedAt: serverTimestamp()
                        };
                        if (!snap.exists()) {
                            payload.terdaftar = 0;
                            payload.createdAt = serverTimestamp();
                        }
                        await setDoc(ref, payload, { merge: true });
                    }
                }
                for (const a of state.applicants) {
                    if (normalizeStatus(a.status) !== 'belum_dinilai') continue;
                    const matched = getPosisiListFromApplicant(a).filter((p) => posisiList.includes(normalizePosisiName(p)));
                    if (!matched.length) continue;
                    const map = { ...getUndanganByPosisi(a) };
                    for (const p of matched) {
                        const key = normalizePosisiName(p);
                        map[key] = {
                            fase: 'undangan',
                            periodId,
                            lokasi: UNDANGAN_LOKASI,
                            rsvp: 'menunggu',
                            undanganDimulaiAt: nowIso
                        };
                    }
                    await updateDoc(doc(db, COL_APPLICANTS, a.id), {
                        undanganByPosisi: map,
                        updatedAt: serverTimestamp()
                    });
                    updated++;
                    if (kirimChat) {
                        for (const p of matched) {
                            try {
                                await sendUndanganChatMessage(a.id, p, map[normalizePosisiName(p)]);
                                chats++;
                            } catch (msgErr) {
                                console.warn('sendUndanganChatMessage', a.id, p, msgErr);
                            }
                        }
                    }
                    for (const p of matched) {
                        await writeActivityLog({
                            type: 'undangan_mulai',
                            applicantId: a.id,
                            applicantName: a.nama,
                            posisi: p,
                            page: 'wawancara',
                            source: 'hrd'
                        });
                    }
                }
                await writeActivityLog({
                    type: 'undangan_gelombang',
                    applicantName: posisiList.join(', '),
                    posisi: posisiList.join(', '),
                    page: 'wawancara',
                    source: 'hrd'
                });
                Swal.close();
                showToast(`Gelombang diterbitkan: ${updated} pelamar${kirimChat ? `, ${chats} chat` : ''}`);
                renderPelamarTable();
                updateUndanganPreview();
                location.hash = `#wawancara/${periodId}`;
            } catch (e) {
                Swal.fire('Gagal', firestoreErrHint(e), 'error');
            }
        }

        async function tutupUndanganBatch() {
            const posisiList = getSelectedUndanganPosisiList();
            if (!posisiList.length) {
                Swal.fire('Pilih divisi', 'Centang minimal satu posisi.', 'warning');
                return;
            }
            const n = countAffectedUndanganApplicants(posisiList, 'tutup');
            const ok = await Swal.fire({
                title: 'Undangan selesai?',
                html: `<p>Fase undangan untuk posisi terpilih akan ditutup pada pelamar yang masih <strong>Undangan</strong> (${n} pelamar).</p><p class="text-sm mt-2">Tombol WhatsApp kembali tanpa teks undangan.</p>`,
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: 'Ya, tutup',
                confirmButtonColor: '#64748b'
            });
            if (!ok.isConfirmed) return;
            const nowIso = new Date().toISOString();
            try {
                let updated = 0;
                for (const a of state.applicants) {
                    const map = { ...getUndanganByPosisi(a) };
                    let changed = false;
                    for (const p of getPosisiListFromApplicant(a)) {
                        const key = normalizePosisiName(p);
                        if (!posisiList.includes(key)) continue;
                        if (map[key]?.fase !== 'undangan') continue;
                        map[key] = { ...map[key], fase: 'undangan_selesai', undanganSelesaiAt: nowIso };
                        changed = true;
                        await writeActivityLog({
                            type: 'undangan_selesai',
                            applicantId: a.id,
                            applicantName: a.nama,
                            posisi: p,
                            page: 'undangan',
                            source: 'hrd'
                        });
                    }
                    if (changed) {
                        await updateDoc(doc(db, COL_APPLICANTS, a.id), {
                            undanganByPosisi: map,
                            updatedAt: serverTimestamp()
                        });
                        updated++;
                    }
                }
                showToast(`Undangan ditutup: ${updated} pelamar`);
                renderPelamarTable();
            } catch (e) {
                Swal.fire('Gagal', e.message || 'Tidak bisa menyimpan', 'error');
            }
        }

        function getPosisiListFromApplicant(a) {
            if (Array.isArray(a?.posisiList) && a.posisiList.length) {
                return a.posisiList.map(normalizePosisiName).filter(Boolean);
            }
            const one = normalizePosisiName(a?.posisi);
            return one ? [one] : [];
        }

        function getPosisiDisplay(a) {
            const list = getPosisiListFromApplicant(a);
            return list.length ? list.join(', ') : '-';
        }

        function applicantMatchesPosisi(a, filterName) {
            const n = normalizePosisiName(filterName);
            if (!n) return true;
            return getPosisiListFromApplicant(a).some((p) => normalizePosisiName(p) === n);
        }

        function parsePosisiInputText(text) {
            return String(text || '').split(/[,;|]/).map(normalizePosisiName).filter(Boolean);
        }

        function getFormPosisiList() {
            return [...document.querySelectorAll('#form-posisi-multi .posisi-chk:checked')]
                .map((el) => normalizePosisiName(el.value)).filter(Boolean);
        }

        function getCvFilesFromApplicant(a) {
            if (Array.isArray(a?.cvFiles) && a.cvFiles.length) return a.cvFiles.filter((f) => f?.data);
            if (a?.cvFile?.data) return [a.cvFile];
            return [];
        }

        function resolveMediaDataUrl(item) {
            if (!item) return '';
            if (typeof item === 'string') return item.trim();
            if (typeof item === 'object' && item.data) return String(item.data).trim();
            if (typeof item === 'object' && item.url) return String(item.url).trim();
            return '';
        }

        function getDocPhotosFromApplicant(a) {
            if (!Array.isArray(a?.docPhotos)) return [];
            return a.docPhotos.map(resolveMediaDataUrl).filter(Boolean);
        }

        function inferApplicantCvDisplayMode(a) {
            if (a?.cvMode === 'pdf') return 'pdf';
            if (a?.cvMode === 'images') return 'images';
            const docs = getDocPhotosFromApplicant(a);
            const pdfs = getCvFilesFromApplicant(a);
            if (docs.length && !pdfs.length) return 'images';
            if (pdfs.length && !docs.length) return 'pdf';
            if (docs.length) return 'images';
            return pdfs.length ? 'pdf' : null;
        }

        function buildDetailCvHtml(a) {
            const docPhotos = getDocPhotosFromApplicant(a);
            const cvList = getCvFilesFromApplicant(a);
            const mode = inferApplicantCvDisplayMode(a);
            if (mode === 'images' && docPhotos.length) {
                return `<div class="grid grid-cols-2 md:grid-cols-4 gap-3">` +
                    docPhotos.map((src, i) =>
                        `<button type="button" class="doc-photo-card block w-full text-left aspect-[4/3] btn-doc-photo-view" data-doc-idx="${i}" title="Klik untuk perbesar">
                            <img src="${src}" class="w-full h-full object-cover pointer-events-none" alt="CV halaman ${i + 1}">
                            <span class="block text-center text-[10px] font-bold text-blue-600 py-1 bg-white/90">Perbesar</span>
                        </button>`
                    ).join('') +
                    `</div>`;
            }
            if (mode === 'pdf' && cvList.length) {
                return cvList.map((f, i) => {
                    const fname = escapeHtml(f.name || `dokumen-${i + 1}`);
                    const dl = `<a href="${f.data}" download="${fname}" class="inline-flex items-center gap-1 px-3 py-2 rounded-lg bg-slate-100 dark:bg-slate-700 text-slate-700 dark:text-slate-200 text-xs font-bold hover:bg-slate-200 dark:hover:bg-slate-600"><i class="fa-solid fa-download"></i> Unduh</a>`;
                    const view = isPdfMime(f.mime, f.name)
                        ? `<button type="button" class="btn-pdf-preview inline-flex items-center gap-1 px-3 py-2 rounded-lg bg-red-50 dark:bg-red-900/30 text-red-700 dark:text-red-300 text-xs font-bold hover:bg-red-100" data-pdf-idx="${i}"><i class="fa-solid fa-eye"></i> Lihat PDF</button>`
                        : `<button type="button" class="btn-doc-photo-view inline-flex items-center gap-1 px-3 py-2 rounded-lg bg-blue-50 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 text-xs font-bold hover:bg-blue-100" data-pdf-idx="${i}"><i class="fa-solid fa-eye"></i> Lihat</button>`;
                    return `<div class="flex flex-wrap items-center gap-2 py-2 border-b border-slate-100 dark:border-slate-700 last:border-0"><span class="text-sm font-semibold flex-1 min-w-0 truncate">${fname}</span>${view}${dl}</div>`;
                }).join('');
            }
            return '<p class="text-slate-400 text-sm">Tidak ada dokumen lamaran.</p>';
        }

        function bindDetailCvViewers(root, a) {
            if (!root) return;
            const docPhotos = getDocPhotosFromApplicant(a);
            const cvList = getCvFilesFromApplicant(a);
            const profilePhotos = (a.photos || []).filter(Boolean);
            root.querySelectorAll('.btn-profile-photo-view').forEach((btn) => {
                btn.addEventListener('click', () => {
                    const i = parseInt(btn.dataset.photoIdx, 10);
                    if (!Number.isNaN(i) && profilePhotos[i]) {
                        const src = resolveMediaDataUrl(profilePhotos[i]);
                        if (src) openImagePreview(src, `Foto diri ${i + 1}`);
                    }
                });
            });
            root.querySelectorAll('.btn-doc-photo-view').forEach((btn) => {
                btn.addEventListener('click', (e) => {
                    e.preventDefault();
                    const i = parseInt(btn.dataset.docIdx, 10);
                    if (!Number.isNaN(i) && docPhotos[i]) {
                        openImagePreview(docPhotos[i], `CV halaman ${i + 1}`);
                        return;
                    }
                    const pi = parseInt(btn.dataset.pdfIdx, 10);
                    const f = cvList[pi];
                    const src = f?.data ? resolveMediaDataUrl(f) : '';
                    if (src && !isPdfMime(f?.mime, f?.name)) openImagePreview(src, f.name || 'Dokumen');
                });
            });
            root.querySelectorAll('.btn-pdf-preview').forEach((btn) => {
                btn.addEventListener('click', () => {
                    const i = parseInt(btn.dataset.pdfIdx, 10);
                    const f = cvList[i];
                    if (f?.data) openPdfPreview(f.data, f.name || 'PDF');
                });
            });
        }

        function openImagePreview(dataUrl, title) {
            const modal = $('image-preview-modal');
            const img = $('image-preview-img');
            const resolved = resolveMediaDataUrl(dataUrl) || (typeof dataUrl === 'string' ? dataUrl.trim() : '');
            if (!modal || !img || !resolved) return;
            const titleEl = $('image-preview-title');
            if (titleEl) titleEl.textContent = title || 'Foto CV';
            img.src = resolved;
            modal.classList.add('is-open');
        }

        function closeImagePreview() {
            const img = $('image-preview-img');
            if (img) img.src = '';
            $('image-preview-modal')?.classList.remove('is-open');
        }

        function attachDocFieldsToPayload(payload, cvMode, cvFile, docPhotos) {
            const docs = (docPhotos || []).filter(Boolean);
            if (cvMode === 'pdf' && cvFile) {
                payload.cvMode = 'pdf';
                payload.cvFile = cvFile;
                payload.cvFiles = [cvFile];
                payload.docPhotos = [];
            } else if (cvMode === 'images' && docs.length) {
                payload.cvMode = 'images';
                payload.docPhotos = docs;
                payload.cvFile = null;
                payload.cvFiles = [];
            } else {
                payload.cvMode = null;
                payload.cvFile = null;
                payload.cvFiles = [];
                payload.docPhotos = [];
            }
        }

        function showUploadFailurePopupHrd(kind) {
            const pdfHtml = 'PDF terlalu besar (maks. ~800 KB). Gunakan foto/screenshot CV (hingga 4 slot) atau file PDF lebih ringkas.';
            const totalHtml = 'Total data terlalu besar. Kurangi foto CV atau hapus PDF, lalu simpan lagi.';
            Swal.fire({
                icon: 'warning',
                title: kind === 'pdf_size' ? 'PDF terlalu besar' : 'Data terlalu besar',
                text: kind === 'pdf_size' ? pdfHtml : totalHtml
            });
        }

        function isPdfMime(mime, name) {
            const m = String(mime || '').toLowerCase();
            const n = String(name || '').toLowerCase();
            return m.includes('pdf') || n.endsWith('.pdf');
        }

        function openPdfPreview(dataUrl, title) {
            const modal = $('pdf-preview-modal');
            const frame = $('pdf-preview-frame');
            if (!modal || !frame) return;
            $('pdf-preview-title').textContent = title || 'Pratinjau PDF';
            frame.src = dataUrl;
            modal.classList.add('is-open');
        }

        function closePdfPreview() {
            const frame = $('pdf-preview-frame');
            if (frame) frame.src = 'about:blank';
            $('pdf-preview-modal')?.classList.remove('is-open');
        }

        function getFormPosisi() {
            const list = getFormPosisiList();
            return list.length ? list.join(', ') : '';
        }

        function renderFormPosisiMulti(selectedList = []) {
            const host = $('form-posisi-multi');
            if (!host) return;
            const names = state.positions
                .map((p) => normalizePosisiName(p.name))
                .filter((n) => n && !isPositionDeleted(n))
                .sort((a, b) => a.localeCompare(b, 'id'));
            const sel = new Set(selectedList.map(normalizePosisiName));
            if (!names.length) {
                host.innerHTML = '<p class="text-xs text-amber-600 font-semibold">Belum ada posisi di master. Tambah lewat Kelola Posisi.</p>';
                return;
            }
            host.innerHTML = names.map((n) => {
                const on = sel.has(n) ? ' checked' : '';
                return `<label class="inline-flex items-center gap-2 px-3 py-2 rounded-xl border border-slate-200 dark:border-slate-600 bg-white/80 dark:bg-slate-900/80 text-sm cursor-pointer hover:border-blue-400">
                    <input type="checkbox" value="${escapeHtml(n)}" class="posisi-chk rounded text-blue-600 focus:ring-blue-500"${on}>
                    <span>${escapeHtml(n)}</span>
                </label>`;
            }).join('');
            host.querySelectorAll('.posisi-chk').forEach((el) => {
                el.addEventListener('change', () => {
                    const cnt = host.querySelectorAll('.posisi-chk:checked').length;
                    if (cnt > MAX_POSISI_SELECT) {
                        el.checked = false;
                        Swal.fire('Maksimal 2 posisi', 'Hanya boleh memilih dua posisi.', 'info');
                    }
                });
            });
        }

        function normalizePosisiName(name) {
            return String(name || '').replace(/\s+/g, ' ').trim();
        }

        /** ID tetap per posisi — cegah error "Document already exists" saat undangan/RSVP dikirim ulang */
        function undanganMessageDocId(kind, posisiName) {
            const k = normalizePosisiName(posisiName).toLowerCase()
                .replace(/[^a-z0-9]+/g, '-')
                .replace(/(^-|-$)/g, '') || 'posisi';
            return `${kind}_${k}`.slice(0, 120);
        }

        /** ID dokumen tetap per nama posisi — cegah duplikat saat seed ganda / dua tab sekaligus */
        function positionDocId(name) {
            const key = normalizePosisiName(name).toLowerCase()
                .replace(/[^a-z0-9]+/g, '-')
                .replace(/(^-|-$)/g, '');
            return 'pos-' + (key || 'lain');
        }

        function countPelamarByPosisi(name) {
            const n = normalizePosisiName(name);
            return state.applicants.filter((a) => applicantMatchesPosisi(a, n)).length;
        }

        /** Pelamar dengan status Diterima untuk posisi ini */
        function countDiterimaByPosisi(name) {
            const n = normalizePosisiName(name);
            return state.applicants.filter((a) =>
                normalizeStatus(a.status) === 'diterima' && applicantMatchesPosisi(a, n)
            ).length;
        }

        function isPositionDeleted(name) {
            const key = vacancyTitleKey(name);
            if (!key) return false;
            if (RETIRED_POSITION_KEYS.has(key)) return true;
            return (state.deletedPositionKeys || []).includes(key);
        }

        function renderLowonganTitleSelect(selectedTitle) {
            const sel = $('lowongan-title');
            if (!sel) return;
            const names = [...state.positions]
                .map((p) => normalizePosisiName(p.name))
                .filter((n) => n && !isPositionDeleted(n))
                .sort((a, b) => a.localeCompare(b, 'id'));
            const cur = normalizePosisiName(selectedTitle || sel.value || '');
            sel.innerHTML = '<option value="">— Pilih dari master posisi —</option>' +
                names.map((n) => `<option value="${escapeHtml(n)}">${escapeHtml(n)}</option>`).join('');
            if (cur && names.some((n) => n.toLowerCase() === cur.toLowerCase())) sel.value = cur;
            else if (cur) {
                sel.innerHTML += `<option value="${escapeHtml(cur)}" selected>${escapeHtml(cur)} (tidak di master)</option>`;
            }
        }

        async function markPositionDeletedInMeta(name) {
            const key = vacancyTitleKey(name);
            if (!key || !db) return;
            await setDoc(doc(db, COL_META, META_DOC), {
                deletedPositionKeys: arrayUnion(key),
                updatedAt: serverTimestamp()
            }, { merge: true });
            if (!state.deletedPositionKeys.includes(key)) state.deletedPositionKeys.push(key);
        }

        async function unmarkPositionDeletedInMeta(name) {
            const key = vacancyTitleKey(name);
            if (!key || !db) return;
            await setDoc(doc(db, COL_META, META_DOC), {
                deletedPositionKeys: arrayRemove(key),
                updatedAt: serverTimestamp()
            }, { merge: true });
            state.deletedPositionKeys = (state.deletedPositionKeys || []).filter((k) => k !== key);
        }

        function getAllPosisiNames() {
            const fromMaster = state.positions
                .map((p) => normalizePosisiName(p.name))
                .filter((n) => n && !isPositionDeleted(n));
            const fromApps = state.applicants
                .flatMap((a) => getPosisiListFromApplicant(a))
                .filter((n) => n && !isPositionDeleted(n));
            const merged = [...fromMaster];
            fromApps.forEach((n) => {
                if (n && !merged.some((m) => m.toLowerCase() === n.toLowerCase())) merged.push(n);
            });
            if (!merged.length) return DEFAULT_POSITIONS.filter((n) => !isPositionDeleted(n));
            return merged.sort((a, b) => a.localeCompare(b, 'id'));
        }

        function syncPosisiOptions() {
            const names = getAllPosisiNames();
            const datalist = $('posisi-datalist');
            if (datalist) {
                datalist.innerHTML = names.map((n) => `<option value="${escapeHtml(n)}"></option>`).join('');
            }
            const sel = $('filter-posisi');
            if (!sel) return;
            const current = sel.value;
            sel.innerHTML = '<option value="">Semua posisi</option>' +
                names.map((p) => `<option value="${escapeHtml(p)}">${escapeHtml(p)}</option>`).join('');
            if (names.includes(current)) sel.value = current;
        }

        // --- Info lowongan kerja (job_vacancies) ---
        function vacancyTitleKey(title) {
            return normalizePosisiName(title).toLowerCase();
        }

        /** Hanya pelamar status Diterima (ditetapkan HRD) untuk posisi ini */
        function countAcceptedApplicantsForVacancyTitle(title) {
            const key = vacancyTitleKey(title);
            if (!key) return 0;
            return state.applicants.filter((a) => {
                if (normalizeStatus(a.status) !== 'diterima') return false;
                return getPosisiListFromApplicant(a).some((p) => vacancyTitleKey(p) === key);
            }).length;
        }

        function collectAllLowonganSectionsFromEditor() {
            const host = $('lowongan-sections-editor');
            if (!host) return [];
            return [...host.querySelectorAll('.lowongan-sec-row')].map((wrap) => {
                const id = wrap.dataset.secId;
                const title = wrap.querySelector('.lowongan-sec-title')?.value ?? '';
                const body = wrap.querySelector('.lowongan-sec-body')?.value ?? '';
                return { id, title, body };
            });
        }

        function newLowonganSectionId() {
            return 'sec-' + Date.now().toString(36) + Math.random().toString(36).slice(2, 6);
        }

        function renderLowonganSectionsEditor(sections) {
            const host = $('lowongan-sections-editor');
            if (!host) return;
            const list = Array.isArray(sections) && sections.length ? sections : [{ id: newLowonganSectionId(), title: '', body: '' }];
            state.lowonganSections = list;
            host.innerHTML = list.map((s, idx) => `
                <div class="lowongan-sec-row rounded-xl border border-slate-200 dark:border-slate-700 p-3 space-y-2 bg-white dark:bg-slate-900" data-sec-id="${escapeHtml(s.id)}">
                    <div class="flex justify-between items-center gap-2">
                        <span class="text-[10px] font-bold text-slate-400">Blok ${idx + 1}</span>
                        <button type="button" class="lowongan-sec-rm text-xs font-bold text-red-600" data-sec-id="${escapeHtml(s.id)}">Hapus</button>
                    </div>
                    <input type="text" class="lowongan-sec-title w-full px-3 py-2 rounded-lg border dark:bg-slate-900 text-sm font-semibold" placeholder="Judul (mis. Persyaratan)" value="${escapeHtml(s.title || '')}" data-sec-id="${escapeHtml(s.id)}">
                    <textarea class="lowongan-sec-body w-full px-3 py-2 rounded-lg border dark:bg-slate-900 text-sm resize-y" rows="3" placeholder="Deskripsi (opsional)" data-sec-id="${escapeHtml(s.id)}">${escapeHtml(s.body || '')}</textarea>
                </div>`).join('');
            host.querySelectorAll('.lowongan-sec-rm').forEach((btn) => {
                btn.addEventListener('click', () => {
                    const id = btn.dataset.secId;
                    let next = collectAllLowonganSectionsFromEditor().filter((x) => x.id !== id);
                    if (!next.length) next = [{ id: newLowonganSectionId(), title: '', body: '' }];
                    renderLowonganSectionsEditor(next);
                });
            });
        }

        function collectLowonganSectionsFromEditor() {
            return collectAllLowonganSectionsFromEditor()
                .map((s) => ({ ...s, title: s.title.trim(), body: s.body.trim() }))
                .filter((s) => s.title || s.body);
        }

        function renderJobVacancyList() {
            const list = $('lowongan-list');
            const empty = $('lowongan-empty');
            if (!list) return;
            const items = (state.jobVacancies || []).slice().sort((a, b) => (a.title || '').localeCompare(b.title || '', 'id'));
            if (!items.length) {
                list.innerHTML = '';
                empty?.classList.remove('hidden');
                updateListPaginationUi('lowongan', 0, 0);
                return;
            }
            empty?.classList.add('hidden');
            const page = sliceForListPage('lowongan', items);
            list.innerHTML = page.items.map((v) => {
                const open = v.status !== 'filled';
                const cnt = countAcceptedApplicantsForVacancyTitle(v.title);
                const badge = open
                    ? '<span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-emerald-100 text-emerald-800">Dibuka</span>'
                    : '<span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-red-100 text-red-800">Terisi</span>';
                const pub = v.published === false ? '<span class="text-[10px] text-slate-400 ml-1">(disembunyikan)</span>' : '';
                const auto = v.autoCloseEnabled
                    ? `<span class="text-[10px] text-slate-500">Auto ?${v.autoCloseLimit || '—'} · ${cnt} diterima</span>`
                    : `<span class="text-[10px] text-slate-500">${cnt} diterima</span>`;
                return `<article class="rounded-2xl border p-4 bg-white/80 dark:bg-slate-800/80 flex flex-wrap gap-3 justify-between items-start">
                    <div class="min-w-0 flex-1">
                        <h4 class="font-bold text-lg">${escapeHtml(v.title || '—')}</h4>
                        <div class="flex flex-wrap gap-2 items-center mt-1">${badge}${pub} ${auto}</div>
                        <p class="text-xs text-slate-500 mt-2">${(v.sections || []).length} blok informasi</p>
                    </div>
                    <div class="flex flex-wrap gap-2 shrink-0">
                        <button type="button" class="vacancy-toggle px-3 py-1.5 rounded-lg text-xs font-bold border" data-id="${v.id}" data-next="${open ? 'filled' : 'open'}">${open ? 'Tutup manual' : 'Buka manual'}</button>
                        <a href="#lowongan/edit/${v.id}" class="px-3 py-1.5 rounded-lg text-xs font-bold bg-blue-600 text-white">Edit</a>
                    </div>
                </article>`;
            }).join('');
            updateListPaginationUi('lowongan', page.total, page.visible);
            list.querySelectorAll('.vacancy-toggle').forEach((btn) => {
                btn.addEventListener('click', async () => {
                    const id = btn.dataset.id;
                    const next = btn.dataset.next;
                    if (!id || !db) return;
                    try {
                        await updateDoc(doc(db, COL_JOB_VACANCIES, id), {
                            status: next,
                            statusLockedManual: true,
                            updatedAt: serverTimestamp()
                        });
                        showToast(next === 'filled' ? 'Lowongan ditutup' : 'Lowongan dibuka');
                    } catch (e) {
                        Swal.fire('Gagal', e.message || 'Status tidak tersimpan', 'error');
                    }
                });
            });
        }

        function resetLowonganForm() {
            $('lowongan-id').value = '';
            $('lowongan-form-heading').textContent = 'Lowongan baru';
            renderLowonganTitleSelect('');
            $('lowongan-status').value = 'open';
            $('lowongan-published').checked = true;
            $('lowongan-auto-close').checked = false;
            $('lowongan-auto-limit').value = '30';
            renderLowonganSectionsEditor([{ id: newLowonganSectionId(), title: '', body: '' }]);
        }

        function loadLowonganForm(id) {
            const v = state.jobVacancies.find((x) => x.id === id);
            if (!v) return;
            $('lowongan-id').value = id;
            $('lowongan-form-heading').textContent = 'Edit lowongan';
            renderLowonganTitleSelect(v.title || '');
            $('lowongan-status').value = v.status === 'filled' ? 'filled' : 'open';
            $('lowongan-published').checked = v.published !== false;
            $('lowongan-auto-close').checked = !!v.autoCloseEnabled;
            $('lowongan-auto-limit').value = String(v.autoCloseLimit || 30);
            const secs = Array.isArray(v.sections) && v.sections.length
                ? v.sections.map((s) => ({ id: s.id || newLowonganSectionId(), title: s.title || '', body: s.body || '' }))
                : [{ id: newLowonganSectionId(), title: '', body: '' }];
            renderLowonganSectionsEditor(secs);
        }

        async function saveLowonganForm(e) {
            e.preventDefault();
            if (!db) return;
            const title = normalizePosisiName($('lowongan-title')?.value || '');
            if (!title) return Swal.fire('Judul wajib', 'Isi judul posisi lowongan.', 'warning');
            const sections = collectLowonganSectionsFromEditor();
            const status = $('lowongan-status')?.value === 'filled' ? 'filled' : 'open';
            const payload = sanitizeFirestorePayload({
                title,
                titleKey: vacancyTitleKey(title),
                status,
                published: $('lowongan-published')?.checked !== false,
                sections,
                autoCloseEnabled: $('lowongan-auto-close')?.checked === true,
                autoCloseLimit: Math.max(1, parseInt($('lowongan-auto-limit')?.value, 10) || 30),
                statusLockedManual: true,
                updatedAt: serverTimestamp()
            });
            const id = $('lowongan-id')?.value?.trim();
            Swal.fire({ title: 'Menyimpan...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
            try {
                if (id) {
                    const prev = state.jobVacancies.find((x) => x.id === id);
                    if (prev && prev.status === status) delete payload.statusLockedManual;
                    await updateDoc(doc(db, COL_JOB_VACANCIES, id), payload);
                } else {
                    await addDoc(collection(db, COL_JOB_VACANCIES), {
                        ...payload,
                        statusLockedManual: false,
                        createdAt: serverTimestamp()
                    });
                    await ensurePositionInMaster(title);
                }
                Swal.close();
                showToast('Lowongan disimpan');
                location.hash = '#lowongan';
            } catch (err) {
                Swal.fire('Gagal', err.message || 'Tidak tersimpan', 'error');
            }
        }

        function scheduleVacancyAutoClose() {
            if (vacancyAutoCloseTimer) clearTimeout(vacancyAutoCloseTimer);
            vacancyAutoCloseTimer = setTimeout(() => syncVacancyAutoClose(), 800);
        }

        async function syncVacancyAutoClose() {
            if (!db || !state.jobVacancies?.length || !state.applicants?.length) return;
            for (const v of state.jobVacancies) {
                if (!v.autoCloseEnabled || v.status === 'filled' || v.statusLockedManual) continue;
                const limit = Math.max(1, parseInt(v.autoCloseLimit, 10) || 30);
                const cnt = countAcceptedApplicantsForVacancyTitle(v.title);
                if (cnt >= limit) {
                    try {
                        await updateDoc(doc(db, COL_JOB_VACANCIES, v.id), {
                            status: 'filled',
                            autoClosedAt: serverTimestamp(),
                            updatedAt: serverTimestamp()
                        });
                    } catch (e) {
                        console.warn('syncVacancyAutoClose', v.id, e);
                    }
                }
            }
        }

        function subscribeJobVacancies() {
            if (!db) return;
            if (jobVacanciesUnsub) jobVacanciesUnsub();
            jobVacanciesUnsub = onSnapshot(
                collection(db, COL_JOB_VACANCIES),
                (snap) => {
                    state.jobVacancies = snap.docs.map((d) => ({ id: d.id, ...d.data() }))
                        .sort((a, b) => (a.title || '').localeCompare(b.title || '', 'id'));
                    const route = parseRoute();
                    if (route.view === 'lowongan') renderJobVacancyList();
                    scheduleVacancyAutoClose();
                },
                (err) => console.error('job_vacancies', err)
            );
        }

        /** Muat blog, broadcast, log aktivitas, chat setelah daftar pelamar siap — percepat buka app */
        function startDeferredSubscriptions() {
            if (deferredSubsStarted || !db) return;
            deferredSubsStarted = true;
            subscribeBlogPosts();
            subscribeBroadcastPosts();
            subscribeActivityLog();
            subscribeChatThreads();
        }

        function bindLowonganForm() {
            $('form-lowongan')?.addEventListener('submit', saveLowonganForm);
            $('btn-lowongan-add-section')?.addEventListener('click', () => {
                const current = collectAllLowonganSectionsFromEditor();
                current.push({ id: newLowonganSectionId(), title: '', body: '' });
                renderLowonganSectionsEditor(current);
            });
        }

        // --- Wawancara (booking slot) ---
        function firestoreErrHint(err) {
            const m = String(err?.message || err || '');
            const code = String(err?.code || '');
            if (code === 'permission-denied' || /permission/i.test(m)) {
                const pid = firebaseConfig.projectId || 'project ini';
                return `Akses ditolak Firestore (project: ${pid}). Bukan cukup menyamakan file rules di PC — wajib di Console project ${pid}:\n\n`
                    + '1. Build → Authentication → Sign-in method → Anonymous → Enable → Save\n'
                    + '2. Build → Firestore Database → buat database (default) jika belum ada\n'
                    + '3. Firestore → Rules → salin isi firestore.rules → Publish (tunggu published)\n'
                    + '4. Jika App Check aktif untuk Firestore, matikan dulu atau izinkan domain hosting Anda';
            }
            if (/payload size exceeds|exceeds the limit/i.test(m)) {
                return 'Batch restore terlalu besar (foto/CV base64). Gunakan file HTML terbaru — restore menulis pelamar satu per satu. Jika masih gagal, ada dokumen pelamar > 1 MB; kurangi lampiran lalu export ulang.';
            }
            if (/quota exceeded|resource.exhausted|resource-exhausted/i.test(m)) {
                return 'Kuota Firebase (Firestore) hari ini sudah habis. Tutup tab HRD/portal yang tidak dipakai, tunggu reset harian, atau upgrade paket Blaze di Firebase Console → Usage.';
            }
            return m || 'Operasi gagal';
        }

        async function verifyFirestoreWriteAccess() {
            await ensureAnonAuth();
            if (!auth?.currentUser) {
                throw new Error('Sesi server belum aktif. Muat ulang halaman.');
            }
            const probeRef = doc(db, COL_META, '_restore_write_probe');
            await setDoc(probeRef, { probe: true, at: serverTimestamp() });
            await deleteDoc(probeRef);
        }

        function sortApplicantsListRows(rows) {
            return rows.sort((a, b) => {
                const ts = (x) => {
                    const c = x.createdAt;
                    if (c?.toMillis) return c.toMillis();
                    if (c?.seconds) return c.seconds * 1000;
                    return 0;
                };
                return ts(b) - ts(a);
            });
        }

        function invalidateApplicantsCache() {
            state.applicantsLoadedAt = 0;
        }

        /** Muat daftar pelamar sekali (bukan onSnapshot) — hemat read Firestore */
        async function loadApplicantsList(opts = {}) {
            const { force = false, silent = false } = opts;
            if (!db) return false;
            const now = Date.now();
            if (!force && state.applicants.length && state.applicantsLoadedAt
                && (now - state.applicantsLoadedAt) < APPLICANTS_LIST_CACHE_MS) {
                return true;
            }
            const btn = $('btn-pelamar-refresh');
            if (!silent && btn) btn.disabled = true;
            try {
                const snap = await withTimeout(
                    getDocs(query(collection(db, COL_APPLICANTS), listLight())),
                    FIRESTORE_OP_TIMEOUT_MS,
                    'Muat daftar pelamar'
                );
                state.applicants = sortApplicantsListRows(
                    snap.docs.map((d) => applicantDocToListRow(d.id, d.data()))
                );
                state.applicantsLoadedAt = now;
                syncPosisiOptions();
                syncStatusFilterOptions();
                refreshBackupImportHint();
                if (!deferredSubsStarted) setTimeout(startDeferredSubscriptions, 50);
                const hint = $('pelamar-list-hint');
                if (hint) {
                    const t = new Date().toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' });
                    hint.innerHTML = `Terakhir dimuat ${t}. Klik <strong>Muat ulang</strong> untuk data terbaru.`;
                }
                return true;
            } catch (e) {
                console.error('loadApplicantsList', e);
                if (!silent) {
                    $('boot-loader-text').textContent = 'Gagal memuat daftar pelamar. Coba Muat ulang.';
                }
                return false;
            } finally {
                if (!silent && btn) btn.disabled = false;
                if (!state.loaded) {
                    state.loaded = true;
                    setConn('connected', 'Terhubung');
                    hideBootHrd();
                }
            }
        }

        async function ensureApplicantsForRoute(route) {
            route = route || parseRoute();
            const views = ['pelamar', 'dashboard', 'chat', 'wawancara'];
            if (!views.includes(route.view)) return;
            
            const now = Date.now();
            const cacheValid = state.applicants && state.applicants.length > 0 
                && state.applicantsLoadedAt && (now - state.applicantsLoadedAt) < APPLICANTS_LIST_CACHE_MS;
                
            if (cacheValid) {
                // Cache is completely valid! Switch tabs instantly without background loads or redundant rendering
                return;
            }
            
            if (state.applicants && state.applicants.length > 0) {
                // Cache is expired, but we have data in memory. Switch instantly and update in the background silently.
                void loadApplicantsList({ force: false, silent: true }).then((ok) => {
                    if (ok) {
                        const cur = parseRoute().view;
                        if (cur === 'pelamar') renderPelamarTable();
                        if (cur === 'dashboard') renderDashboard();
                    }
                });
                return;
            }
            
            // If there are no applicants in memory at all, we must block and load them.
            await loadApplicantsList({
                force: false,
                silent: route.view !== 'pelamar'
            });
        }

        async function ensureApplicantsCacheForInterview() {
            await loadApplicantsList({ force: false, silent: true });
        }

        // --- Wawancara: monitor gelombang & booking ---
        function validateJamRange(jamMulai, jamSelesai) {
            const a = parseTimeToMinutes(jamMulai);
            const b = parseTimeToMinutes(jamSelesai);
            if (a == null || b == null) return 'Jam mulai dan selesai wajib diisi.';
            if (b <= a) return 'Jam selesai harus setelah jam mulai.';
            return null;
        }

        function getSessionsForPeriod(periodId) {
            return state.interviewSessions
                .filter((s) => s.periodId === periodId)
                .sort((a, b) => (a.tanggal || '').localeCompare(b.tanggal || '') || (a.slot || '').localeCompare(b.slot || ''));
        }

        function getPeriodBookingStats(periodId) {
            const sessions = getSessionsForPeriod(periodId);
            let terdaftar = 0;
            let kuota = 0;
            sessions.forEach((s) => {
                terdaftar += s.terdaftar || 0;
                kuota += s.kuotaMax || 0;
            });
            return { sessions: sessions.length, terdaftar, kuota };
        }

        function sessionIsBookable(s) {
            if (!s || s.registrationClosed) return false;
            if (s.tanggal < todayYmdLocal()) return false;
            return (s.terdaftar || 0) < (s.kuotaMax || 0);
        }

        function syncWawancaraTimeFieldsVisibility() {
            const dual = $('hrd-iv-dual-session')?.checked;
            $('hrd-iv-single-times')?.classList.toggle('hidden', !!dual);
            $('hrd-iv-dual-times')?.classList.toggle('hidden', !dual);
        }

        function subscribeInterviewBookings(sessionId) {
            if (!db || interviewBookingsUnsubs.has(sessionId)) return;
            const unsub = onSnapshot(
                collection(db, COL_INTERVIEW_SESSIONS, sessionId, SUB_BOOKINGS),
                (snap) => {
                    state.interviewBookings[sessionId] = snap.docs.map((d) => ({ id: d.id, ...d.data() }));
                    const route = parseRoute();
                    if (route.view === 'wawancara') renderWawancaraPanel(route);
                },
                (err) => console.error('interview bookings', sessionId, err)
            );
            interviewBookingsUnsubs.set(sessionId, unsub);
        }

        function unsubscribeInterviewBookings() {
            interviewBookingsUnsubs.forEach((u) => u());
            interviewBookingsUnsubs.clear();
            state.interviewBookings = {};
        }

        function syncInterviewBookingSubscriptions(route) {
            const periodId = route.periodId;
            if (!periodId) {
                unsubscribeInterviewBookings();
                return;
            }
            const ids = new Set(getSessionsForPeriod(periodId).map((s) => s.id));
            ids.forEach((sid) => subscribeInterviewBookings(sid));
            [...interviewBookingsUnsubs.keys()].forEach((sid) => {
                if (!ids.has(sid)) {
                    interviewBookingsUnsubs.get(sid)();
                    interviewBookingsUnsubs.delete(sid);
                    delete state.interviewBookings[sid];
                }
            });
        }

        function subscribeInterviewPeriods() {
            if (!db) return;
            if (interviewPeriodsUnsub) interviewPeriodsUnsub();
            interviewPeriodsUnsub = onSnapshot(
                collection(db, COL_INTERVIEW_PERIODS),
                (snap) => {
                    state.interviewPeriods = snap.docs
                        .map((d) => ({ id: d.id, ...d.data() }))
                        .sort((a, b) => {
                            const ca = a.createdAt?.toMillis?.() || a.createdAt?.seconds * 1000 || 0;
                            const cb = b.createdAt?.toMillis?.() || b.createdAt?.seconds * 1000 || 0;
                            return cb - ca;
                        });
                    const route = parseRoute();
                    if (route.view === 'wawancara') renderWawancaraPanel(route);
                },
                (err) => console.error('interview_periods', err)
            );
        }

        function subscribeInterviewSessions() {
            if (!db) return;
            if (interviewSessionsUnsub) interviewSessionsUnsub();
            interviewSessionsUnsub = onSnapshot(
                collection(db, COL_INTERVIEW_SESSIONS),
                (snap) => {
                    state.interviewSessions = snap.docs
                        .map((d) => ({ id: d.id, ...d.data() }))
                        .sort((a, b) => (b.tanggal || '').localeCompare(a.tanggal || '') || (a.slot || '').localeCompare(b.slot || ''));
                    const route = parseRoute();
                    syncInterviewBookingSubscriptions(route);
                    if (route.view === 'wawancara') renderWawancaraPanel(route);
                },
                (err) => console.error('interview_sessions', err)
            );
        }

        async function tutupWawancaraPeriod(periodId) {
            const period = state.interviewPeriods.find((p) => p.id === periodId);
            if (!period) return;
            const ok = await Swal.fire({
                title: 'Tutup gelombang wawancara?',
                html: `<p>Fase undangan untuk posisi <strong>${escapeHtml((period.posisiList || []).join(', '))}</strong> akan ditutup.</p>`,
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: 'Ya, tutup gelombang',
                confirmButtonColor: '#64748b'
            });
            if (!ok.isConfirmed) return;
            const nowIso = new Date().toISOString();
            Swal.fire({ title: 'Menutup gelombang…', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
            try {
                await updateDoc(doc(db, COL_INTERVIEW_PERIODS, periodId), {
                    status: 'selesai',
                    updatedAt: serverTimestamp()
                });
                const posSet = new Set((period.posisiList || []).map(normalizePosisiName));
                for (const a of state.applicants) {
                    const map = { ...getUndanganByPosisi(a) };
                    let changed = false;
                    for (const p of getPosisiListFromApplicant(a)) {
                        const key = normalizePosisiName(p);
                        if (!posSet.has(key)) continue;
                        if (map[key]?.fase !== 'undangan') continue;
                        if (map[key]?.periodId && map[key].periodId !== periodId) continue;
                        map[key] = { ...map[key], fase: 'undangan_selesai', undanganSelesaiAt: nowIso };
                        changed = true;
                    }
                    if (changed) {
                        await updateDoc(doc(db, COL_APPLICANTS, a.id), {
                            undanganByPosisi: map,
                            updatedAt: serverTimestamp()
                        });
                    }
                }
                Swal.close();
                showToast('Gelombang wawancara ditutup');
                renderPelamarTable();
                location.hash = '#wawancara';
            } catch (e) {
                Swal.fire('Gagal', firestoreErrHint(e), 'error');
            }
        }

        async function cancelInterviewBooking(sessionId, applicantId) {
            const ok = await Swal.fire({
                title: 'Batalkan booking?',
                text: 'Slot akan kosong kembali. Pelamar perlu booking ulang lewat chat atau manual HRD.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Ya, batalkan',
                confirmButtonColor: '#dc2626'
            });
            if (!ok.isConfirmed) return;
            const sessionRef = doc(db, COL_INTERVIEW_SESSIONS, sessionId);
            const bookingRef = doc(db, COL_INTERVIEW_SESSIONS, sessionId, SUB_BOOKINGS, applicantId);
            try {
                await runTransaction(db, async (tx) => {
                    const bSnap = await tx.get(bookingRef);
                    if (!bSnap.exists()) throw new Error('Booking tidak ditemukan');
                    tx.delete(bookingRef);
                    const sSnap = await tx.get(sessionRef);
                    if (sSnap.exists()) {
                        const cur = sSnap.data().terdaftar || 0;
                        tx.update(sessionRef, { terdaftar: Math.max(0, cur - 1), updatedAt: serverTimestamp() });
                    }
                });
                await updateDoc(doc(db, COL_APPLICANTS, applicantId), {
                    interviewBooking: deleteField(),
                    updatedAt: serverTimestamp()
                }).catch(() => {});
                showToast('Booking dibatalkan');
            } catch (e) {
                Swal.fire('Gagal', firestoreErrHint(e), 'error');
            }
        }

        async function hrdAssignInterviewBooking(applicantId, sessionId) {
            if (!state.applicants.length) await ensureApplicantsCacheForInterview();
            const session = state.interviewSessions.find((s) => s.id === sessionId);
            if (!session) return Swal.fire('Sesi', 'Sesi tidak ditemukan.', 'warning');
            let a = state.applicants.find((x) => x.id === applicantId);
            if (!a) {
                try { a = await loadApplicantFull(applicantId); } catch (e) { console.warn(e); }
            }
            if (!a) return Swal.fire('Pelamar', 'Data pelamar tidak ditemukan.', 'error');
            if (!applicantMatchesSessionPositions(a, session.posisiList)) {
                return Swal.fire('Posisi', 'Posisi pelamar tidak masuk sesi ini.', 'warning');
            }
            const existing = a.interviewBooking;
            if (existing?.sessionId === sessionId) {
                return Swal.fire('Sudah booking', 'Pelamar sudah terdaftar di sesi ini.', 'info');
            }
            Swal.fire({ title: 'Menyimpan booking…', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
            try {
                if (existing?.sessionId) await cancelInterviewBookingQuiet(existing.sessionId, applicantId);
                const posKey = getApplicantPosisiList(a).find((p) =>
                    (session.posisiList || []).map(normalizePosisiInterview).includes(p)
                ) || getApplicantPosisiList(a)[0] || '';
                await bookInterviewSlotCore(applicantId, sessionId, {
                    nama: a.nama,
                    posisi: posKey,
                    source: 'hrd_manual'
                });
                const map = { ...getUndanganMap(a) };
                const pk = normalizePosisiName(posKey);
                if (pk && map[pk]) map[pk] = { ...map[pk], rsvp: 'hadir' };
                await updateDoc(doc(db, COL_APPLICANTS, applicantId), {
                    undanganByPosisi: map,
                    updatedAt: serverTimestamp()
                }).catch(() => {});
                Swal.close();
                showToast(`Booking manual: ${a.nama}`);
            } catch (e) {
                Swal.fire('Gagal', firestoreErrHint(e), 'error');
            }
        }

        async function cancelInterviewBookingQuiet(sessionId, applicantId) {
            const sessionRef = doc(db, COL_INTERVIEW_SESSIONS, sessionId);
            const bookingRef = doc(db, COL_INTERVIEW_SESSIONS, sessionId, SUB_BOOKINGS, applicantId);
            await runTransaction(db, async (tx) => {
                const bSnap = await tx.get(bookingRef);
                if (!bSnap.exists()) return;
                tx.delete(bookingRef);
                const sSnap = await tx.get(sessionRef);
                if (sSnap.exists()) {
                    const cur = sSnap.data().terdaftar || 0;
                    tx.update(sessionRef, { terdaftar: Math.max(0, cur - 1), updatedAt: serverTimestamp() });
                }
            });
            await updateDoc(doc(db, COL_APPLICANTS, applicantId), {
                interviewBooking: deleteField(),
                updatedAt: serverTimestamp()
            }).catch(() => {});
        }

        async function bookInterviewSlotCore(applicantId, sessionId, meta) {
            const sessionRef = doc(db, COL_INTERVIEW_SESSIONS, sessionId);
            const bookingRef = doc(db, COL_INTERVIEW_SESSIONS, sessionId, SUB_BOOKINGS, applicantId);
            const applicantRef = doc(db, COL_APPLICANTS, applicantId);
            await runTransaction(db, async (tx) => {
                const sSnap = await tx.get(sessionRef);
                if (!sSnap.exists()) throw new Error('Sesi tidak ditemukan');
                const s = sSnap.data();
                if (s.registrationClosed) throw new Error('Pendaftaran sesi sudah ditutup');
                if (s.tanggal < todayYmdLocal()) throw new Error('Sesi sudah lewat');
                const max = s.kuotaMax || 0;
                const cur = s.terdaftar || 0;
                if (cur >= max) throw new Error('Kuota sesi sudah penuh');
                const existBook = await tx.get(bookingRef);
                if (existBook.exists()) throw new Error('Sudah terdaftar di sesi ini');
                const appSnap = await tx.get(applicantRef);
                if (appSnap.exists() && appSnap.data()?.interviewBooking?.sessionId) {
                    throw new Error('Pelamar sudah punya booking di sesi lain');
                }
                tx.update(sessionRef, { terdaftar: cur + 1, updatedAt: serverTimestamp() });
                tx.set(bookingRef, {
                    applicantId,
                    nama: meta.nama || '',
                    posisi: meta.posisi || '',
                    source: meta.source || 'portal',
                    bookedAt: serverTimestamp()
                });
                tx.update(applicantRef, {
                    interviewBooking: {
                        periodId: s.periodId || '',
                        sessionId,
                        tanggal: s.tanggal,
                        slot: s.slot,
                        label: s.label || s.slot,
                        jamMulai: s.jamMulai,
                        jamSelesai: s.jamSelesai,
                        posisi: meta.posisi || '',
                        lokasi: UNDANGAN_LOKASI
                    },
                    updatedAt: serverTimestamp()
                });
            });
        }

        async function setSessionRegistrationClosed(sessionId, closed) {
            try {
                await updateDoc(doc(db, COL_INTERVIEW_SESSIONS, sessionId), {
                    registrationClosed: closed,
                    updatedAt: serverTimestamp()
                });
                showToast(closed ? 'Pendaftaran sesi ditutup' : 'Pendaftaran sesi dibuka');
            } catch (e) {
                Swal.fire('Gagal', e.message, 'error');
            }
        }

        function renderWawancaraSessionBookingsTable(session) {
            const rows = state.interviewBookings[session.id] || [];
            const terdaftar = session.terdaftar || rows.length;
            const kuota = session.kuotaMax || 0;
            const dots = [];
            for (let i = 0; i < Math.min(kuota, 20); i++) {
                dots.push(`<span class="inline-block w-2 h-2 rounded-full ${i < terdaftar ? 'bg-violet-600' : 'bg-emerald-200 border border-emerald-400'}"></span>`);
            }
            const body = rows.length
                ? rows.map((r) => `<tr>
                    <td class="p-2 font-semibold">${escapeHtml(r.nama)}</td>
                    <td class="p-2 text-xs">${escapeHtml(r.posisi || '')}</td>
                    <td class="p-2 text-xs">${escapeHtml(r.source === 'hrd_manual' ? 'HRD manual' : 'Portal')}</td>
                    <td class="p-2 text-xs"><button type="button" class="btn-wa-batal-booking text-red-600 font-bold text-[10px]" data-sid="${session.id}" data-aid="${r.applicantId}">Batalkan</button></td>
                </tr>`).join('')
                : `<tr><td colspan="4" class="p-4 text-center text-slate-400 text-sm">Belum ada booking</td></tr>`;
            const rsvpCandidates = state.applicants.filter((a) =>
                applicantMatchesSessionPositions(a, session.posisiList) &&
                hasRsvpHadirForSession(a, session.posisiList) &&
                !rows.some((r) => r.applicantId === a.id) &&
                !a.interviewBooking?.sessionId
            );
            const manualBlock = rsvpCandidates.length && sessionIsBookable(session)
                ? `<div class="mt-3 p-3 rounded-xl border border-dashed border-slate-300">
                    <p class="text-xs font-bold text-slate-500 mb-2">Booking manual (HRD)</p>
                    <div class="flex flex-wrap gap-2 items-center">
                        <select id="wa-manual-add-${session.id}" class="text-xs px-2 py-1.5 rounded-lg border max-w-[220px]">
                            ${rsvpCandidates.map((a) => `<option value="${a.id}">${escapeHtml(a.nama)}</option>`).join('')}
                        </select>
                        <button type="button" class="btn-wa-manual-booking px-3 py-1.5 rounded-lg bg-violet-600 text-white text-xs font-bold" data-sid="${session.id}">Assign slot</button>
                    </div>
                </div>`
                : '';
            return `<p class="text-xs text-slate-500 mb-2 flex flex-wrap gap-1 items-center">${dots.join('')} <span class="ml-1 font-bold">${terdaftar}/${kuota}</span></p>
                <div class="overflow-x-auto rounded-xl border">
                    <table class="w-full text-sm"><thead><tr class="bg-slate-100 text-left text-[10px] uppercase">
                        <th class="p-2">Nama</th><th class="p-2">Posisi</th><th class="p-2">Sumber</th><th class="p-2">Aksi</th>
                    </tr></thead><tbody>${body}</tbody></table>
                </div>${manualBlock}`;
        }

        function renderWawancaraPeriodDetail(periodId) {
            const host = $('hrd-wa-period-detail');
            const period = state.interviewPeriods.find((p) => p.id === periodId);
            if (!host || !period) {
                host?.classList.add('view-hidden');
                return;
            }
            host.classList.remove('view-hidden');
            const sessions = getSessionsForPeriod(periodId);
            const stats = getPeriodBookingStats(periodId);
            host.innerHTML = `
                <div class="bg-white/80 rounded-2xl p-5 border space-y-4">
                    <button type="button" id="btn-wa-back-list" class="text-xs font-bold text-slate-500 hover:underline"><i class="fa-solid fa-arrow-left mr-1"></i> Daftar gelombang</button>
                    <div class="flex flex-wrap justify-between gap-3 items-start">
                        <div>
                            <h4 class="font-bold text-lg">${formatInterviewDateId(period.tanggalMulai)} — ${formatInterviewDateId(period.tanggalAkhir)}</h4>
                            <p class="text-xs text-slate-500 mt-1">${escapeHtml((period.posisiList || []).join(', '))}</p>
                            <p class="text-sm font-bold text-violet-700 mt-2">${stats.terdaftar}/${stats.kuota} booking · ${stats.sessions} sesi</p>
                        </div>
                        ${period.status !== 'selesai'
                            ? `<button type="button" class="btn-wa-tutup-period px-3 py-1.5 rounded-lg border border-slate-400 text-slate-700 text-xs font-bold" data-pid="${periodId}">Tutup gelombang</button>`
                            : '<span class="text-xs font-bold text-slate-400">Gelombang ditutup</span>'}
                    </div>
                    <div class="space-y-4">
                        ${sessions.map((s) => {
                            const full = (s.terdaftar || 0) >= (s.kuotaMax || 0);
                            const closed = s.registrationClosed;
                            return `<div class="p-4 rounded-xl border space-y-2">
                                <div class="flex flex-wrap justify-between gap-2 items-start">
                                    <div>
                                        <p class="font-bold text-sm">${formatInterviewDateId(s.tanggal)} · ${escapeHtml(s.label || s.slot)}</p>
                                        <p class="text-xs text-slate-500">${formatJamRange(s.jamMulai, s.jamSelesai)} · kuota ${s.kuotaMax || 0}</p>
                                    </div>
                                    <div class="flex flex-wrap gap-1">
                                        ${closed
                                            ? `<button type="button" class="btn-wa-buka-sesi px-2 py-1 rounded-lg bg-emerald-600 text-white text-[10px] font-bold" data-sid="${s.id}">Buka daftar</button>`
                                            : `<button type="button" class="btn-wa-tutup-sesi px-2 py-1 rounded-lg border border-red-300 text-red-600 text-[10px] font-bold" data-sid="${s.id}">Tutup daftar</button>`}
                                    </div>
                                </div>
                                <p class="text-[10px] font-bold ${full ? 'text-red-600' : 'text-emerald-700'}">${full ? 'Penuh' : closed ? 'Pendaftaran ditutup' : 'Masih ada slot'}</p>
                                ${renderWawancaraSessionBookingsTable(s)}
                            </div>`;
                        }).join('')}
                    </div>
                </div>`;
        }

        function renderWawancaraPeriodList(activePeriodId) {
            const host = $('hrd-wa-period-list');
            if (!host) return;
            const periods = state.interviewPeriods.filter((p) => p.status !== 'selesai').concat(
                state.interviewPeriods.filter((p) => p.status === 'selesai')
            );
            if (!periods.length) {
                host.innerHTML = '<p class="text-sm text-slate-500 p-4 rounded-xl border border-dashed">Belum ada gelombang. Terbitkan gelombang di form atas.</p>';
                return;
            }
            host.innerHTML = periods.map((p) => {
                const stats = getPeriodBookingStats(p.id);
                const active = p.id === activePeriodId;
                return `<button type="button" class="wa-period-pick w-full text-left p-4 rounded-xl border transition-colors ${active ? 'border-violet-500 bg-violet-50 ring-2 ring-violet-300' : 'border-slate-200 bg-white/80 hover:border-violet-400'}" data-pid="${p.id}">
                    <p class="font-bold text-sm">${formatInterviewDateId(p.tanggalMulai)} — ${formatInterviewDateId(p.tanggalAkhir)}</p>
                    <p class="text-[10px] text-slate-500 mt-1">${escapeHtml((p.posisiList || []).slice(0, 5).join(', '))}${(p.posisiList || []).length > 5 ? '…' : ''}</p>
                    <p class="text-xs mt-2"><span class="font-bold text-violet-700">${stats.terdaftar}/${stats.kuota}</span> booking · ${p.status === 'selesai' ? 'Ditutup' : 'Aktif'}</p>
                </button>`;
            }).join('');
        }

        function renderWawancaraPanel(route) {
            route = route || parseRoute();
            renderUndanganPosisiCheckboxes();
            syncWawancaraTimeFieldsVisibility();
            const tglMulai = $('hrd-wawancara-tgl-mulai');
            const tglAkhir = $('hrd-wawancara-tgl-akhir');
            if (tglMulai && !tglMulai.value) tglMulai.value = todayYmdLocal();
            if (tglAkhir && !tglAkhir.value) tglAkhir.value = todayYmdLocal();
            renderWawancaraPeriodList(route.periodId || null);
            if (route.periodId) renderWawancaraPeriodDetail(route.periodId);
            else $('hrd-wa-period-detail')?.classList.add('view-hidden');
        }

        function bindWawancaraPanelEvents() {
            $('hrd-btn-wawancara-terbitkan')?.addEventListener('click', publishWawancaraGelombang);
            $('hrd-iv-dual-session')?.addEventListener('change', () => {
                syncWawancaraTimeFieldsVisibility();
                updateUndanganPreview();
            });
            $('hrd-wawancara-tgl-mulai')?.addEventListener('change', updateUndanganPreview);
            $('hrd-wawancara-tgl-akhir')?.addEventListener('change', updateUndanganPreview);
            ['wawancara-kuota-utama', 'wawancara-kuota-sesi1', 'wawancara-kuota-sesi2'].forEach((id) => {
                $(id)?.addEventListener('input', updateUndanganPreview);
            });
            $('hrd-wa-period-list')?.addEventListener('click', (e) => {
                const btn = e.target.closest('.wa-period-pick');
                if (btn?.dataset?.pid) location.hash = `#wawancara/${btn.dataset.pid}`;
            });
            $('hrd-wa-period-detail')?.addEventListener('click', async (e) => {
                if (e.target.id === 'btn-wa-back-list' || e.target.closest('#btn-wa-back-list')) {
                    location.hash = '#wawancara';
                    return;
                }
                const tutup = e.target.closest('.btn-wa-tutup-period');
                const tutupSesi = e.target.closest('.btn-wa-tutup-sesi');
                const bukaSesi = e.target.closest('.btn-wa-buka-sesi');
                const batalBook = e.target.closest('.btn-wa-batal-booking');
                const manualBook = e.target.closest('.btn-wa-manual-booking');
                if (tutup?.dataset?.pid) await tutupWawancaraPeriod(tutup.dataset.pid);
                if (tutupSesi?.dataset?.sid) await setSessionRegistrationClosed(tutupSesi.dataset.sid, true);
                if (bukaSesi?.dataset?.sid) await setSessionRegistrationClosed(bukaSesi.dataset.sid, false);
                if (batalBook?.dataset?.sid && batalBook?.dataset?.aid) {
                    await cancelInterviewBooking(batalBook.dataset.sid, batalBook.dataset.aid);
                }
                if (manualBook?.dataset?.sid) {
                    const sel = document.getElementById(`wa-manual-add-${manualBook.dataset.sid}`);
                    const aid = sel?.value;
                    if (!aid) return Swal.fire('Pilih pelamar', 'Pilih nama dari daftar.', 'warning');
                    await hrdAssignInterviewBooking(aid, manualBook.dataset.sid);
                }
            });
            syncWawancaraTimeFieldsVisibility();
        }

        // --- Routing ---
        function parseRoute() {
            const hash = (location.hash || '#dashboard').replace(/^#/, '');
            const parts = hash.split('/').filter(Boolean);
            if (parts[0] === 'pelamar' && parts[1] === 'edit' && parts[2]) return { view: 'form', id: parts[2], mode: 'edit' };
            if (parts[0] === 'pelamar' && parts[1] === 'baru') return { view: 'form', id: null, mode: 'new' };
            if (parts[0] === 'pelamar' && parts[1] && parts[2] === 'pesan') return { view: 'detail', id: parts[1], tab: 'pesan' };
            if (parts[0] === 'pelamar' && parts[1] && (parts[2] === 'aktivitas' || parts[2] === 'kunjungan')) {
                return { view: 'detail', id: parts[1], tab: 'aktivitas' };
            }
            if (parts[0] === 'pelamar' && parts[1]) return { view: 'detail', id: parts[1], tab: 'profil' };
            if (parts[0] === 'pelamar') return { view: 'pelamar' };
            if (parts[0] === 'posisi') return { view: 'posisi' };
            if (parts[0] === 'lowongan' && parts[1] === 'edit' && parts[2]) return { view: 'lowongan-form', id: parts[2], mode: 'edit' };
            if (parts[0] === 'lowongan' && parts[1] === 'baru') return { view: 'lowongan-form', id: null, mode: 'new' };
            if (parts[0] === 'lowongan') return { view: 'lowongan' };
            if (parts[0] === 'aktivitas') return { view: 'aktivitas' };
            if (parts[0] === 'broadcast' && parts[1] === 'edit' && parts[2]) return { view: 'broadcast-form', id: parts[2], mode: 'edit' };
            if (parts[0] === 'broadcast' && parts[1] === 'baru') return { view: 'broadcast-form', id: null, mode: 'new' };
            if (parts[0] === 'broadcast') return { view: 'blog' };
            if (parts[0] === 'blog' && parts[1] === 'edit' && parts[2]) return { view: 'blog-form', id: parts[2], mode: 'edit' };
            if (parts[0] === 'blog' && parts[1] === 'baru') return { view: 'blog-form', id: null, mode: 'new' };
            if (parts[0] === 'blog') return { view: 'blog' };
            if (parts[0] === 'pengaturan') return { view: 'pengaturan' };
            if (parts[0] === 'wawancara' && parts[1]) return { view: 'wawancara', periodId: parts[1] };
            if (parts[0] === 'wawancara' || parts[0] === 'undangan' || parts[0] === 'interview') return { view: 'wawancara', periodId: null };
            if (parts[0] === 'chat' && parts[1]) return { view: 'chat', chatId: parts[1] };
            if (parts[0] === 'chat') return { view: 'chat', chatId: null };
            if (parts[0] === 'login') return { view: 'login' };
            return { view: 'dashboard' };
        }

        function showView(name) {
            if (name === 'login') return;
            if (!getSession()) {
                window.__SENCHA__.showPelamarPublic();
                return;
            }
                        document.querySelectorAll('#view-hrd-app .view-panel').forEach((p) => p.classList.add('view-hidden'));
            const titles = {
                dashboard: 'Dashboard', pelamar: 'Daftar Pelamar', form: 'Form Pelamar',
                detail: 'Detail Pelamar', posisi: 'Kelola Posisi',
                lowongan: 'Info Lowongan', 'lowongan-form': 'Form Lowongan',
                blog: 'Info / Blog', 'blog-form': 'Artikel',
                'broadcast-form': 'Broadcast',                 aktivitas: 'Log Aktivitas', pengaturan: 'Pengaturan',
                chat: 'Chat Pelamar', wawancara: 'Wawancara'
            };
            $('hrd-page-title').textContent = titles[name] || 'SENCHA HRD';
            if (name === 'dashboard') $('hrd-panel-dashboard').classList.remove('view-hidden');
            if (name === 'pelamar') $('hrd-panel-pelamar').classList.remove('view-hidden');
            if (name === 'form') $('hrd-panel-form').classList.remove('view-hidden');
            if (name === 'detail') $('hrd-panel-detail').classList.remove('view-hidden');
            if (name === 'posisi') $('hrd-panel-posisi').classList.remove('view-hidden');
            if (name === 'lowongan') $('hrd-panel-lowongan').classList.remove('view-hidden');
            if (name === 'lowongan-form') $('hrd-panel-lowongan-form').classList.remove('view-hidden');
            if (name === 'blog') $('hrd-panel-blog').classList.remove('view-hidden');
            if (name === 'blog-form') $('hrd-panel-blog-form').classList.remove('view-hidden');
            if (name === 'broadcast-form') $('hrd-panel-broadcast-form').classList.remove('view-hidden');
            if (name === 'aktivitas') $('hrd-panel-aktivitas').classList.remove('view-hidden');
            if (name === 'chat') $('hrd-panel-chat').classList.remove('view-hidden');
            if (name === 'pengaturan') $('hrd-panel-pengaturan').classList.remove('view-hidden');
            if (name === 'wawancara') $('hrd-panel-wawancara').classList.remove('view-hidden');
            document.querySelectorAll('#view-hrd-app .nav-link').forEach((a) => {
                const nav = a.dataset.nav;
                const active = nav === name
                    || (nav === 'form' && name === 'form')
                    || (nav === 'blog' && (name === 'blog' || name === 'blog-form' || name === 'broadcast-form'))
                    || (nav === 'aktivitas' && name === 'aktivitas')
                    || (nav === 'chat' && name === 'chat')
                    || (nav === 'wawancara' && name === 'wawancara')
                    || (nav === 'lowongan' && (name === 'lowongan' || name === 'lowongan-form'));
                a.classList.toggle('bg-[#e8f5e3]', active);
                a.classList.toggle('text-[#2d6a3e]', active);
            });
        }

        function isMobileNavViewport() {
            return window.matchMedia('(max-width: 1023px)').matches;
        }

        function setMobileNavOpen(open) {
            document.body.classList.toggle('mobile-nav-open', !!open);
            const btn = $('btn-mobile-menu');
            const backdrop = $('sidebar-backdrop');
            if (btn) btn.setAttribute('aria-expanded', open ? 'true' : 'false');
            if (backdrop) backdrop.setAttribute('aria-hidden', open ? 'false' : 'true');
        }

        function closeMobileNav() {
            setMobileNavOpen(false);
        }

        function openMobileNav() {
            if (isMobileNavViewport()) setMobileNavOpen(true);
        }

        function toggleMobileNav() {
            if (!isMobileNavViewport()) return;
            setMobileNavOpen(!document.body.classList.contains('mobile-nav-open'));
        }

        function setHrdMobileNavOpen(open) {
            document.body.classList.toggle('hrd-mobile-nav-open', !!open);
            const btn = $('hrd-btn-mobile-menu');
            const backdrop = $('hrd-sidebar-backdrop');
            if (btn) btn.setAttribute('aria-expanded', open ? 'true' : 'false');
            if (backdrop) backdrop.setAttribute('aria-hidden', open ? 'false' : 'true');
        }
        function closeHrdMobileNav() {
            setHrdMobileNavOpen(false);
        }
        function bindHrdMobileNav() {
            $('hrd-btn-mobile-menu')?.addEventListener('click', () => {
                if (!isMobileNavViewport()) return;
                setHrdMobileNavOpen(!document.body.classList.contains('hrd-mobile-nav-open'));
            });
            $('hrd-btn-sidebar-close')?.addEventListener('click', closeHrdMobileNav);
            $('hrd-sidebar-backdrop')?.addEventListener('click', closeHrdMobileNav);
            document.querySelectorAll('#hrd-app-sidebar .nav-link').forEach((a) => {
                a.addEventListener('click', () => {
                    if (isMobileNavViewport()) closeHrdMobileNav();
                });
            });
            window.addEventListener('resize', () => {
                if (!isMobileNavViewport()) closeHrdMobileNav();
            });
            document.addEventListener('keydown', (e) => {
                if (e.key === 'Escape' && document.body.classList.contains('hrd-mobile-nav-open')) closeHrdMobileNav();
            });
        }

        async function navigate() {
            startDeferredSubscriptions();
            closeBlogPreviewModal();
            closeBroadcastPreviewModal();
            const route = parseRoute();
            if (!getSession()) return;
            closeMobileNav();
            const sess = getSession();
            $('hrd-user-label').textContent = sess?.username ? `@${sess.username}` : '';
            setBackupImportUiVisible(true);
            if (route.view === 'form') {
                showView('form');
                if (route.mode === 'edit' && route.id) loadFormForEdit(route.id);
                else resetForm();
            } else if (route.view === 'blog-form') {
                showView('blog-form');
                if (route.mode === 'edit' && route.id) loadBlogForm(route.id);
                else resetBlogForm();
            } else if (route.view === 'broadcast-form') {
                showView('broadcast-form');
                if (route.mode === 'edit' && route.id) loadBroadcastForm(route.id);
                else resetBroadcastForm();
            } else if (route.view === 'lowongan-form') {
                showView('lowongan-form');
                if (route.mode === 'edit' && route.id) loadLowonganForm(route.id);
                else resetLowonganForm();
                renderLowonganTitleSelect($('lowongan-title')?.value);
            } else if (route.view === 'detail') {
                showView('detail');
                void renderDetail(route.id, route.tab || 'profil');
            } else {
                await ensureApplicantsForRoute(route);
                showView(route.view);
                if (route.view === 'pelamar') renderPelamarTable();
                if (route.view === 'dashboard') renderDashboard();
                    if (route.view === 'posisi') renderPosisiPanel();
                    if (route.view === 'lowongan-form') renderLowonganTitleSelect($('lowongan-title')?.value);
                    if (route.view === 'lowongan') renderJobVacancyList();
                if (route.view === 'blog') {
                    renderBlogList();
                    renderBroadcastList();
                }
                if (route.view === 'aktivitas') renderActivityLogList();
                if (route.view === 'pengaturan') renderPengaturanPanel();
                if (route.view === 'chat') {
                    renderChatInbox();
                    if (route.chatId) selectChatHubApplicant(route.chatId);
                    else if (state.chatHubApplicantId) selectChatHubApplicant(state.chatHubApplicantId);
                }
                if (route.view === 'wawancara') {
                    renderWawancaraPanel(route);
                }
            }
        }

        function renderPengaturanPanel() {
            const cb = $('hrd-toggle-fake-activity');
            if (cb) cb.checked = state.fakeActivityEnabled !== false;
            const tpl = $('hrd-undangan-template');
            if (tpl && tpl.value !== getUndanganTemplate()) tpl.value = getUndanganTemplate();
            const rejectTpl = $('hrd-status-reject-template');
            if (rejectTpl && rejectTpl.value !== getStatusRejectTemplate()) rejectTpl.value = getStatusRejectTemplate();
        }

        async function saveStatusRejectTemplate() {
            if (!db) return;
            const tpl = ($('hrd-status-reject-template')?.value || '').trim() || DEFAULT_STATUS_REJECT_TEMPLATE;
            await setDoc(doc(db, COL_META, META_DOC), {
                statusRejectChatTemplate: tpl,
                updatedAt: serverTimestamp()
            }, { merge: true });
            state.statusRejectTemplate = tpl;
            showToast('Template chat Tidak Diterima disimpan');
        }

        async function saveFakeActivitySetting(enabled) {
            if (!db) return;
            await setDoc(doc(db, COL_META, META_DOC), {
                fakeActivityFeed: { enabled: !!enabled, updatedAt: serverTimestamp() }
            }, { merge: true });
            state.fakeActivityEnabled = !!enabled;
            showToast(enabled ? 'Notifikasi portal pelamar aktif' : 'Notifikasi portal pelamar nonaktif');
        }

        function subscribeAppMeta() {
            if (!db) return;
            if (metaUnsub) metaUnsub();
            metaUnsub = onSnapshot(doc(db, COL_META, META_DOC), (snap) => {
                const data = snap.exists() ? snap.data() : {};
                const enabled = data?.fakeActivityFeed?.enabled;
                state.fakeActivityEnabled = enabled !== false;
                state.deletedPositionKeys = Array.isArray(data?.deletedPositionKeys)
                    ? data.deletedPositionKeys.filter(Boolean)
                    : [];
                state.undanganTemplate = String(data?.undanganTemplate || '').trim() || DEFAULT_UNDANGAN_TEMPLATE;
                state.statusRejectTemplate = String(data?.statusRejectChatTemplate || '').trim() || DEFAULT_STATUS_REJECT_TEMPLATE;
                syncPosisiOptions();
                if (parseRoute().view === 'wawancara') renderWawancaraPanel(parseRoute());
                if (parseRoute().view === 'posisi') renderPosisiPanel();
                if (parseRoute().view === 'pengaturan') renderPengaturanPanel();
                if (parseRoute().view === 'lowongan-form') renderLowonganTitleSelect($('lowongan-title')?.value);
                if (parseRoute().view === 'pelamar-form') renderFormPosisiMulti(getFormPosisiList());
            }, (err) => console.error('meta snapshot', err));
        }

        function formatTs(ts) {
            if (!ts) return '-';
            try {
                const d = ts.toDate ? ts.toDate() : new Date(ts);
                return d.toLocaleString('id-ID', { day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' });
            } catch { return '-'; }
        }

        function blogSortKey(p) {
            const u = p.updatedAt;
            if (u?.toMillis) return u.toMillis();
            if (u?.seconds) return u.seconds * 1000;
            return 0;
        }

        function getFilteredBlogPosts() {
            const f = $('blog-filter')?.value || '';
            return state.blogPosts.filter((p) => {
                if (f === 'published') return p.published === true;
                if (f === 'draft') return !p.published;
                return true;
            });
        }

        function blogExcerpt(text, max = 110) {
            const s = String(text || '').trim();
            if (s.length <= max) return s;
            return s.slice(0, max).trim() + '\u2026';
        }

        function renderBlogGallery(el, photos) {
            if (!el) return;
            const list = Array.isArray(photos) ? photos.filter(Boolean) : [];
            if (!list.length) {
                el.innerHTML = '';
                el.classList.add('view-hidden');
                return;
            }
            const cols = list.length === 1 ? 'grid-cols-1' : list.length === 2 ? 'grid-cols-2' : 'grid-cols-1 sm:grid-cols-3';
            el.className = `blog-gallery grid gap-0.5 bg-slate-100 dark:bg-slate-900 ${cols}`;
            el.classList.remove('view-hidden');
            el.innerHTML = list.map((url) =>
                `<div class="gallery-cell"><img src="${url}" alt=""></div>`
            ).join('');
        }

        function openBlogPreviewModal(id) {
            const p = state.blogPosts.find((x) => x.id === id);
            if (!p) return;
            state.blogPreviewId = id;
            const pub = p.published === true;
            const statusEl = $('blog-preview-status');
            if (statusEl) {
                statusEl.textContent = pub ? 'Ditayangkan di website' : 'Draft \u2014 belum tayang';
                statusEl.className = pub
                    ? 'text-[10px] font-bold uppercase tracking-wider mb-1 text-emerald-600'
                    : 'text-[10px] font-bold uppercase tracking-wider mb-1 text-amber-600';
            }
            $('blog-preview-title').textContent = p.title || 'Tanpa judul';
            $('blog-preview-date').textContent = formatTs(p.publishedAt || p.updatedAt);
            const bodyEl = $('blog-preview-body');
            if (bodyEl) {
                bodyEl.textContent = p.body || '';
                bodyEl.classList.toggle('view-hidden', !p.body);
            }
            renderBlogGallery($('blog-preview-photos'), p.photos);
            const editLink = $('blog-preview-edit');
            if (editLink) editLink.href = `#blog/edit/${p.id}`;
            $('blog-preview-modal')?.classList.add('is-open');
        }

        function closeBlogPreviewModal() {
            state.blogPreviewId = null;
            $('blog-preview-modal')?.classList.remove('is-open');
        }

        function bindBlogPreviewModal() {
            $('blog-preview-close')?.addEventListener('click', closeBlogPreviewModal);
            $('blog-preview-close-btn')?.addEventListener('click', closeBlogPreviewModal);
            $('blog-preview-modal')?.addEventListener('click', (e) => {
                if (e.target.id === 'blog-preview-modal') closeBlogPreviewModal();
            });
            document.addEventListener('keydown', (e) => {
                if (e.key === 'Escape' && $('blog-preview-modal')?.classList.contains('is-open')) {
                    closeBlogPreviewModal();
                }
            });
        }

        function renderBlogList() {
            const rows = getFilteredBlogPosts().sort((a, b) => blogSortKey(b) - blogSortKey(a));
            const host = $('blog-card-list');
            const empty = $('blog-empty');
            if (!host) return;
            if (!rows.length) {
                host.innerHTML = '';
                empty?.classList.remove('hidden');
                updateListPaginationUi('blog', 0, 0);
                return;
            }
            empty?.classList.add('hidden');
            const page = sliceForListPage('blog', rows);
            host.innerHTML = page.items.map((p) => {
                const pub = p.published === true;
                const photos = Array.isArray(p.photos) ? p.photos.filter(Boolean) : [];
                const thumb = photos[0]
                    ? `<div class="aspect-[16/10] overflow-hidden bg-slate-100 dark:bg-slate-900"><img src="${photos[0]}" alt="" class="w-full h-full object-cover"></div>`
                    : `<div class="aspect-[16/10] bg-indigo-50 dark:bg-slate-900 flex items-center justify-center text-indigo-300"><i class="fa-solid fa-newspaper text-4xl"></i></div>`;
                const statusBadge = pub
                    ? '<span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-emerald-100 text-emerald-800 dark:bg-emerald-900/40 dark:text-emerald-300">Tayang</span>'
                    : '<span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-slate-100 text-slate-600 dark:bg-slate-700 dark:text-slate-300">Draft</span>';
                const toggleLabel = pub ? 'Non-tayang' : 'Tayang';
                const toggleCls = pub ? 'text-amber-600' : 'text-emerald-600';
                return `<article class="rounded-2xl border border-white dark:border-slate-600 bg-white/90 dark:bg-slate-800/90 shadow-sm overflow-hidden flex flex-col">
                    <button type="button" class="btn-blog-open w-full text-left group" data-id="${p.id}">
                        ${thumb}
                        <div class="p-4">
                            <div class="flex flex-wrap items-center justify-between gap-2 mb-2">
                                ${statusBadge}
                                <span class="text-[10px] text-slate-400">${formatTs(p.updatedAt)}</span>
                            </div>
                            <h4 class="font-bold text-slate-800 dark:text-white leading-snug group-hover:text-indigo-600 transition-colors">${escapeHtml(p.title || 'Tanpa judul')}</h4>
                            <p class="blog-excerpt text-sm text-slate-500 mt-2">${escapeHtml(blogExcerpt(p.body))}</p>
                            <span class="inline-block mt-3 text-xs font-bold text-indigo-600">Baca lengkap &rarr;</span>
                        </div>
                    </button>
                    <div class="flex flex-wrap gap-3 px-4 py-3 border-t border-slate-100 dark:border-slate-700 bg-slate-50/80 dark:bg-slate-900/40 text-xs">
                        <a href="#blog/edit/${p.id}" class="text-indigo-600 font-bold hover:underline">Edit</a>
                        <button type="button" class="btn-blog-toggle ${toggleCls} font-bold hover:underline" data-id="${p.id}">${toggleLabel}</button>
                        <button type="button" class="btn-blog-del text-red-600 font-bold hover:underline" data-id="${p.id}">Hapus</button>
                    </div>
                </article>`;
            }).join('');
            updateListPaginationUi('blog', page.total, page.visible);
        }

        function resetBlogForm() {
            $('blog-id').value = '';
            $('blog-title').value = '';
            $('blog-body').value = '';
            $('blog-published').checked = false;
            $('blog-form-title').textContent = 'Artikel baru';
            state.blogFormPhotos = [null, null, null];
            [0, 1, 2].forEach(resetBlogPhotoSlot);
        }

        function loadBlogForm(id) {
            const p = state.blogPosts.find((x) => x.id === id);
            if (!p) {
                Swal.fire('Tidak ditemukan', '', 'warning');
                location.hash = '#blog';
                return;
            }
            $('blog-id').value = id;
            $('blog-title').value = p.title || '';
            $('blog-body').value = p.body || '';
            $('blog-published').checked = p.published === true;
            $('blog-form-title').textContent = 'Edit artikel';
            state.blogFormPhotos = [...(p.photos || []), null, null, null].slice(0, 3);
            state.blogFormPhotos.forEach((ph, i) => renderBlogPhotoSlot(i, ph));
        }

        function renderBlogPhotoSlot(idx, dataUrl) {
            const slot = document.querySelector(`[data-blog-photo-idx="${idx}"]`);
            if (!slot) return;
            if (dataUrl) {
                slot.innerHTML = `<img src="${dataUrl}" alt=""><button type="button" class="absolute top-1 right-1 w-6 h-6 rounded-full bg-red-600 text-white text-xs blog-photo-remove" data-idx="${idx}">×</button>`;
                slot.classList.add('relative');
                slot.querySelector('.blog-photo-remove')?.addEventListener('click', (e) => {
                    e.stopPropagation();
                    state.blogFormPhotos[idx] = null;
                    resetBlogPhotoSlot(idx);
                });
            } else resetBlogPhotoSlot(idx);
        }

        function resetBlogPhotoSlot(idx) {
            const labels = ['Foto 1', 'Foto 2', 'Foto 3'];
            const icons = ['fa-camera', 'fa-image', 'fa-image'];
            const slot = document.querySelector(`[data-blog-photo-idx="${idx}"]`);
            if (!slot) return;
            slot.classList.remove('relative');
            slot.innerHTML = `<i class="fa-solid ${icons[idx]} text-2xl mb-1"></i><span class="text-[10px] font-bold">${labels[idx]}</span>`;
        }

        function bindBlogPhotoSlots() {
            document.querySelectorAll('[data-blog-photo-idx]').forEach((slot) => {
                slot.addEventListener('click', () => {
                    const idx = parseInt(slot.dataset.blogPhotoIdx, 10);
                    const input = document.createElement('input');
                    input.type = 'file';
                    input.accept = 'image/jpeg,image/png,image/webp,image/heic,image/heif,image/*';
                    input.onchange = async () => {
                        const file = input.files?.[0];
                        if (!file) return;
                        try {
                            Swal.fire({ title: 'Mengompres foto...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
                            const compressed = await processPhotoFile(file);
                            Swal.close();
                            state.blogFormPhotos[idx] = compressed;
                            renderBlogPhotoSlot(idx, compressed);
                        } catch (err) {
                            Swal.close();
                            Swal.fire('Gagal', hrdImageProcessErrorMessage(err), 'error');
                        }
                    };
                    input.click();
                });
            });
        }

        async function saveBlogPost(e) {
            e.preventDefault();
            const title = ($('blog-title')?.value || '').trim();
            const body = ($('blog-body')?.value || '').trim();
            const published = $('blog-published')?.checked ?? false;
            const id = $('blog-id')?.value || '';
            if (!title || !body) return Swal.fire('Lengkapi', 'Judul dan isi wajib.', 'warning');

            const photos = state.blogFormPhotos.filter(Boolean);
            const payload = {
                title,
                body,
                photos,
                published,
                updatedAt: serverTimestamp()
            };
            if (published) payload.publishedAt = serverTimestamp();

            if (JSON.stringify(payload).length > 950000) {
                return Swal.fire('Terlalu besar', 'Kurangi ukuran foto.', 'warning');
            }

            Swal.fire({ title: 'Menyimpan...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
            try {
                if (id) {
                    await updateDoc(doc(db, COL_BLOG, id), payload);
                } else {
                    payload.createdAt = serverTimestamp();
                    if (!published) payload.publishedAt = null;
                    await addDoc(collection(db, COL_BLOG), payload);
                }
                Swal.close();
                showToast('Artikel disimpan');
                location.hash = '#blog';
            } catch (err) {
                Swal.close();
                Swal.fire('Gagal', err.message, 'error');
            }
        }

        async function toggleBlogPublished(id) {
            const p = state.blogPosts.find((x) => x.id === id);
            if (!p) return;
            const next = !p.published;
            try {
                const payload = { published: next, updatedAt: serverTimestamp() };
                if (next) payload.publishedAt = serverTimestamp();
                await updateDoc(doc(db, COL_BLOG, id), payload);
                showToast(next ? 'Artikel ditayangkan' : 'Artikel disembunyikan');
            } catch (e) {
                Swal.fire('Gagal', e.message, 'error');
            }
        }

        async function deleteBlogPost(id) {
            const p = state.blogPosts.find((x) => x.id === id);
            if (!p) return;
            const ok = await Swal.fire({
                title: 'Hapus artikel?',
                text: `"${p.title}" akan dihapus permanen.`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc2626'
            });
            if (!ok.isConfirmed) return;
            try {
                await deleteDoc(doc(db, COL_BLOG, id));
                showToast('Artikel dihapus');
            } catch (e) {
                Swal.fire('Gagal', e.message, 'error');
            }
        }

        function subscribeBlogPosts() {
            if (!db) return;
            if (blogUnsub) blogUnsub();
            blogUnsub = onSnapshot(
                collection(db, COL_BLOG),
                (snap) => {
                    state.blogPosts = snap.docs.map((d) => ({ id: d.id, ...d.data() }));
                    if (parseRoute().view === 'blog') renderBlogList();
                    if (state.blogPreviewId && $('blog-preview-modal')?.classList.contains('is-open')) {
                        const still = state.blogPosts.find((x) => x.id === state.blogPreviewId);
                        if (still) openBlogPreviewModal(state.blogPreviewId);
                        else closeBlogPreviewModal();
                    }
                },
                (err) => console.error('blog snapshot', err)
            );
        }

        function getTodayYmdWib() {
            return new Intl.DateTimeFormat('en-CA', { timeZone: 'Asia/Jakarta', year: 'numeric', month: '2-digit', day: '2-digit' }).format(new Date());
        }

        function formatDateIdShort(dateStr) {
            if (!dateStr) return '-';
            try {
                return new Date(dateStr + 'T12:00:00').toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' });
            } catch { return dateStr; }
        }

        function isBroadcastScheduleActive(b, today) {
            const start = String(b?.scheduleStart || '').trim();
            const end = String(b?.scheduleEnd || '').trim();
            if (!start || !end) return false;
            return today >= start && today <= end;
        }

        let activityRetentionBusy = false;

        function activityTsKeyFromData(row) {
            const t = row?.at;
            if (t?.toMillis) return t.toMillis();
            if (t?.seconds) return t.seconds * 1000;
            return 0;
        }

        async function deleteActivityLogDocs(docIds) {
            if (!db || !docIds?.length) return;
            for (let i = 0; i < docIds.length; i += ACTIVITY_LOG_DELETE_BATCH) {
                const batch = writeBatch(db);
                docIds.slice(i, i + ACTIVITY_LOG_DELETE_BATCH).forEach((id) => batch.delete(doc(db, COL_ACTIVITY, id)));
                await batch.commit();
            }
        }

        async function pruneActivityLogsForApplicant(applicantId) {
            if (!db || !applicantId) return;
            try {
                const snap = await getDocs(query(
                    collection(db, COL_ACTIVITY),
                    where('applicantId', '==', applicantId),
                    orderBy('at', 'desc'),
                    limit(ACTIVITY_LOG_MAX_PER_APPLICANT + 15)
                ));
                const excess = snap.docs.slice(ACTIVITY_LOG_MAX_PER_APPLICANT).map((d) => d.id);
                await deleteActivityLogDocs(excess);
            } catch (e) {
                console.warn('pruneActivityLogsForApplicant', e);
            }
        }

        async function pruneActivityLogsGlobal() {
            if (!db) return;
            try {
                let guard = 0;
                while (guard++ < 30) {
                    const countSnap = await getCountFromServer(collection(db, COL_ACTIVITY));
                    const total = countSnap.data().count;
                    if (total <= ACTIVITY_LOG_MAX_GLOBAL) return;
                    const removeCount = Math.min(total - ACTIVITY_LOG_MAX_GLOBAL, ACTIVITY_LOG_DELETE_BATCH);
                    const snap = await getDocs(query(
                        collection(db, COL_ACTIVITY),
                        orderBy('at', 'asc'),
                        limit(removeCount)
                    ));
                    if (snap.empty) return;
                    const batch = writeBatch(db);
                    snap.docs.forEach((d) => batch.delete(d.ref));
                    await batch.commit();
                }
            } catch (e) {
                console.warn('pruneActivityLogsGlobal', e);
            }
        }

        async function pruneAllActivityLogsPerApplicant() {
            if (!db) return;
            try {
                const snap = await getDocs(query(
                    collection(db, COL_ACTIVITY),
                    orderBy('at', 'desc'),
                    limit(ACTIVITY_LOG_MAX_GLOBAL)
                ));
                const byApplicant = new Map();
                snap.docs.forEach((d) => {
                    const data = d.data();
                    const aid = data.applicantId;
                    if (!aid) return;
                    if (!byApplicant.has(aid)) byApplicant.set(aid, []);
                    byApplicant.get(aid).push({ id: d.id, at: data.at });
                });
                const toDelete = [];
                for (const rows of byApplicant.values()) {
                    rows.sort((a, b) => activityTsKeyFromData(b) - activityTsKeyFromData(a));
                    rows.slice(ACTIVITY_LOG_MAX_PER_APPLICANT).forEach((r) => toDelete.push(r.id));
                }
                await deleteActivityLogDocs(toDelete);
            } catch (e) {
                console.warn('pruneAllActivityLogsPerApplicant', e);
            }
        }

        async function runActivityLogRetentionAfterWrite(applicantId) {
            try {
                if (applicantId) await pruneActivityLogsForApplicant(applicantId);
                await pruneActivityLogsGlobal();
            } catch (e) {
                console.warn('runActivityLogRetentionAfterWrite', e);
            }
        }

        async function runActivityLogRetentionMaintenance() {
            if (!db || activityRetentionBusy) return;
            activityRetentionBusy = true;
            try {
                await pruneAllActivityLogsPerApplicant();
                await pruneActivityLogsGlobal();
                await pruneAllActivityLogsPerApplicant();
                await pruneActivityLogsGlobal();
            } catch (e) {
                console.warn('runActivityLogRetentionMaintenance', e);
            } finally {
                activityRetentionBusy = false;
            }
        }

        async function writeActivityLog({ type, applicantId, applicantName, posisi, page, source }) {
            if (!db) return;
            try {
                await addDoc(collection(db, COL_ACTIVITY), sanitizeFirestorePayload({
                    type: type || 'kunjungan',
                    applicantId: applicantId || null,
                    applicantName: applicantName || '',
                    posisi: posisi || '',
                    page: page || '',
                    source: source || '',
                    at: serverTimestamp()
                }));
                void runActivityLogRetentionAfterWrite(applicantId || null);
            } catch (e) {
                console.warn('writeActivityLog', e);
            }
        }

        function activitySortKey(row) {
            const t = row?.at;
            if (t?.toMillis) return t.toMillis();
            if (t?.seconds) return t.seconds * 1000;
            return 0;
        }

        function activityLogLabel(row) {
            if (row.type === 'lamaran_baru') return 'Mengirim lamaran';
            if (row.type === 'undangan_mulai') return 'Undangan wawancara dimulai';
            if (row.type === 'undangan_gelombang') return 'Gelombang undangan divisi';
            if (row.type === 'undangan_selesai') return 'Undangan wawancara ditutup';
            if (row.type === 'undangan_rsvp_hadir') return 'Konfirmasi: hadir';
            if (row.type === 'undangan_rsvp_tidak') return 'Konfirmasi: tidak bisa hadir';
            if (row.type === 'status_tidak_diterima') return 'Pemberitahuan tidak diterima';
            if (row.type === 'kunjungan') return visitPageLabel(row.page);
            if (row.type === 'login') return 'Login portal';
            return visitPageLabel(row.page) || row.type || 'Aktivitas';
        }

        function getActivityLogsForApplicant(applicantId) {
            if (!applicantId) return [];
            return state.activityLogs
                .filter((row) => row.applicantId === applicantId)
                .sort((a, b) => activitySortKey(b) - activitySortKey(a))
                .slice(0, ACTIVITY_LOG_MAX_PER_APPLICANT);
        }

        function getFilteredActivityLogs() {
            const f = $('aktivitas-filter')?.value || '';
            return state.activityLogs.filter((row) => {
                if (f === 'lamaran_baru') return row.type === 'lamaran_baru';
                return true;
            });
        }

        function renderActivityLogList() {
            const rows = getFilteredActivityLogs().sort((a, b) => activitySortKey(b) - activitySortKey(a));
            const host = $('aktivitas-list');
            const empty = $('aktivitas-empty');
            if (!host) return;
            if (!rows.length) {
                host.innerHTML = '';
                empty?.classList.remove('hidden');
                updateListPaginationUi('aktivitas', 0, 0);
                return;
            }
            empty?.classList.add('hidden');
            const page = sliceForListPage('aktivitas', rows);
            host.innerHTML = page.items.map((row) => {
                const canOpen = !!row.applicantId;
                const pos = row.posisi ? `<span class="text-xs text-slate-500">${escapeHtml(row.posisi)}</span>` : '';
                return `<button type="button" class="activity-log-row w-full text-left px-4 py-3 flex flex-wrap items-start justify-between gap-2 ${canOpen ? '' : 'opacity-70 cursor-default'}" data-applicant-id="${escapeHtml(row.applicantId || '')}" ${canOpen ? '' : 'disabled'}>
                    <div class="min-w-0 flex-1">
                        <p class="font-bold text-sm text-slate-800 dark:text-white">${escapeHtml(row.applicantName || 'Tanpa nama')}</p>
                        <p class="text-xs text-indigo-600 dark:text-indigo-400 font-semibold mt-0.5">${escapeHtml(activityLogLabel(row))}</p>
                        ${pos}
                    </div>
                    <span class="text-[10px] text-slate-400 shrink-0">${formatTs(row.at)}</span>
                </button>`;
            }).join('');
            updateListPaginationUi('aktivitas', page.total, page.visible);
        }

        function subscribeActivityLog() {
            if (!db) return;
            if (activityUnsub) activityUnsub();
            activityUnsub = onSnapshot(
                collection(db, COL_ACTIVITY),
                (snap) => {
                    state.activityLogs = snap.docs.map((d) => ({ id: d.id, ...d.data() }));
                    const route = parseRoute();
                    if (route.view === 'aktivitas') renderActivityLogList();
                    if (route.view === 'detail' && route.tab === 'aktivitas') {
                        renderDetailActivityPane(route.id);
                    }
                },
                (err) => console.error('activity snapshot', err)
            );
        }

        function getFilteredBroadcastPosts() {
            const f = $('broadcast-filter')?.value || '';
            const today = getTodayYmdWib();
            return state.broadcastPosts.filter((p) => {
                if (f === 'published') return p.published === true;
                if (f === 'draft') return !p.published;
                if (f === 'active') return p.published === true && isBroadcastScheduleActive(p, today);
                return true;
            });
        }

        function renderBroadcastList() {
            const rows = getFilteredBroadcastPosts().sort((a, b) => blogSortKey(b) - blogSortKey(a));
            const host = $('broadcast-card-list');
            const empty = $('broadcast-empty');
            if (!host) return;
            if (!rows.length) {
                host.innerHTML = '';
                empty?.classList.remove('hidden');
                updateListPaginationUi('broadcast', 0, 0);
                return;
            }
            empty?.classList.add('hidden');
            const page = sliceForListPage('broadcast', rows);
            const today = getTodayYmdWib();
            host.innerHTML = page.items.map((p) => {
                const pub = p.published === true;
                const activeToday = pub && isBroadcastScheduleActive(p, today);
                const photos = Array.isArray(p.photos) ? p.photos.filter(Boolean) : [];
                const thumb = photos[0]
                    ? `<div class="aspect-[16/10] overflow-hidden bg-slate-100 dark:bg-slate-900"><img src="${photos[0]}" alt="" class="w-full h-full object-cover"></div>`
                    : `<div class="aspect-[16/10] bg-amber-50 dark:bg-slate-900 flex items-center justify-center text-amber-300"><i class="fa-solid fa-bullhorn text-4xl"></i></div>`;
                const statusBadge = activeToday
                    ? '<span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-amber-100 text-amber-800 dark:bg-amber-900/40 dark:text-amber-300">Jadwal aktif</span>'
                    : (pub
                        ? '<span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-emerald-100 text-emerald-800 dark:bg-emerald-900/40 dark:text-emerald-300">Tayang</span>'
                        : '<span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-slate-100 text-slate-600 dark:bg-slate-700 dark:text-slate-300">Draft</span>');
                const toggleLabel = pub ? 'Non-tayang' : 'Tayang';
                const toggleCls = pub ? 'text-amber-600' : 'text-emerald-600';
                const sched = `${formatDateIdShort(p.scheduleStart)} &ndash; ${formatDateIdShort(p.scheduleEnd)}`;
                return `<article class="rounded-2xl border border-white dark:border-slate-600 bg-white/90 dark:bg-slate-800/90 shadow-sm overflow-hidden flex flex-col">
                    <button type="button" class="btn-broadcast-open w-full text-left group" data-id="${p.id}">
                        ${thumb}
                        <div class="p-4">
                            <div class="flex flex-wrap items-center justify-between gap-2 mb-2">
                                ${statusBadge}
                                <span class="text-[10px] text-slate-400">${formatTs(p.updatedAt)}</span>
                            </div>
                            <p class="text-[10px] text-amber-700 dark:text-amber-400 font-semibold mb-1">${sched}</p>
                            <h4 class="font-bold text-slate-800 dark:text-white leading-snug group-hover:text-amber-600 transition-colors">${escapeHtml(p.title || 'Tanpa judul')}</h4>
                            <p class="blog-excerpt text-sm text-slate-500 mt-2">${escapeHtml(blogExcerpt(p.body))}</p>
                            <span class="inline-block mt-3 text-xs font-bold text-amber-600">Baca lengkap &rarr;</span>
                        </div>
                    </button>
                    <div class="flex flex-wrap gap-3 px-4 py-3 border-t border-slate-100 dark:border-slate-700 bg-slate-50/80 dark:bg-slate-900/40 text-xs">
                        <a href="#broadcast/edit/${p.id}" class="text-amber-600 font-bold hover:underline">Edit</a>
                        <button type="button" class="btn-broadcast-toggle ${toggleCls} font-bold hover:underline" data-id="${p.id}">${toggleLabel}</button>
                        <button type="button" class="btn-broadcast-del text-red-600 font-bold hover:underline" data-id="${p.id}">Hapus</button>
                    </div>
                </article>`;
            }).join('');
            updateListPaginationUi('broadcast', page.total, page.visible);
        }

        function openBroadcastPreviewModal(id) {
            const p = state.broadcastPosts.find((x) => x.id === id);
            if (!p) return;
            state.broadcastPreviewId = id;
            const pub = p.published === true;
            const statusEl = $('broadcast-preview-status');
            if (statusEl) {
                statusEl.textContent = pub ? 'Popup aktif (sesuai jadwal)' : 'Draft \u2014 belum tayang';
                statusEl.className = pub
                    ? 'text-[10px] font-bold uppercase tracking-wider mb-1 text-emerald-600'
                    : 'text-[10px] font-bold uppercase tracking-wider mb-1 text-amber-600';
            }
            $('broadcast-preview-title').textContent = p.title || 'Tanpa judul';
            $('broadcast-preview-date').textContent = formatTs(p.updatedAt);
            const schedEl = $('broadcast-preview-schedule');
            if (schedEl) {
                schedEl.textContent = `Jadwal: ${formatDateIdShort(p.scheduleStart)} \u2013 ${formatDateIdShort(p.scheduleEnd)}`;
            }
            const bodyEl = $('broadcast-preview-body');
            if (bodyEl) {
                bodyEl.textContent = p.body || '';
                bodyEl.classList.toggle('view-hidden', !p.body);
            }
            renderBlogGallery($('broadcast-preview-photos'), p.photos);
            const editLink = $('broadcast-preview-edit');
            if (editLink) editLink.href = `#broadcast/edit/${p.id}`;
            $('broadcast-preview-modal')?.classList.add('is-open');
        }

        function closeBroadcastPreviewModal() {
            state.broadcastPreviewId = null;
            $('broadcast-preview-modal')?.classList.remove('is-open');
        }

        function bindBroadcastPreviewModal() {
            $('broadcast-preview-close')?.addEventListener('click', closeBroadcastPreviewModal);
            $('broadcast-preview-close-btn')?.addEventListener('click', closeBroadcastPreviewModal);
            $('broadcast-preview-modal')?.addEventListener('click', (e) => {
                if (e.target.id === 'broadcast-preview-modal') closeBroadcastPreviewModal();
            });
            document.addEventListener('keydown', (e) => {
                if (e.key === 'Escape' && $('broadcast-preview-modal')?.classList.contains('is-open')) {
                    closeBroadcastPreviewModal();
                }
            });
        }

        function resetBroadcastForm() {
            $('broadcast-id').value = '';
            $('broadcast-title').value = '';
            $('broadcast-body').value = '';
            $('broadcast-published').checked = false;
            const today = getTodayYmdWib();
            $('broadcast-schedule-start').value = today;
            $('broadcast-schedule-end').value = today;
            $('broadcast-form-title').textContent = 'Broadcast baru';
            state.broadcastFormPhotos = [null, null, null];
            [0, 1, 2].forEach(resetBroadcastPhotoSlot);
        }

        function loadBroadcastForm(id) {
            const p = state.broadcastPosts.find((x) => x.id === id);
            if (!p) {
                Swal.fire('Tidak ditemukan', '', 'warning');
                location.hash = '#blog';
                return;
            }
            $('broadcast-id').value = id;
            $('broadcast-title').value = p.title || '';
            $('broadcast-body').value = p.body || '';
            $('broadcast-published').checked = p.published === true;
            $('broadcast-schedule-start').value = p.scheduleStart || '';
            $('broadcast-schedule-end').value = p.scheduleEnd || '';
            $('broadcast-form-title').textContent = 'Edit broadcast';
            state.broadcastFormPhotos = [...(p.photos || []), null, null, null].slice(0, 3);
            state.broadcastFormPhotos.forEach((ph, i) => renderBroadcastPhotoSlot(i, ph));
        }

        function renderBroadcastPhotoSlot(idx, dataUrl) {
            const slot = document.querySelector(`[data-broadcast-photo-idx="${idx}"]`);
            if (!slot) return;
            if (dataUrl) {
                slot.innerHTML = `<img src="${dataUrl}" alt=""><button type="button" class="absolute top-1 right-1 w-6 h-6 rounded-full bg-red-600 text-white text-xs broadcast-photo-remove" data-idx="${idx}">\u00d7</button>`;
                slot.classList.add('relative');
                slot.querySelector('.broadcast-photo-remove')?.addEventListener('click', (e) => {
                    e.stopPropagation();
                    state.broadcastFormPhotos[idx] = null;
                    resetBroadcastPhotoSlot(idx);
                });
            } else resetBroadcastPhotoSlot(idx);
        }

        function resetBroadcastPhotoSlot(idx) {
            const labels = ['Foto 1', 'Foto 2', 'Foto 3'];
            const icons = ['fa-camera', 'fa-image', 'fa-image'];
            const slot = document.querySelector(`[data-broadcast-photo-idx="${idx}"]`);
            if (!slot) return;
            slot.classList.remove('relative');
            slot.innerHTML = `<i class="fa-solid ${icons[idx]} text-2xl mb-1"></i><span class="text-[10px] font-bold">${labels[idx]}</span>`;
        }

        function bindBroadcastPhotoSlots() {
            document.querySelectorAll('[data-broadcast-photo-idx]').forEach((slot) => {
                slot.addEventListener('click', () => {
                    const idx = parseInt(slot.dataset.broadcastPhotoIdx, 10);
                    const input = document.createElement('input');
                    input.type = 'file';
                    input.accept = 'image/jpeg,image/png,image/webp,image/heic,image/heif,image/*';
                    input.onchange = async () => {
                        const file = input.files?.[0];
                        if (!file) return;
                        try {
                            Swal.fire({ title: 'Mengompres foto...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
                            const compressed = await processPhotoFile(file);
                            Swal.close();
                            state.broadcastFormPhotos[idx] = compressed;
                            renderBroadcastPhotoSlot(idx, compressed);
                        } catch (err) {
                            Swal.close();
                            Swal.fire('Gagal', hrdImageProcessErrorMessage(err), 'error');
                        }
                    };
                    input.click();
                });
            });
        }

        async function saveBroadcastPost(e) {
            e.preventDefault();
            const title = ($('broadcast-title')?.value || '').trim();
            const body = ($('broadcast-body')?.value || '').trim();
            const published = $('broadcast-published')?.checked ?? false;
            const scheduleStart = $('broadcast-schedule-start')?.value || '';
            const scheduleEnd = $('broadcast-schedule-end')?.value || '';
            const id = $('broadcast-id')?.value || '';
            if (!title || !body) return Swal.fire('Lengkapi', 'Judul dan isi wajib.', 'warning');
            if (!scheduleStart || !scheduleEnd) return Swal.fire('Lengkapi', 'Tanggal jadwal wajib.', 'warning');
            if (scheduleStart > scheduleEnd) return Swal.fire('Jadwal', 'Tanggal mulai tidak boleh setelah tanggal selesai.', 'warning');

            const photos = state.broadcastFormPhotos.filter(Boolean);
            const payload = {
                title,
                body,
                photos,
                published,
                scheduleStart,
                scheduleEnd,
                updatedAt: serverTimestamp()
            };
            if (published) payload.publishedAt = serverTimestamp();

            if (JSON.stringify(payload).length > 950000) {
                return Swal.fire('Terlalu besar', 'Kurangi ukuran foto.', 'warning');
            }

            Swal.fire({ title: 'Menyimpan...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
            try {
                if (id) {
                    await updateDoc(doc(db, COL_BROADCAST, id), payload);
                } else {
                    payload.createdAt = serverTimestamp();
                    if (!published) payload.publishedAt = null;
                    await addDoc(collection(db, COL_BROADCAST), payload);
                }
                Swal.close();
                showToast('Broadcast disimpan');
                location.hash = '#blog';
            } catch (err) {
                Swal.close();
                Swal.fire('Gagal', err.message, 'error');
            }
        }

        async function toggleBroadcastPublished(id) {
            const p = state.broadcastPosts.find((x) => x.id === id);
            if (!p) return;
            const next = !p.published;
            try {
                const payload = { published: next, updatedAt: serverTimestamp() };
                if (next) payload.publishedAt = serverTimestamp();
                await updateDoc(doc(db, COL_BROADCAST, id), payload);
                showToast(next ? 'Broadcast ditayangkan' : 'Broadcast disembunyikan');
            } catch (e) {
                Swal.fire('Gagal', e.message, 'error');
            }
        }

        async function deleteBroadcastPost(id) {
            const p = state.broadcastPosts.find((x) => x.id === id);
            if (!p) return;
            const ok = await Swal.fire({
                title: 'Hapus broadcast?',
                text: `"${p.title}" akan dihapus permanen.`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc2626'
            });
            if (!ok.isConfirmed) return;
            try {
                await deleteDoc(doc(db, COL_BROADCAST, id));
                showToast('Broadcast dihapus');
            } catch (e) {
                Swal.fire('Gagal', e.message, 'error');
            }
        }

        function subscribeBroadcastPosts() {
            if (!db) return;
            if (broadcastUnsub) broadcastUnsub();
            broadcastUnsub = onSnapshot(
                collection(db, COL_BROADCAST),
                (snap) => {
                    state.broadcastPosts = snap.docs.map((d) => ({ id: d.id, ...d.data() }));
                    if (parseRoute().view === 'blog') renderBroadcastList();
                    if (state.broadcastPreviewId && $('broadcast-preview-modal')?.classList.contains('is-open')) {
                        const still = state.broadcastPosts.find((x) => x.id === state.broadcastPreviewId);
                        if (still) openBroadcastPreviewModal(state.broadcastPreviewId);
                        else closeBroadcastPreviewModal();
                    }
                },
                (err) => console.error('broadcast snapshot', err)
            );
        }

        // --- Render ---
        function getFilteredApplicants() {
            const q = ($('filter-search')?.value || '').toLowerCase().trim();
            const st = $('filter-status')?.value || '';
            const pos = $('filter-posisi')?.value || '';
            return state.applicants.filter((a) => {
                if (st && normalizeStatus(a.status) !== st) return false;
                if (pos && !applicantMatchesPosisi(a, pos)) return false;
                if (!applicantMatchesFaseUndanganFilter(a)) return false;
                if (!applicantMatchesRsvpUndanganFilter(a)) return false;
                if (q) {
                    const blob = `${a.nama} ${getPosisiDisplay(a)} ${a.whatsapp || ''}`.toLowerCase();
                    if (!blob.includes(q)) return false;
                }
                return true;
            });
        }

        function renderPelamarTable() {
            const rows = getFilteredApplicants();
            const host = $('pelamar-card-list');
            const empty = $('pelamar-empty');
            if (!host) return;
            if (!rows.length) {
                host.innerHTML = '';
                empty.classList.remove('hidden');
                updateListPaginationUi('pelamar', 0, 0);
                const pagContainer = $('pelamar-pagination-container');
                if (pagContainer) pagContainer.innerHTML = '';
                return;
            }
            empty.classList.add('hidden');
            
            const total = rows.length;
            const pageSize = 20;
            const totalPages = Math.ceil(total / pageSize);
            
            if (!state.pelamarCurrentPage) state.pelamarCurrentPage = 1;
            if (state.pelamarCurrentPage > totalPages) state.pelamarCurrentPage = Math.max(1, totalPages);
            
            const startIdx = (state.pelamarCurrentPage - 1) * pageSize;
            const endIdx = Math.min(startIdx + pageSize, total);
            const pageItems = rows.slice(startIdx, endIdx);

            host.innerHTML = `<div class="overflow-x-auto rounded-2xl border border-slate-100 bg-white/95 shadow-sm">
                <table class="min-w-full divide-y divide-slate-150 text-left text-xs sm:text-sm">
                    <thead class="bg-slate-50/80 text-[10px] sm:text-xs font-bold uppercase tracking-wider text-slate-500">
                        <tr>
                            <th scope="col" class="px-4 py-3.5">Pelamar</th>
                            <th scope="col" class="px-4 py-3.5">Posisi</th>
                            <th scope="col" class="px-4 py-3.5">Status</th>
                            <th scope="col" class="px-4 py-3.5">Aktivitas / Catatan</th>
                            <th scope="col" class="px-4 py-3.5 text-right">Aksi</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100 bg-white/50">
                        ${pageItems.map((a) => {
                            const age = calcAgeFromBirthdate(a.tanggalLahir);
                            const thumb = (a.photos && a.photos[0])
                                ? `<img src="${a.photos[0]}" class="w-10 h-10 rounded-xl object-cover shrink-0" alt="">`
                                : `<span class="w-10 h-10 rounded-xl bg-slate-100 dark:bg-slate-700 flex items-center justify-center text-slate-400 shrink-0"><i class="fa-solid fa-user text-sm"></i></span>`;
                            const catCnt = getApplicantCatatanCount(a);
                            const catatanBadge = catCnt
                                ? `<span class="inline-block mt-0.5 text-[9px] font-bold px-2 py-0.5 rounded-full bg-emerald-100 text-emerald-700 dark:bg-emerald-900/40 dark:text-emerald-300">${catCnt} catatan</span>`
                                : '';
                            
                            return `<tr class="pelamar-card hover:bg-violet-50/20 dark:hover:bg-slate-800/20 transition-colors cursor-pointer" data-id="${a.id}">
                                <td class="px-4 py-3.5 whitespace-nowrap">
                                    <div class="flex items-center gap-3">
                                        ${thumb}
                                        <div class="min-w-0">
                                            <p class="font-bold text-slate-800 dark:text-white truncate">${escapeHtml(a.nama)}</p>
                                            <p class="text-[10px] text-slate-400 mt-0.5">${formatDateId(a.tanggalLahir)}${age != null ? ` &middot; ${age} th` : ''}</p>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-4 py-3.5">
                                    <p class="text-xs sm:text-sm text-slate-700 dark:text-slate-300 font-semibold truncate max-w-[220px]">${escapeHtml(getPosisiDisplay(a))}</p>
                                </td>
                                <td class="px-4 py-3.5 whitespace-nowrap">
                                    <span class="${statusClass(a.status)}" title="${escapeHtml(getStatusMeta(a.status).hint)}">${statusLabel(a.status)}</span>
                                </td>
                                <td class="px-4 py-3.5">
                                    <div class="flex flex-col gap-0.5">
                                        ${renderUndanganBadgesHtml(a)}
                                        ${renderPelamarUndanganStatusHtml(a)}
                                        ${catatanBadge}
                                    </div>
                                </td>
                                <td class="px-4 py-3.5 whitespace-nowrap text-right text-xs font-semibold">
                                    <div class="pelamar-card-actions flex justify-end items-center gap-2" onclick="event.stopPropagation();">
                                        ${waChatButtonHtml(a.whatsapp, 'Chat', a)}
                                        ${normalizeStatus(a.status) === 'belum_dinilai'
                                            ? `<button type="button" class="btn-undang-pelamar text-violet-700 dark:text-violet-300 font-bold text-[11px] hover:underline" data-id="${escapeHtml(a.id)}" title="Undang wawancara via chat web">Undang</button>`
                                            : ''}
                                        <a href="#pelamar/${a.id}/pesan" class="text-violet-600 font-bold text-[11px] hover:underline">Pesan</a>
                                        <a href="#pelamar/edit/${a.id}" class="text-emerald-600 font-bold text-[11px] hover:underline">Edit</a>
                                        <a href="#pelamar/${a.id}" class="text-blue-600 font-bold text-[11px] hover:underline">Rincian</a>
                                    </div>
                                </td>
                            </tr>`;
                        }).join('')}
                    </tbody>
                </table>
            </div>`;
            
            // Render Pagination count and page numbers
            const countEl = $('pelamar-list-count');
            if (countEl) {
                countEl.textContent = total
                    ? `Menampilkan ${startIdx + 1}-${endIdx} dari ${total} pelamar`
                    : 'Belum ada data';
            }
            
            const footer = $('pelamar-list-footer');
            if (footer) {
                footer.classList.toggle('hidden', total === 0);
                
                let paginationHtml = '';
                if (totalPages > 1) {
                    paginationHtml += `<div class="flex items-center justify-center gap-1 mt-3 flex-wrap">`;
                    
                    // Prev Button
                    paginationHtml += `<button type="button" class="px-2.5 py-1.5 rounded-lg border text-xs font-semibold transition-colors ${state.pelamarCurrentPage === 1 ? 'bg-slate-50 text-slate-400 cursor-not-allowed border-slate-200' : 'bg-white hover:bg-violet-50 text-slate-700 border-slate-300 hover:text-violet-700'}" ${state.pelamarCurrentPage === 1 ? 'disabled' : ''} onclick="event.stopPropagation(); setPelamarPage(${state.pelamarCurrentPage - 1});">Sebelumnya</button>`;
                    
                    // Page numbers window
                    const maxVisiblePages = 5;
                    let startPage = Math.max(1, state.pelamarCurrentPage - 2);
                    let endPage = Math.min(totalPages, startPage + maxVisiblePages - 1);
                    if (endPage - startPage + 1 < maxVisiblePages) {
                        startPage = Math.max(1, endPage - maxVisiblePages + 1);
                    }
                    
                    if (startPage > 1) {
                        paginationHtml += `<button type="button" class="w-8 h-8 rounded-lg border text-xs font-bold transition-colors bg-white hover:bg-violet-50 text-slate-700 border-slate-300 hover:text-violet-700" onclick="event.stopPropagation(); setPelamarPage(1);">1</button>`;
                        if (startPage > 2) {
                            paginationHtml += `<span class="px-1 text-slate-400">...</span>`;
                        }
                    }
                    
                    for (let p = startPage; p <= endPage; p++) {
                        const active = p === state.pelamarCurrentPage;
                        paginationHtml += `<button type="button" class="w-8 h-8 rounded-lg border text-xs font-bold transition-colors ${active ? 'bg-violet-600 border-violet-600 text-white shadow-sm' : 'bg-white hover:bg-violet-50 text-slate-700 border-slate-300 hover:text-violet-700'}" onclick="event.stopPropagation(); setPelamarPage(${p});">${p}</button>`;
                    }
                    
                    if (endPage < totalPages) {
                        if (endPage < totalPages - 1) {
                            paginationHtml += `<span class="px-1 text-slate-400">...</span>`;
                        }
                        paginationHtml += `<button type="button" class="w-8 h-8 rounded-lg border text-xs font-bold transition-colors bg-white hover:bg-violet-50 text-slate-700 border-slate-300 hover:text-violet-700" onclick="event.stopPropagation(); setPelamarPage(${totalPages});">${totalPages}</button>`;
                    }
                    
                    // Next Button
                    paginationHtml += `<button type="button" class="px-2.5 py-1.5 rounded-lg border text-xs font-semibold transition-colors ${state.pelamarCurrentPage === totalPages ? 'bg-slate-50 text-slate-400 cursor-not-allowed border-slate-200' : 'bg-white hover:bg-violet-50 text-slate-700 border-slate-300 hover:text-violet-700'}" ${state.pelamarCurrentPage === totalPages ? 'disabled' : ''} onclick="event.stopPropagation(); setPelamarPage(${state.pelamarCurrentPage + 1});">Selanjutnya</button>`;
                    
                    paginationHtml += `</div>`;
                }
                
                let pagContainer = $('pelamar-pagination-container');
                if (!pagContainer) {
                    const loadMoreBtn = $('btn-pelamar-load-more');
                    if (loadMoreBtn) loadMoreBtn.classList.add('hidden');
                    
                    pagContainer = document.createElement('div');
                    pagContainer.id = 'hrd-pelamar-pagination-container';
                    footer.appendChild(pagContainer);
                }
                pagContainer.innerHTML = paginationHtml;
            }
            
            syncPosisiOptions();
        }

        window.setPelamarPage = function(p) {
            state.pelamarCurrentPage = p;
            renderPelamarTable();
            window.scrollTo({ top: 0, behavior: 'smooth' });
        };

        function renderPosisiPanel() {
            const tbody = $('posisi-tbody');
            const empty = $('posisi-empty');
            const sorted = [...state.positions]
                .filter((p) => !isPositionDeleted(p.name))
                .sort((a, b) => (a.name || '').localeCompare(b.name || '', 'id'));
            if (!sorted.length) {
                tbody.innerHTML = '';
                empty?.classList.remove('hidden');
                return;
            }
            empty?.classList.add('hidden');
            tbody.innerHTML = sorted.map((p) => {
                const cnt = countDiterimaByPosisi(p.name);
                return `<tr class="hover:bg-violet-50/40 dark:hover:bg-slate-700/30">
                    <td class="p-3 font-semibold text-slate-800 dark:text-white">${escapeHtml(p.name)}</td>
                    <td class="p-3 text-center font-bold text-slate-600" title="Pelamar status Diterima">${cnt}</td>
                    <td class="p-3 text-center whitespace-nowrap">
                        <button type="button" class="btn-edit-posisi text-blue-600 font-bold text-xs hover:underline mr-3" data-id="${p.id}">Ubah</button>
                        <button type="button" class="btn-del-posisi text-red-600 font-bold text-xs hover:underline" data-id="${p.id}">Hapus</button>
                    </td>
                </tr>`;
            }).join('');
        }

        async function promptPosisiName(title, defaultValue = '') {
            const { value, isConfirmed } = await Swal.fire({
                title,
                input: 'text',
                inputValue: defaultValue,
                inputPlaceholder: 'Nama posisi',
                inputAttributes: { maxlength: 80 },
                showCancelButton: true,
                confirmButtonText: 'Simpan',
                cancelButtonText: 'Batal',
                inputValidator: (v) => {
                    if (!normalizePosisiName(v)) return 'Nama posisi wajib diisi';
                    return null;
                }
            });
            if (!isConfirmed) return null;
            return normalizePosisiName(value);
        }

        async function addPositionMaster(name) {
            const n = normalizePosisiName(name);
            if (!n) return;
            const dup = state.positions.some((p) => normalizePosisiName(p.name).toLowerCase() === n.toLowerCase());
            if (dup) return Swal.fire('Sudah ada', `Posisi "${n}" sudah terdaftar.`, 'info');
            await unmarkPositionDeletedInMeta(n);
            await setDoc(doc(db, COL_POSITIONS, positionDocId(n)), { name: n, createdAt: serverTimestamp() }, { merge: true });
            showToast('Posisi ditambahkan');
        }

        async function renamePositionMaster(id, oldName, newName) {
            const oldN = normalizePosisiName(oldName);
            const newN = normalizePosisiName(newName);
            if (!newN || oldN === newN) return;
            const dup = state.positions.some((p) => p.id !== id && normalizePosisiName(p.name).toLowerCase() === newN.toLowerCase());
            if (dup) return Swal.fire('Sudah ada', `Posisi "${newN}" sudah terdaftar.`, 'warning');

            const affected = state.applicants.filter((a) => getPosisiListFromApplicant(a).includes(oldN));
            if (affected.length > 0) {
                const ok = await Swal.fire({
                    title: 'Ubah nama posisi?',
                    html: `"<strong>${escapeHtml(oldN)}</strong>" &rarr; "<strong>${escapeHtml(newN)}</strong>"<br><span class="text-sm">${affected.length} pelamar akan ikut diperbarui.</span>`,
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonText: 'Ya, ubah semua'
                });
                if (!ok.isConfirmed) return;
            }

            Swal.fire({ title: 'Menyimpan...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
            try {
                const batch = writeBatch(db);
                batch.update(doc(db, COL_POSITIONS, id), { name: newN, updatedAt: serverTimestamp() });
                affected.forEach((a) => {
                    const list = getPosisiListFromApplicant(a).map((p) => (p === oldN ? newN : p));
                    batch.update(doc(db, COL_APPLICANTS, a.id), {
                        posisi: list.join(', '),
                        posisiList: list,
                        updatedAt: serverTimestamp()
                    });
                });
                await batch.commit();
                Swal.close();
                showToast('Posisi diperbarui');
            } catch (e) {
                Swal.close();
                Swal.fire('Gagal', e.message, 'error');
            }
        }

        async function deletePositionMaster(id, name) {
            const n = normalizePosisiName(name);
            const cnt = countPelamarByPosisi(n);
            if (cnt > 0) {
                return Swal.fire(
                    'Tidak bisa dihapus',
                    `Masih ada ${cnt} pelamar dengan posisi ini. Ubah posisi pelamar dulu, atau rename posisi tersebut.`,
                    'warning'
                );
            }
            const ok = await Swal.fire({
                title: 'Hapus posisi?',
                text: `"${n}" akan dihapus dari master.`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc2626'
            });
            if (!ok.isConfirmed) return;
            try {
                const key = vacancyTitleKey(n);
                const toDelete = state.positions
                    .filter((p) => vacancyTitleKey(p.name) === key)
                    .map((p) => p.id);
                if (!toDelete.length) toDelete.push(id);
                const batch = writeBatch(db);
                toDelete.forEach((docId) => batch.delete(doc(db, COL_POSITIONS, docId)));
                await batch.commit();
                await markPositionDeletedInMeta(n);
                showToast('Posisi dihapus — tidak akan muncul lagi otomatis');
            } catch (e) {
                Swal.fire('Gagal', e.message, 'error');
            }
        }

        async function ensurePositionInMaster(name) {
            const n = normalizePosisiName(name);
            if (!n || isPositionDeleted(n)) return;
            const exists = state.positions.some((p) => normalizePosisiName(p.name).toLowerCase() === n.toLowerCase());
            if (exists) return;
            try {
                await setDoc(doc(db, COL_POSITIONS, positionDocId(n)), { name: n, createdAt: serverTimestamp() }, { merge: true });
            } catch (e) {
                console.warn('Gagal menambah posisi ke master:', e);
            }
        }

        /** Hapus dokumen posisi ganda (nama sama, beda ID) — sisa satu per nama */
        async function dedupePositionMaster() {
            try {
                const snap = await getDocs(collection(db, COL_POSITIONS));
                const groups = new Map();
                snap.docs.forEach((d) => {
                    const key = normalizePosisiName(d.data().name).toLowerCase();
                    if (!key) return;
                    if (!groups.has(key)) groups.set(key, []);
                    groups.get(key).push({ id: d.id, name: d.data().name });
                });
                const toDelete = [];
                for (const list of groups.values()) {
                    if (list.length <= 1) continue;
                    list.sort((a, b) => {
                        const aStd = a.id.startsWith('pos-') ? 0 : 1;
                        const bStd = b.id.startsWith('pos-') ? 0 : 1;
                        if (aStd !== bStd) return aStd - bStd;
                        return a.id.localeCompare(b.id);
                    });
                    for (let i = 1; i < list.length; i++) toDelete.push(list[i].id);
                }
                if (!toDelete.length) return 0;
                const batch = writeBatch(db);
                toDelete.forEach((id) => batch.delete(doc(db, COL_POSITIONS, id)));
                await batch.commit();
                console.info('[posisi] Duplikat dihapus:', toDelete.length);
                return toDelete.length;
            } catch (e) {
                console.warn('dedupePositionMaster', e);
                return 0;
            }
        }

        // --- Export / Import & restore penuh (migrasi project Firebase baru) ---
        function serializeForExport(val) {
            if (val == null || typeof val !== 'object') return val;
            if (typeof val.toDate === 'function') {
                return { __firestoreTimestamp: val.toDate().toISOString() };
            }
            if (Array.isArray(val)) return val.map(serializeForExport);
            const out = {};
            for (const [k, v] of Object.entries(val)) out[k] = serializeForExport(v);
            return out;
        }

        function deserializeForImport(val) {
            if (val == null || typeof val !== 'object') return val;
            if (val.__firestoreTimestamp) {
                return Timestamp.fromDate(new Date(val.__firestoreTimestamp));
            }
            if (Array.isArray(val)) return val.map(deserializeForImport);
            const out = {};
            for (const [k, v] of Object.entries(val)) out[k] = deserializeForImport(v);
            return out;
        }

        function downloadJsonFile(obj, filename) {
            const blob = new Blob([JSON.stringify(obj, null, 0)], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = filename;
            document.body.appendChild(a);
            a.click();
            a.remove();
            URL.revokeObjectURL(url);
        }

        function pickJsonFile() {
            return new Promise((resolve, reject) => {
                const input = document.createElement('input');
                input.type = 'file';
                input.accept = '.json,application/json';
                input.onchange = async () => {
                    const file = input.files?.[0];
                    if (!file) return reject(new Error('Batal'));
                    try {
                        const text = await file.text();
                        resolve({ file, data: JSON.parse(text) });
                    } catch (e) {
                        reject(e);
                    }
                };
                input.click();
            });
        }

        async function exportFullFirestoreBackup() {
            if (!db) return Swal.fire('Server', 'Belum terhubung. Jalankan START.bat.', 'error');
            await ensureAnonAuth();
            Swal.fire({ title: 'Mengekspor…', html: 'Membaca semua koleksi. File besar bisa memakan waktu.', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
            try {
                const pack = {
                    format: 'sencha_full_backup',
                    version: FULL_BACKUP_VERSION,
                    exportedAt: new Date().toISOString(),
                    sourceProjectId: firebaseConfig.projectId || '',
                    collections: {}
                };
                const flatCols = [
                    COL_POSITIONS,
                    COL_LOGIN_INDEX,
                    COL_BLOG,
                    COL_BROADCAST,
                    COL_ACTIVITY,
                    COL_CHAT_THREADS,
                    COL_JOB_VACANCIES
                ];
                for (const col of flatCols) {
                    Swal.update({ html: `Membaca <strong>${col}</strong>?` });
                    const snap = await getDocs(collection(db, col));
                    pack.collections[col] = snap.docs.map((d) => ({
                        id: d.id,
                        data: serializeForExport(d.data())
                    }));
                }
                const metaSnap = await getDoc(doc(db, COL_META, META_DOC));
                pack.collections.app_meta_main = metaSnap.exists()
                    ? { id: META_DOC, data: serializeForExport(metaSnap.data()) }
                    : null;

                Swal.update({ html: 'Membaca <strong>applicants</strong> + pesan…' });
                const appSnap = await getDocs(collection(db, COL_APPLICANTS));
                pack.collections.applicants = [];
                for (const d of appSnap.docs) {
                    const msgs = await getDocs(collection(db, COL_APPLICANTS, d.id, SUB_MESSAGES));
                    const visits = await getDocs(collection(db, COL_APPLICANTS, d.id, SUB_VISITS));
                    pack.collections.applicants.push({
                        id: d.id,
                        data: serializeForExport(d.data()),
                        messages: msgs.docs.map((m) => ({ id: m.id, data: serializeForExport(m.data()) })),
                        visits: visits.docs.map((v) => ({ id: v.id, data: serializeForExport(v.data()) }))
                    });
                }

                Swal.update({ html: 'Membaca <strong>interview_sessions</strong>…' });
                const sessSnap = await getDocs(collection(db, COL_INTERVIEW_SESSIONS));
                pack.collections.interview_sessions = [];
                for (const d of sessSnap.docs) {
                    const qSnap = await getDocs(collection(db, COL_INTERVIEW_SESSIONS, d.id, SUB_INTERVIEW_QUEUE));
                    pack.collections.interview_sessions.push({
                        id: d.id,
                        data: serializeForExport(d.data()),
                        queue: qSnap.docs.map((q) => ({ id: q.id, data: serializeForExport(q.data()) }))
                    });
                }

                const stamp = new Date().toISOString().slice(0, 19).replace(/[:T]/g, '-');
                const fname = `sencha-backup-${pack.sourceProjectId || 'export'}-${stamp}.json`;
                downloadJsonFile(pack, fname);
                Swal.fire('Export selesai', `File <strong>${escapeHtml(fname)}</strong> diunduh. Simpan aman sebelum restore ke project baru.`, 'success');
            } catch (e) {
                Swal.fire('Export gagal', firestoreErrHint(e), 'error');
            }
        }

        const FIRESTORE_BATCH_MAX_BYTES = 8 * 1024 * 1024;
        const FIRESTORE_DOC_MAX_BYTES = 1040000;

        function estimatePayloadBytes(data) {
            try {
                return new Blob([JSON.stringify(data)]).size;
            } catch {
                return JSON.stringify(data).length;
            }
        }

        async function commitBatchFns(batchFns, maxOps = 60) {
            for (let i = 0; i < batchFns.length; i += maxOps) {
                const batch = writeBatch(db);
                batchFns.slice(i, i + maxOps).forEach((fn) => fn(batch));
                await batch.commit();
            }
        }

        function queueSetOps(ops, ref, data) {
            const payload = deserializeForImport(data);
            ops.push((batch) => batch.set(ref, payload, { merge: true }));
            return estimatePayloadBytes(payload);
        }

        async function setDocMergeSafe(ref, data) {
            const payload = deserializeForImport(data);
            const bytes = estimatePayloadBytes(payload);
            if (bytes > FIRESTORE_DOC_MAX_BYTES) {
                throw new Error(
                    `Dokumen terlalu besar (${Math.round(bytes / 1024)} KB, maks ~1024 KB/dokumen): ${ref.path}. `
                    + 'Kurangi foto/CV di data pelamar tersebut lalu export ulang.'
                );
            }
            await setDoc(ref, payload, { merge: true });
        }

        function parseFullBackupPayload(raw) {
            const data = typeof raw === 'string' ? JSON.parse(raw) : raw;
            if (data?.format === 'sencha_full_backup' && data.collections) return data;
            throw new Error('Bukan file backup penuh Sencha (format sencha_full_backup). Gunakan Export semua data dari HRD.');
        }

        async function restoreFullFirestoreBackup() {
            if (!db) return Swal.fire('Server', 'Belum terhubung. Jalankan START.bat.', 'error');
            let picked;
            try {
                picked = await pickJsonFile();
            } catch (e) {
                if (e.message === 'Batal') return;
                return Swal.fire('File', e.message || 'Tidak valid', 'error');
            }
            let pack;
            try {
                pack = parseFullBackupPayload(picked.data);
            } catch (e) {
                return Swal.fire('Format', e.message, 'error');
            }
            const src = pack.sourceProjectId || 'tidak diketahui';
            const dst = firebaseConfig.projectId || '—';
            const ok = await Swal.fire({
                title: 'Restore backup ke Firebase ini?',
                html: `<p class="text-sm">Dari project: <strong>${escapeHtml(src)}</strong><br>Ke project: <strong>${escapeHtml(dst)}</strong></p>
                    <p class="text-xs mt-2 text-amber-700">Menimpa/menggabungkan dokumen dengan ID sama. Pastikan <code>firebaseConfig</code> sudah project <strong>baru</strong>.</p>`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Ya, restore',
                confirmButtonColor: '#7c3aed',
                cancelButtonText: 'Batal'
            });
            if (!ok.isConfirmed) return;

            try {
                Swal.fire({ title: 'Memeriksa izin…', text: 'Tes tulis ke Firestore…', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
                await verifyFirestoreWriteAccess();
                Swal.close();
            } catch (e) {
                return Swal.fire({
                    title: 'Restore gagal — tidak bisa menulis',
                    html: `<pre class="text-left text-xs whitespace-pre-wrap">${escapeHtml(firestoreErrHint(e))}</pre>`,
                    icon: 'error',
                    width: 520
                });
            }

            Swal.fire({ title: 'Restore…', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
            const smallOps = [];
            const c = pack.collections;
            const queueFlat = (colName, items) => {
                (items || []).forEach((row) => {
                    if (!row?.id) return;
                    queueSetOps(smallOps, doc(db, colName, row.id), row.data);
                });
            };

            try {
                Swal.update({ html: 'Restore posisi, blog, indeks…' });
                queueFlat(COL_POSITIONS, c[COL_POSITIONS]);
                queueFlat(COL_JOB_VACANCIES, c[COL_JOB_VACANCIES]);
                queueFlat(COL_BLOG, c[COL_BLOG]);
                queueFlat(COL_BROADCAST, c[COL_BROADCAST]);
                queueFlat(COL_ACTIVITY, c[COL_ACTIVITY]);
                queueFlat(COL_CHAT_THREADS, c[COL_CHAT_THREADS]);
                queueFlat(COL_LOGIN_INDEX, c[COL_LOGIN_INDEX]);
                if (c.app_meta_main?.data) {
                    queueSetOps(smallOps, doc(db, COL_META, META_DOC), c.app_meta_main.data);
                }
                await commitBatchFns(smallOps, 80);

                const applicants = c.applicants || [];
                for (let i = 0; i < applicants.length; i++) {
                    const row = applicants[i];
                    if (!row?.id) continue;
                    Swal.update({ html: `Restore pelamar ${i + 1} / ${applicants.length}?` });
                    await setDocMergeSafe(doc(db, COL_APPLICANTS, row.id), row.data);
                    const subOps = [];
                    for (const m of row.messages || []) {
                        if (!m?.id) continue;
                        queueSetOps(subOps, doc(db, COL_APPLICANTS, row.id, SUB_MESSAGES, m.id), m.data);
                    }
                    for (const v of row.visits || []) {
                        if (!v?.id) continue;
                        queueSetOps(subOps, doc(db, COL_APPLICANTS, row.id, SUB_VISITS, v.id), v.data);
                    }
                    if (subOps.length) await commitBatchFns(subOps, 100);
                }

                Swal.update({ html: 'Restore interview…' });
                for (const row of c.interview_sessions || []) {
                    if (!row?.id) continue;
                    await setDocMergeSafe(doc(db, COL_INTERVIEW_SESSIONS, row.id), row.data);
                    const qOps = [];
                    for (const q of row.queue || []) {
                        if (!q?.id) continue;
                        queueSetOps(qOps, doc(db, COL_INTERVIEW_SESSIONS, row.id, SUB_INTERVIEW_QUEUE, q.id), q.data);
                    }
                    if (qOps.length) await commitBatchFns(qOps, 100);
                }
                invalidateApplicantsCache();
                applicantFullCache.clear();
                await loadApplicantsList({ force: true, silent: true });
                Swal.fire('Restore selesai', `Data backup ditulis ke database lokal (<strong>${escapeHtml(dst)}</strong>). Muat ulang halaman jika perlu.`, 'success');
            } catch (e) {
                Swal.fire('Restore gagal', firestoreErrHint(e), 'error');
            }
        }

        function bindMigrationBackupUi() {
            $('btn-export-full-backup')?.addEventListener('click', () => void exportFullFirestoreBackup());
            $('btn-restore-full-backup')?.addEventListener('click', () => void restoreFullFirestoreBackup());
        }

        // --- Import backup JSON (base64 foto/CV dari Cursor) -> Firestore ---
        function setBackupImportUiVisible(visible) {
            const headerBtn = $('btn-import-backup');
            if (headerBtn) {
                headerBtn.classList.toggle('hidden', !visible);
                headerBtn.classList.toggle('inline-flex', visible);
            }
            ['btn-import-backup-dash', 'backup-import-card'].forEach((id) => {
                const el = $(id);
                if (el) el.classList.toggle('hidden', !visible);
            });
            if (visible) refreshBackupImportHint();
        }

        function refreshBackupImportHint() {
            const el = $('backup-import-hint');
            if (!el) return;
            el.textContent = `Pilih file backup (mis. ${BACKUP_JSON_HINT_PATH}). Cursor mengisi foto sebagai base64 di dalam JSON.`;
        }

        function applicantExistsByRingkasanId(idRingkasan) {
            if (!idRingkasan) return false;
            return state.applicants.some((a) => a.idRingkasan === idRingkasan);
        }

        function parseBackupJson(raw) {
            const data = typeof raw === 'string' ? JSON.parse(raw) : raw;
            let list = [];
            if (Array.isArray(data.applicants)) list = data.applicants;
            else if (Array.isArray(data.pelamar)) {
                list = data.pelamar.map((entry) => {
                    const f = entry.hrdForm || entry;
                    return {
                        idRingkasan: entry.idRingkasan,
                        nama: f.nama,
                        tanggalLahir: f.tanggalLahir,
                        whatsapp: f.whatsappDb || f.whatsappForm || f.whatsapp,
                        posisiList: f.posisiList || (f.posisi ? [f.posisi] : []),
                        status: f.status,
                        catatanList: entry.catatanList || [],
                        photos: entry.photos || f.photos || [],
                        cvFiles: (() => { const arr = Array.isArray(entry.cvFiles) ? entry.cvFiles.filter(x=>x?.data) : []; if (arr.length) return arr; const one = entry.cvFile || f.cvFile; return one?.data ? [one] : []; })(),
                        cvFile: (() => { const arr = Array.isArray(entry.cvFiles) ? entry.cvFiles.filter(x=>x?.data) : []; if (arr.length) return arr[0]; return entry.cvFile || f.cvFile || null; })()
                    };
                });
            } else {
                throw new Error('Format backup tidak dikenali. Butuh "applicants" atau "pelamar".');
            }
            if (!list.length) throw new Error('Tidak ada pelamar di file backup.');
            return { meta: data, applicants: list };
        }

        function pickBackupJsonFile() {
            return new Promise((resolve, reject) => {
                const input = document.createElement('input');
                input.type = 'file';
                input.accept = '.json,application/json';
                input.onchange = async () => {
                    const file = input.files?.[0];
                    if (!file) return reject(new Error('Batal'));
                    try {
                        const text = await file.text();
                        resolve({ file, data: parseBackupJson(text) });
                    } catch (e) {
                        reject(e);
                    }
                };
                input.click();
            });
        }

        function normalizeBackupAttachments(raw) {
            if (!Array.isArray(raw)) return [];
            return raw.filter(Boolean).slice(0, 3).map((p) => {
                if (typeof p === 'string') return { data: p, mime: 'image/jpeg', name: 'foto.jpg' };
                if (p?.data) return { data: p.data, mime: p.mime || 'image/jpeg', name: p.name || 'foto.jpg' };
                return null;
            }).filter(Boolean);
        }

        async function preparePhotosForImport(rawPhotos) {
            const items = normalizeBackupAttachments(rawPhotos);
            const out = [];
            for (const item of items) {
                try {
                    const compressed = await compressUntilFit(item.data, PHOTO_TARGET_BYTES);
                    out.push({ data: compressed, mime: 'image/jpeg', name: item.name || 'foto.jpg' });
                } catch (e) {
                    console.warn('Foto gagal dikompres, pakai asli', e);
                    out.push(item);
                }
            }
            return out;
        }

        function prepareCvForImport(cvFile) {
            if (!cvFile?.data) return null;
            const approx = cvFile.data.length * 0.75;
            if (approx > CV_MAX_BYTES) {
                throw new Error(`CV ${cvFile.name || ''} terlalu besar (>${Math.round(CV_MAX_BYTES / 1024)} KB)`);
            }
            return {
                name: cvFile.name || 'lamaran.pdf',
                mime: cvFile.mime || 'application/pdf',
                data: cvFile.data
            };
        }

        async function buildApplicantPayloadFromBackup(entry) {
            const nama = String(entry.nama || entry.hrdForm?.nama || '').trim();
            const tanggalLahir = String(entry.tanggalLahir || entry.hrdForm?.tanggalLahir || '').trim();
            let posisiList = Array.isArray(entry.posisiList) ? [...entry.posisiList] : [];
            if (!posisiList.length && entry.posisi) posisiList = [entry.posisi];
            if (!posisiList.length && entry.hrdForm?.posisiList) posisiList = [...entry.hrdForm.posisiList];
            if (!posisiList.length && entry.hrdForm?.posisi) posisiList = [entry.hrdForm.posisi];
            posisiList = posisiList.map(normalizePosisiName).filter(Boolean);
            const whatsapp = normalizeWhatsapp(
                entry.whatsapp || entry.hrdForm?.whatsappDb || entry.hrdForm?.whatsappForm || ''
            );
            const catatanList = (entry.catatanList || []).map((item) => ({
                id: makeCatatanId(),
                judul: String(item.judul || '').trim(),
                isi: String(item.isi || '')
            })).filter((c) => c.judul || c.isi);
            const photos = await preparePhotosForImport(entry.photos || entry.hrdForm?.photos);
            let cvFiles = [];
            if (Array.isArray(entry.cvFiles) && entry.cvFiles.length) {
                for (const cf of entry.cvFiles) {
                    try {
                        const one = prepareCvForImport(cf);
                        if (one) cvFiles.push(one);
                    } catch (cvErr) {
                        console.warn('CV dilewati:', cvErr.message);
                    }
                }
            } else {
                try {
                    const one = prepareCvForImport(entry.cvFile || entry.hrdForm?.cvFile);
                    if (one) cvFiles.push(one);
                } catch (cvErr) {
                    console.warn('CV dilewati:', cvErr.message);
                }
            }
            if (!cvFiles.length && entry.cvFileLocal?.name) {
                const note = `PDF ${entry.cvFileLocal.name} (~${Math.round((entry.cvFileLocal.sizeBytes || 0) / 1024)} KB) ada di folder lampiran - unggah manual di edit pelamar.`;
                const has = catatanList.some((c) => c.judul === 'PDF lamaran');
                if (!has) catatanList.push({ id: makeCatatanId(), judul: 'PDF lamaran', isi: note });
            }
            const payload = {
                nama,
                tanggalLahir,
                umurSaatInput: calcAgeFromBirthdate(tanggalLahir),
                posisi: posisiList.join(', '),
                posisiList,
                whatsapp,
                photos,
                catatanList,
                catatan: '',
                status: normalizeStatus(entry.status || entry.hrdForm?.status || 'belum_dinilai'),
                source: 'backup_import'
            };
            if (entry.idRingkasan) payload.idRingkasan = entry.idRingkasan;
            const docPhotosRaw = entry.docPhotos || entry.hrdForm?.docPhotos;
            if (Array.isArray(docPhotosRaw) && docPhotosRaw.length) {
                attachDocFieldsToPayload(payload, 'images', null, docPhotosRaw.filter(Boolean));
            } else if (cvFiles.length) {
                attachDocFieldsToPayload(payload, 'pdf', cvFiles[0], []);
            }
            return payload;
        }

        function isBackupEntryPending(entry) {
            if (entry.skipImport) return false;
            if (!entry.idRingkasan) return true;
            return !applicantExistsByRingkasanId(entry.idRingkasan);
        }

        async function importBackupApplicants(applicants) {
            await ensureAnonAuth();
            let ok = 0;
            let skipped = 0;
            const errors = [];
            const total = applicants.length;
            for (let i = 0; i < applicants.length; i++) {
                const entry = applicants[i];
                const label = entry.nama || entry.hrdForm?.nama || entry.idRingkasan || `#${i + 1}`;
                if (!isBackupEntryPending(entry)) {
                    skipped++;
                    continue;
                }
                Swal.update({
                    title: `Mengimpor ${i + 1} / ${total}`,
                    html: `<p class="text-sm">${escapeHtml(label)}</p>`
                });
                try {
                    const payload = sanitizeFirestorePayload(await buildApplicantPayloadFromBackup(entry));
                    if (!payload.nama || !payload.tanggalLahir || !payload.posisiList?.length) {
                        throw new Error('Nama, tanggal lahir, atau posisi kosong');
                    }
                    const sizeCheck = JSON.stringify({ ...payload, createdAt: 1, updatedAt: 1 }).length;
                    if (sizeCheck > 950000) {
                        throw new Error('Data terlalu besar setelah foto - kurangi resolusi di folder lampiran');
                    }
                    payload.createdAt = serverTimestamp();
                    payload.updatedAt = serverTimestamp();
                    await withTimeout(
                        addDoc(collection(db, COL_APPLICANTS), payload),
                        FIRESTORE_OP_TIMEOUT_MS,
                        `Simpan ${payload.nama}`
                    );
                    for (const p of payload.posisiList) {
                        await withTimeout(ensurePositionInMaster(p), 12000, `Posisi ${p}`).catch(() => {});
                    }
                    ok++;
                } catch (err) {
                    const code = err?.code ? ` [${err.code}]` : '';
                    errors.push(`${label}: ${err.message || err}${code}`);
                }
            }
            return { ok, skipped, errors, total };
        }

        async function runBackupImport() {
            if (!db) return Swal.fire('Firebase belum siap', '', 'error');
            let picked;
            try {
                picked = await pickBackupJsonFile();
            } catch (err) {
                if (err.message === 'Batal') return;
                return Swal.fire('File tidak valid', err.message || String(err), 'error');
            }

            const { applicants } = picked.data;
            const pending = applicants.filter(isBackupEntryPending);
            if (!pending.length) {
                return Swal.fire(
                    'Tidak ada yang baru',
                    'Semua pelamar di file sudah ada di database (idRingkasan sama).',
                    'info'
                );
            }

            const names = pending.map((p) => p.nama || p.hrdForm?.nama || p.idRingkasan).join(', ');
            const fotoCount = pending.reduce((n, p) => n + (p.photos?.length || p.hrdForm?.photos?.length || 0), 0);

            const confirm = await Swal.fire({
                title: `Import ${pending.length} pelamar?`,
                html: `<p class="text-sm text-slate-600">${escapeHtml(names)}</p>
                    <p class="text-xs mt-2 text-slate-500">${fotoCount} foto di file &middot; kompresi otomatis &middot; max ~${Math.round(FIRESTORE_OP_TIMEOUT_MS / 1000)} dtk per orang</p>`,
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: 'Ya, import',
                cancelButtonText: 'Batal',
                showLoaderOnConfirm: true,
                allowOutsideClick: () => !Swal.isLoading(),
                preConfirm: async () => {
                    try {
                        return await importBackupApplicants(pending);
                    } catch (err) {
                        Swal.showValidationMessage(err.message || String(err));
                        return false;
                    }
                }
            });

            if (!confirm.isConfirmed || !confirm.value) return;
            const { ok, skipped, errors } = confirm.value;

            if (errors.length) {
                await Swal.fire(
                    ok ? 'Sebagian berhasil' : 'Import gagal',
                    `Berhasil: ${ok}. Dilewati (sudah ada): ${skipped}.\n\n${errors.join('\n')}`,
                    ok ? 'warning' : 'error'
                );
            } else {
                await Swal.fire('Import selesai', `${ok} pelamar ditambahkan.`, 'success');
                showToast(`${ok} pelamar diimpor`);
            }
            if (ok) location.hash = '#pelamar';
        }

        function bindBackupImport() {
            const run = () => runBackupImport();
            $('btn-import-backup')?.addEventListener('click', run);
            $('btn-import-backup-dash')?.addEventListener('click', run);
            $('btn-import-backup-run')?.addEventListener('click', run);
        }

        function renderDashboard() {
            const list = state.applicants;
            $('stat-total').textContent = list.length;
            $('stat-belum').textContent = list.filter((a) => normalizeStatus(a.status) === 'belum_dinilai').length;
            $('stat-pertimbangkan').textContent = list.filter((a) => normalizeStatus(a.status) === 'pertimbangkan').length;
            $('stat-diterima').textContent = list.filter((a) => normalizeStatus(a.status) === 'diterima').length;
            $('stat-tidak-cocok').textContent = list.filter((a) => normalizeStatus(a.status) === 'tidak_cocok').length;
            renderStatusLegend();
            const counts = {};
            list.forEach((a) => {
                getPosisiListFromApplicant(a).forEach((p) => { counts[p] = (counts[p] || 0) + 1; });
            });
            const sorted = Object.entries(counts).sort((a, b) => b[1] - a[1]).slice(0, 6);
            $('stat-posisi').innerHTML = sorted.length
                ? sorted.map(([p, n]) => `<div class="flex justify-between"><span>${escapeHtml(p)}</span><span class="font-bold text-blue-600">${n}</span></div>`).join('')
                : '<p class="text-slate-400">Belum ada data.</p>';
        }

        function formatTsDetail(ts) {
            if (!ts) return '—';
            try {
                const d = ts.toDate ? ts.toDate() : new Date(ts);
                return d.toLocaleString('id-ID', { day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit', second: '2-digit' });
            } catch { return '—'; }
        }
        function messageSortKeyHrd(m) {
            const t = m?.createdAt || m?.at;
            if (t?.toMillis) return t.toMillis();
            if (t?.seconds) return t.seconds * 1000;
            return 0;
        }

        async function touchChatThread(applicantId, from, text) {
            if (!db || !applicantId) return;
            const a = state.applicants.find((x) => x.id === applicantId);
            const patch = {
                applicantId,
                applicantName: a?.nama || 'Pelamar',
                posisi: a ? getPosisiDisplay(a) : '',
                lastMessage: String(text || '').slice(0, 280),
                lastFrom: from,
                lastMessageAt: serverTimestamp(),
                updatedAt: serverTimestamp()
            };
            if (from === 'pelamar') patch.unreadHrd = increment(1);
            if (from === 'hrd') patch.unreadPelamar = increment(1);
            await setDoc(doc(db, COL_CHAT_THREADS, applicantId), patch, { merge: true });
        }

        async function markHrdThreadRead(applicantId) {
            if (!db || !applicantId) return;
            await setDoc(doc(db, COL_CHAT_THREADS, applicantId), { unreadHrd: 0 }, { merge: true });
        }

        function totalUnreadHrd() {
            return state.chatThreads.reduce((n, t) => n + (Number(t.unreadHrd) || 0), 0);
        }

        function updateChatBadges() {
            const n = totalUnreadHrd();
            ['sidebar-chat-badge', 'header-chat-badge'].forEach((id) => {
                const el = $(id);
                if (!el) return;
                el.textContent = n > 99 ? '99+' : String(n);
                el.classList.toggle('hidden', n <= 0);
            });
        }

        function subscribeChatThreads() {
            if (!db) return;
            if (chatThreadsUnsub) chatThreadsUnsub();
            chatThreadsUnsub = onSnapshot(collection(db, COL_CHAT_THREADS), (snap) => {
                state.chatThreads = snap.docs.map((d) => ({ id: d.id, ...d.data() }))
                    .sort((a, b) => {
                        const ta = a.lastMessageAt?.toMillis?.() || (a.lastMessageAt?.seconds ? a.lastMessageAt.seconds * 1000 : 0);
                        const tb = b.lastMessageAt?.toMillis?.() || (b.lastMessageAt?.seconds ? b.lastMessageAt.seconds * 1000 : 0);
                        return tb - ta;
                    });
                updateChatBadges();
                if (parseRoute().view === 'chat') renderChatInbox();
            }, (err) => console.error('chat_threads', err));
        }

        function teardownChatHubMessages() {
            if (state.chatHubMsgUnsub) {
                state.chatHubMsgUnsub();
                state.chatHubMsgUnsub = null;
            }
        }

        function renderChatHubThread() {
            const box = $('chat-hub-thread');
            if (!box) return;
            const msgs = state.detailMessages;
            if (!state.chatHubApplicantId) {
                box.innerHTML = '<p class="text-xs text-slate-400 text-center py-8">Pilih pelamar di daftar kiri.</p>';
                return;
            }
            if (!msgs.length) {
                box.innerHTML = '<p class="text-xs text-slate-400 text-center py-8">Belum ada pesan. Mulai percakapan di bawah.</p>';
                return;
            }
            box.innerHTML = msgs.map((m) => {
                const hrd = m.from === 'hrd';
                const side = hrd ? 'hrd' : 'pelamar';
                const inner = renderMessageBubbleHtml(m, side, state.chatHubApplicantId);
                const bubbleCls = m?.type === 'undangan_wawancara'
                    ? (hrd ? 'bg-violet-100 dark:bg-violet-900/40' : 'bg-white dark:bg-slate-800 border border-violet-200 dark:border-violet-700')
                    : (hrd ? 'bg-blue-600 text-white' : 'bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-600');
                const rsvpNote = m?.type === 'undangan_wawancara' && hrd && (() => {
                    const key = m.inviteKey || normalizePosisiName(m.posisi);
                    const aa = state.applicants.find((x) => x.id === state.chatHubApplicantId);
                    const rv = aa ? getUndanganEntry(aa, key)?.rsvp : '';
                    return rv && rv !== 'menunggu' ? `<p class="text-[10px] font-bold mt-1 text-emerald-200">Pelamar: ${escapeHtml(rsvpLabel(rv))}</p>` : '';
                })();
                return `<div class="flex ${hrd ? 'justify-end' : 'justify-start'}"><div class="max-w-[88%] px-3 py-2 rounded-xl text-xs ${bubbleCls}">${inner}${rsvpNote || ''}<p class="opacity-70 mt-1 text-[10px]">${hrd ? 'HRD' : 'Pelamar'} · ${formatTsDetail(m.createdAt)}</p></div></div>`;
            }).join('');
            box.scrollTop = box.scrollHeight;
        }

        function renderChatInbox() {
            const list = $('chat-inbox-list');
            const empty = $('chat-inbox-empty');
            if (!list) return;
            const q = ($('chat-inbox-search')?.value || '').trim().toLowerCase();
            const threads = state.chatThreads.filter((t) => {
                if (!q) return true;
                return String(t.applicantName || '').toLowerCase().includes(q)
                    || String(t.posisi || '').toLowerCase().includes(q);
            });
            if (!threads.length) {
                list.innerHTML = '';
                empty?.classList.remove('hidden');
                updateListPaginationUi('chat', 0, 0);
                return;
            }
            empty?.classList.add('hidden');
            const page = sliceForListPage('chat', threads);
            list.innerHTML = page.items.map((t) => {
                const aid = t.applicantId || t.id;
                const unread = Number(t.unreadHrd) || 0;
                const active = state.chatHubApplicantId === aid;
                return `<button type="button" class="chat-inbox-row w-full text-left p-3 ${active ? 'is-active' : ''}" data-chat-id="${escapeHtml(aid)}">
                    <div class="flex justify-between gap-2 items-start">
                        <span class="font-bold text-sm truncate">${escapeHtml(t.applicantName || 'Pelamar')}</span>
                        ${unread ? `<span class="nav-badge shrink-0">${unread > 9 ? '9+' : unread}</span>` : ''}
                    </div>
                    <p class="text-xs text-slate-500 truncate mt-0.5">${escapeHtml(t.lastMessage || '—')}</p>
                    <p class="text-[10px] text-slate-400 mt-1">${formatTs(t.lastMessageAt)} · ${t.lastFrom === 'hrd' ? 'Anda' : 'Pelamar'}</p>
                </button>`;
            }).join('');
            updateListPaginationUi('chat', page.total, page.visible);
        }

        function selectChatHubApplicant(id) {
            if (!id || !db) return;
            state.chatHubApplicantId = id;
            teardownChatHubMessages();
            markHrdThreadRead(id);
            const a = state.applicants.find((x) => x.id === id);
            const header = $('chat-hub-header');
            if (header) {
                header.innerHTML = `<div class="flex flex-wrap justify-between gap-2 items-start">
                    <div><p class="font-bold">${escapeHtml(a?.nama || 'Pelamar')}</p>
                    <p class="text-xs text-slate-500">${escapeHtml(getPosisiDisplay(a) || '—')}</p></div>
                    <a href="#pelamar/${id}" class="text-xs font-bold text-blue-600 hover:underline">Buka profil</a>
                </div>`;
            }
            $('chat-hub-form')?.classList.remove('hidden');
            renderChatInbox();
            state.chatHubMsgUnsub = onSnapshot(collection(db, COL_APPLICANTS, id, SUB_MESSAGES), (snap) => {
                state.detailMessages = snap.docs.map((d) => ({ id: d.id, ...d.data() }))
                    .sort((a, b) => messageSortKeyHrd(a) - messageSortKeyHrd(b));
                renderChatHubThread();
                if (state.detailTab === 'pesan') renderDetailMessagesPane(id);
            }, (err) => console.error('chat hub messages', err));
            renderChatHubThread();
        }

        async function sendChatHubMessage(e) {
            e.preventDefault();
            const id = state.chatHubApplicantId;
            const text = ($('chat-hub-input')?.value || '').trim();
            if (!id || !text || !db) return;
            try {
                await addDoc(collection(db, COL_APPLICANTS, id, SUB_MESSAGES), {
                    from: 'hrd',
                    text,
                    createdAt: serverTimestamp()
                });
                await touchChatThread(id, 'hrd', text);
                $('chat-hub-input').value = '';
            } catch (err) {
                Swal.fire('Gagal', err.message || 'Pesan tidak terkirim', 'error');
            }
        }

        function visitPageLabel(p) {
            const m = { akun: 'Akun / dashboard', pesan: 'Tab pesan', daftar: 'Kirim lamaran', login: 'Login', buka: 'Buka portal', kunjungan: 'Kunjungan umum' };
            return m[p] || p || '—';
        }
        function teardownDetailSubs() {
            if (state.detailMsgUnsub) { state.detailMsgUnsub(); state.detailMsgUnsub = null; }
            state.detailMessages = [];
        }
        function subscribeDetailExtras(id) {
            teardownDetailSubs();
            if (!db || !id) return;
            state.detailMsgUnsub = onSnapshot(collection(db, COL_APPLICANTS, id, SUB_MESSAGES), (snap) => {
                state.detailMessages = snap.docs.map((d) => ({ id: d.id, ...d.data() }))
                    .sort((a, b) => messageSortKeyHrd(a) - messageSortKeyHrd(b));
                if (state.detailTab === 'pesan') renderDetailMessagesPane(id);
            }, (err) => console.error('detail msg', err));
        }
        function renderDetailCloseBar() {
            return `<a href="#pelamar" class="inline-flex items-center justify-center w-10 h-10 rounded-xl border border-slate-200 dark:border-slate-600 text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-700 shrink-0" title="Kembali ke daftar" aria-label="Tutup"><i class="fa-solid fa-xmark text-lg"></i></a>`;
        }

        function renderDetailTabBar(id, tab) {
            const tabs = [
                { id: 'profil', label: 'Profil' },
                { id: 'pesan', label: 'Pesan' },
                { id: 'aktivitas', label: 'Log aktivitas' }
            ];
            return `<div class="flex flex-wrap gap-2 border-b border-slate-200 dark:border-slate-700 pb-3 mb-4">
                ${tabs.map((t) => `<a href="#pelamar/${id}/${t.id}" class="px-3 py-1.5 rounded-lg text-xs font-bold ${tab === t.id ? 'bg-blue-600 text-white' : 'bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300 hover:bg-slate-200'}">${t.label}</a>`).join('')}
            </div>`;
        }
        function renderDetailMessagesPane(id) {
            const pane = $('detail-tab-pane');
            if (!pane) return;
            markHrdThreadRead(id);
            const a = state.applicants.find((x) => x.id === id);
            const msgs = state.detailMessages;
            pane.innerHTML = `
                <div class="space-y-3">
                    <p class="text-xs text-slate-500">Chat dengan ${escapeHtml(a?.nama || 'pelamar')} — tanpa WhatsApp.</p>
                    <div id="hrd-chat-thread" class="max-h-64 overflow-y-auto space-y-2 border border-slate-100 dark:border-slate-700 rounded-xl p-3 bg-slate-50/50 dark:bg-slate-900/30">
                        ${msgs.length ? msgs.map((m) => {
                            const hrd = m.from === 'hrd';
                            const side = hrd ? 'hrd' : 'pelamar';
                            const inner = renderMessageBubbleHtml(m, side, id);
                            const bubbleCls = m?.type === 'undangan_wawancara'
                                ? (hrd ? 'bg-violet-100 dark:bg-violet-900/40 text-slate-800 dark:text-slate-100' : 'bg-white dark:bg-slate-800 border border-violet-200')
                                : (hrd ? 'bg-blue-600 text-white' : 'bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-600');
                            const rsvpNote = m?.type === 'undangan_wawancara' && hrd ? (() => {
                                const key = m.inviteKey || normalizePosisiName(m.posisi);
                                const rv = getUndanganEntry(a, key)?.rsvp;
                                return rv && rv !== 'menunggu' ? `<p class="text-[10px] font-bold mt-1 text-violet-600">Konfirmasi: ${escapeHtml(rsvpLabel(rv))}</p>` : '';
                            })() : '';
                            return `<div class="flex ${hrd ? 'justify-end' : 'justify-start'}"><div class="max-w-[85%] px-3 py-2 rounded-xl text-xs ${bubbleCls}">${inner}${rsvpNote || ''}<p class="opacity-70 mt-1 text-[10px]">${hrd ? 'HRD' : 'Pelamar'} · ${formatTsDetail(m.createdAt)}</p></div></div>`;
                        }).join('') : '<p class="text-xs text-slate-400 text-center py-4">Belum ada pesan.</p>'}
                    </div>
                    <form id="hrd-chat-form" class="flex gap-2">
                        <input type="text" id="hrd-chat-input" maxlength="2000" placeholder="Tulis pertanyaan ke pelamar..." class="flex-1 px-3 py-2 rounded-lg border text-sm dark:bg-slate-900">
                        <button type="submit" class="px-4 py-2 rounded-lg bg-emerald-600 text-white text-sm font-bold shrink-0"><i class="fa-solid fa-paper-plane mr-1"></i> Kirim</button>
                    </form>
                </div>`;
            const thread = $('hrd-chat-thread');
            if (thread) thread.scrollTop = thread.scrollHeight;
            $('hrd-chat-form')?.addEventListener('submit', (e) => sendHrdMessage(e, id));
        }
        function renderDetailActivityPane(id) {
            const pane = $('detail-tab-pane');
            if (!pane) return;
            const rows = getActivityLogsForApplicant(id);
            pane.innerHTML = `
                <p class="text-xs text-slate-500 mb-3">Sama dengan menu <strong>Log Aktivitas</strong> — semua kegiatan pelamar di portal (tanggal &amp; jam).</p>
                ${rows.length ? `<div class="overflow-x-auto"><table class="w-full text-sm"><thead><tr class="text-left text-xs uppercase text-slate-400 border-b border-slate-200"><th class="py-2 pr-4">Waktu</th><th class="py-2">Kegiatan</th></tr></thead><tbody>
                    ${rows.map((v) => `<tr class="border-b border-slate-100 dark:border-slate-700"><td class="py-2 pr-4 font-mono text-xs">${formatTsDetail(v.at)}</td><td class="py-2">${escapeHtml(activityLogLabel(v))}</td></tr>`).join('')}
                </tbody></table></div>` : '<p class="text-sm text-slate-400 py-6 text-center">Belum ada aktivitas tercatat.</p>'}`;
        }
        async function sendHrdMessage(e, id) {
            e.preventDefault();
            const text = ($('hrd-chat-input')?.value || '').trim();
            if (!text || !db) return;
            try {
                await addDoc(collection(db, COL_APPLICANTS, id, SUB_MESSAGES), {
                    from: 'hrd',
                    text,
                    createdAt: serverTimestamp()
                });
                await touchChatThread(id, 'hrd', text);
                $('hrd-chat-input').value = '';
            } catch (err) {
                Swal.fire('Gagal', err.message || 'Pesan tidak terkirim', 'error');
            }
        }

        async function renderDetail(id, tab) {
            state.detailTab = tab || 'profil';
            const listRow = state.applicants.find((x) => x.id === id);
            const box = $('detail-content');
            if (!listRow) {
                teardownDetailSubs();
                box.innerHTML = '<p class="text-red-600 font-bold">Data tidak ditemukan.</p><a href="#pelamar" class="text-blue-600 text-sm">Kembali</a>';
                return;
            }
            subscribeDetailExtras(id);
            const tabBar = renderDetailTabBar(id, state.detailTab);

            if (state.detailTab === 'pesan') {
                const a = listRow;
                box.innerHTML = `<div class="bg-white/80 dark:bg-slate-800/80 rounded-2xl p-6 border border-white shadow-sm"><div class="flex justify-end mb-2">${renderDetailCloseBar()}</div>${tabBar}<div id="hrd-detail-tab-pane"></div>
                    <div class="flex flex-wrap gap-2 pt-4 border-t border-slate-100 dark:border-slate-700 mt-4">
                        <a href="#pelamar/${id}" class="px-4 py-2 rounded-lg border text-sm font-bold">Profil</a>
                        <a href="#pelamar" class="px-4 py-2 rounded-lg text-sm font-bold text-slate-500">Daftar</a>
                    </div></div>`;
                renderDetailMessagesPane(id);
                return;
            }
            if (state.detailTab === 'aktivitas') {
                box.innerHTML = `<div class="bg-white/80 dark:bg-slate-800/80 rounded-2xl p-6 border border-white shadow-sm"><div class="flex justify-end mb-2">${renderDetailCloseBar()}</div>${tabBar}<div id="hrd-detail-tab-pane"></div>
                    <div class="flex flex-wrap gap-2 pt-4 border-t border-slate-100 dark:border-slate-700 mt-4">
                        <a href="#pelamar/${id}" class="px-4 py-2 rounded-lg border text-sm font-bold">Profil</a>
                        <a href="#pelamar" class="px-4 py-2 rounded-lg text-sm font-bold text-slate-500">Daftar</a>
                    </div></div>`;
                renderDetailActivityPane(id);
                return;
            }

            box.innerHTML = `<div class="bg-white/80 dark:bg-slate-800/80 rounded-2xl p-8 border text-center text-slate-500"><div class="animate-spin rounded-full h-10 w-10 border-4 border-slate-200 border-t-blue-600 mx-auto"></div><p class="mt-3 text-sm font-semibold">Memuat foto &amp; CV…</p></div>`;
            const a = listRow._listLight ? await loadApplicantFull(id) : listRow;
            if (!a) {
                box.innerHTML = '<p class="text-red-600 font-bold">Data tidak ditemukan.</p><a href="#pelamar" class="text-blue-600 text-sm">Kembali</a>';
                return;
            }
            const age = calcAgeFromBirthdate(a.tanggalLahir);

            const photos = (a.photos || []).filter(Boolean);
            const photoHtml = photos.length
                ? `<div class="grid grid-cols-2 md:grid-cols-3 gap-3">${photos.map((p, i) =>
                    `<button type="button" class="block rounded-xl overflow-hidden border border-slate-200 aspect-[3/4] w-full btn-profile-photo-view" data-photo-idx="${i}"><img src="${p}" class="w-full h-full object-cover pointer-events-none" alt="Foto ${i + 1}"></button>`
                ).join('')}</div>`
                : '<p class="text-slate-400 text-sm">Tidak ada foto.</p>';
            const cvHtml = buildDetailCvHtml(a);
            box.innerHTML = `
                <div class="bg-white/80 dark:bg-slate-800/80 rounded-2xl p-6 border border-white shadow-sm space-y-5">
                    <div class="flex justify-end">${renderDetailCloseBar()}</div>
                    ${tabBar}
                    <div class="flex flex-wrap justify-between gap-3 items-start">
                        <div>
                            <h3 class="text-2xl font-black text-slate-900 dark:text-white">${escapeHtml(a.nama)}</h3>
                            <p class="text-blue-600 font-bold mt-1">${escapeHtml(getPosisiDisplay(a))}</p>
                            <p class="text-sm text-slate-500 mt-2">${formatDateId(a.tanggalLahir)} &middot; <strong>${age ?? '—'} tahun</strong> &middot; Masih bekerja: <strong>${formatMasihBekerjaLabel(a.masihBekerja)}</strong></p>
                            ${a.whatsapp ? `<p class="text-sm mt-2">${waChatButtonHtml(a.whatsapp, 'WhatsApp', a)}</p>` : '<p class="text-sm text-slate-400 mt-2">WhatsApp belum diisi</p>'}
                            ${renderUndanganBadgesHtml(a) ? `<div class="mt-2">${renderUndanganBadgesHtml(a)}</div>` : ''}
                            ${a.source === 'public' ? '<span class="inline-block mt-2 text-[10px] font-bold px-2 py-0.5 rounded-full bg-emerald-100 text-emerald-800">Lamaran online</span>' : ''}
                        </div>
                        <span class="${statusClass(a.status)}">${statusLabel(a.status)}</span>
                    </div>
                    <div><h4 class="text-xs font-bold uppercase text-slate-400 mb-2">Foto</h4>${photoHtml}</div>
                    <div><h4 class="text-xs font-bold uppercase text-slate-400 mb-2">Lamaran / CV</h4>${cvHtml}</div>
                    <div><h4 class="text-xs font-bold uppercase text-slate-400 mb-2">Keterangan / catatan</h4>${renderCatatanDetailHtml(a)}</div>
                    <div class="flex flex-wrap gap-2 pt-2 border-t border-slate-100 dark:border-slate-700 items-center">
                        <a href="#pelamar/${id}/pesan" class="px-4 py-2 rounded-lg bg-emerald-600 text-white text-sm font-bold shrink-0"><i class="fa-solid fa-comment-dots mr-1"></i> Pesan</a>
                        <select id="hrd-detail-status" class="px-3 py-2 rounded-lg border text-sm font-semibold dark:bg-slate-900 min-w-[11rem]">${buildStatusSelectOptions(a.status)}</select>
                        <button type="button" id="hrd-btn-save-status" class="px-4 py-2 rounded-lg bg-blue-600 text-white text-sm font-bold shrink-0">Simpan Status</button>
                        <a href="#pelamar/edit/${a.id}" class="px-4 py-2 rounded-lg border text-sm font-bold shrink-0">Edit</a>
                        <button type="button" id="hrd-btn-delete-pelamar" class="px-4 py-2 rounded-lg bg-red-600 text-white text-sm font-bold shrink-0">Hapus</button>
                        <a href="#pelamar" class="px-4 py-2 rounded-lg text-sm font-bold text-slate-500 shrink-0">Daftar</a>
                    </div>
                </div>`;
            $('btn-save-status')?.addEventListener('click', async () => {
                const st = $('detail-status').value;
                const prev = normalizeStatus(a.status);
                const ok = await applyApplicantStatusUpdate(id, st, prev, a.nama || '');
                if (!ok) {
                    $('detail-status').value = prev;
                    return;
                }
                if (normalizeStatus(st) !== prev) {
                    a.status = normalizeStatus(st);
                    invalidateApplicantsCache();
                }
            });
            bindDetailCvViewers(box, a);
            $('btn-delete-pelamar')?.addEventListener('click', async () => {
                const ok = await Swal.fire({ title: 'Hapus pelamar?', text: `"${a.nama}" akan dihapus permanen.`, icon: 'warning', showCancelButton: true, confirmButtonColor: '#dc2626' });
                if (!ok.isConfirmed) return;
                try {
                    const wa = a.whatsappNormalized || (a.whatsapp ? String(a.whatsapp).replace(/\D/g, '') : '');
                    if (wa) await deleteDoc(doc(db, COL_LOGIN_INDEX, wa.startsWith('62') ? wa : '62' + wa.replace(/^0/, ''))).catch(() => {});
                    await deleteDoc(doc(db, COL_APPLICANTS, id));
                    invalidateApplicantsCache();
                    applicantFullCache.delete(id);
                    teardownDetailSubs();
                    showToast('Data dihapus');
                    location.hash = '#pelamar';
                } catch (e) {
                    Swal.fire('Gagal', e.message, 'error');
                }
            });
        }

        function resetForm() {
            $('form-id').value = '';
            delete $('form-id').dataset.prevStatus;
            $('form-pelamar').reset();
            state.formPhotos = [null];
            state.formCvFile = null;
            state.formDocPhotos = [null, null, null, null];
            state.cvMode = null;
            resetPhotoSlot(0);
            clearDocImagesHrd();
            renderPdfSlotHrd();
            applyCvModeUiHrd();
            if ($('form-status')) $('form-status').innerHTML = buildStatusSelectOptions('belum_dinilai');
            if ($('form-whatsapp')) $('form-whatsapp').value = '';
            if ($('form-masih-bekerja')) $('form-masih-bekerja').value = '';
            state.formCatatan = [];
            closeCatatanModal();
            renderFormCatatanList();
            renderFormPosisiMulti();
            updateUmurPreview();
        }

        async function loadFormForEdit(id) {
            Swal.fire({ title: 'Memuat data pelamar…', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
            const a = await loadApplicantFull(id);
            Swal.close();
            if (!a) {
                Swal.fire('Tidak ditemukan', '', 'warning');
                location.hash = '#pelamar';
                return;
            }
            showView('form');
            $('form-id').value = id;
            $('form-id').dataset.prevStatus = normalizeStatus(a.status);
            $('form-nama').value = a.nama || '';
            $('form-tgl-lahir').value = a.tanggalLahir || '';
            state.formCatatan = getCatatanListFromApplicant(a);
            renderFormCatatanList();
            $('form-status').innerHTML = buildStatusSelectOptions(a.status);
            $('form-status').value = normalizeStatus(a.status);
            if ($('form-whatsapp')) {
                const w = normalizeWhatsapp(a.whatsapp);
                $('form-whatsapp').value = w.startsWith('62') ? '0' + w.slice(2) : (a.whatsapp || '');
            }
            if ($('form-masih-bekerja')) $('form-masih-bekerja').value = masihBekerjaToSelectValue(a.masihBekerja);
            renderFormPosisiMulti(getPosisiListFromApplicant(a));
            $('form-posisi').value = '';
            const allPhotos = (a.photos || []).filter(Boolean);
            state.formPhotos = [allPhotos[0] || null];
            state.formCvFile = null;
            state.formDocPhotos = [null, null, null, null];
            state.cvMode = a.cvMode || null;
            const docPhotos = getDocPhotosFromApplicant(a);
            if (docPhotos.length && (a.cvMode === 'images' || inferApplicantCvDisplayMode(a) === 'images')) {
                docPhotos.forEach((p, i) => {
                    state.formDocPhotos[i] = p;
                });
                state.cvMode = 'images';
            } else {
                const cvFrom = getCvFilesFromApplicant(a);
                if (cvFrom[0]) {
                    state.formCvFile = cvFrom[0];
                    state.cvMode = 'pdf';
                }
            }
            renderPhotoSlot(0, state.formPhotos[0]);
            for (let i = 0; i < MAX_DOC_PHOTOS; i++) renderDocPhotoSlotHrd(i, state.formDocPhotos[i]);
            renderPdfSlotHrd();
            applyCvModeUiHrd();
            updateUmurPreview();
            $('page-title').textContent = 'Edit Pelamar';
        }

        // --- Form submit ---

        async function ensureLoginIndexForApplicant(applicantId, nama, whatsapp, accessToken) {
            const waNorm = normalizeWhatsapp(whatsapp);
            if (!waNorm || !applicantId) return;
            const namaNorm = String(nama || '').trim().replace(/\s+/g, ' ').toLowerCase();
            const token = accessToken || generatePortalToken();
            await setDoc(doc(db, COL_APPLICANTS, applicantId), {
                whatsappNormalized: waNorm,
                namaNormalized: namaNorm,
                accessToken: token,
                updatedAt: serverTimestamp()
            }, { merge: true });
            await setDoc(doc(db, COL_LOGIN_INDEX, waNorm), {
                applicantId,
                accessToken: token,
                namaNormalized: namaNorm,
                nama: String(nama || '').trim(),
                updatedAt: serverTimestamp()
            }, { merge: true });
            return token;
        }
        function generatePortalToken() {
            const arr = new Uint8Array(16);
            crypto.getRandomValues(arr);
            return Array.from(arr, (b) => b.toString(16).padStart(2, '0')).join('');
        }

        async function savePelamar(e) {
            e.preventDefault();
            if (!db) return Swal.fire('Database belum siap', 'Pastikan START.bat sudah jalan dan PostgreSQL terhubung.', 'error');

            const nama = $('form-nama').value.trim();
            const tanggalLahir = $('form-tgl-lahir').value;
            const posisiList = getFormPosisiList();
            const posisi = posisiList.join(', ');
            const catatanList = collectFormCatatanForSave();
            const status = normalizeStatus($('form-status').value || 'belum_dinilai');
            const id = $('form-id').value;
            const whatsapp = normalizeWhatsapp($('form-whatsapp')?.value || '');
            const masihBekerja = parseMasihBekerjaSelect($('form-masih-bekerja')?.value || '');

            if (!nama || !tanggalLahir || !posisiList.length) {
                return Swal.fire('Lengkapi data', 'Nama, tanggal lahir, dan minimal satu posisi wajib diisi.', 'warning');
            }
            if (posisiList.length > MAX_POSISI_SELECT) {
                return Swal.fire('Posisi', 'Maksimal 2 posisi.', 'warning');
            }
            const photos = state.formPhotos.filter(Boolean);
            if (!photos.length) {
                return Swal.fire('Foto', 'Foto diri wajib diunggah.', 'warning');
            }
            syncCvModeFromFormHrd();

            const payload = {
                nama,
                tanggalLahir,
                umurSaatInput: calcAgeFromBirthdate(tanggalLahir),
                posisi,
                posisiList,
                whatsapp,
                photos,
                catatanList,
                catatan: '',
                status,
                updatedAt: serverTimestamp()
            };
            if (masihBekerja !== null) payload.masihBekerja = masihBekerja;
            if (!id) payload.source = 'hrd';
            attachDocFieldsToPayload(payload, state.cvMode, state.formCvFile, state.formDocPhotos.filter(Boolean));

            const approxSize = JSON.stringify(payload).length;
            if (approxSize > FIRESTORE_PAYLOAD_MAX) {
                return showUploadFailurePopupHrd('total_size');
            }

            const prevStatus = id
                ? normalizeStatus($('form-id').dataset.prevStatus || 'belum_dinilai')
                : 'belum_dinilai';
            const needsRejectNotif = status === 'tidak_cocok' && prevStatus !== 'tidak_cocok';
            if (needsRejectNotif) {
                const ok = await confirmStatusRejectNotif(nama);
                if (!ok) return;
            }

            Swal.fire({ title: 'Menyimpan...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
            try {
                let savedApplicantId = id;
                if (id) {
                    await updateDoc(doc(db, COL_APPLICANTS, id), payload);
                } else {
                    payload.createdAt = serverTimestamp();
                    const ref = await addDoc(collection(db, COL_APPLICANTS), payload);
                    savedApplicantId = ref.id;
                    await writeActivityLog({
                        type: 'lamaran_baru',
                        applicantId: savedApplicantId,
                        applicantName: nama,
                        posisi,
                        page: 'daftar',
                        source: 'hrd'
                    });
                }
                if (needsRejectNotif && savedApplicantId) {
                    await sendStatusRejectChatMessage(savedApplicantId, nama);
                }
                if (whatsapp && savedApplicantId) await ensureLoginIndexForApplicant(savedApplicantId, nama, whatsapp, null).catch(() => {});
                for (const p of posisiList) await ensurePositionInMaster(p);
                invalidateApplicantsCache();
                applicantFullCache.delete(savedApplicantId);
                await loadApplicantsList({ force: true, silent: true });
                Swal.close();
                showToast(needsRejectNotif ? 'Pelamar tersimpan & pesan chat terkirim' : 'Pelamar tersimpan');
                location.hash = '#pelamar';
            } catch (err) {
                Swal.close();
                Swal.fire('Gagal menyimpan', err.message || 'Periksa koneksi & rules Firestore', 'error');
            }
        }

        // --- Auth app-level ---
        async function verifyLogin(username, password) {
            const userHash = await hashPassword(password);
            return username === DEFAULT_ADMIN_USER && userHash === getEmbeddedAdminHash();
        }

        $('btn-logout')?.addEventListener('click', () => {
            clearSession();
            window.__SENCHA__.showPelamarPublic();
        });

        function renderPdfSlotHrd() {
            const slot = document.querySelector('#hrd-form-pelamar [data-cv-pdf-hrd]');
            if (!slot) return;
            const file = state.formCvFile;
            const label = slot.querySelector('.cv-slot-label');
            if (file) {
                slot.classList.add('has-file');
                const previewBtn = isPdfMime(file.mime, file.name)
                    ? ' <button type="button" class="cv-preview-btn text-xs font-bold text-blue-600 underline ml-1">Lihat PDF</button>'
                    : '';
                label.innerHTML = escapeHtml(file.name) + ' <button type="button" class="cv-rm-hrd text-red-600 font-bold text-xs ml-1">Hapus</button>' + previewBtn;
                slot.querySelector('.cv-preview-btn')?.addEventListener('click', (e) => {
                    e.stopPropagation();
                    openPdfPreview(file.data, file.name);
                });
                slot.querySelector('.cv-rm-hrd')?.addEventListener('click', (e) => {
                    e.stopPropagation();
                    state.formCvFile = null;
                    syncCvModeFromFormHrd();
                    renderPdfSlotHrd();
                });
            } else {
                slot.classList.remove('has-file');
                label.textContent = 'Klik untuk unggah PDF';
            }
        }

        function bindHrdDocUploads() {
            const pdfSlot = document.querySelector('#hrd-form-pelamar [data-cv-pdf-hrd]');
            pdfSlot?.addEventListener('click', (e) => {
                if (e.target.closest('.cv-rm-hrd') || e.target.closest('.cv-preview-btn')) return;
                if (state.cvMode === 'images') {
                    return Swal.fire('Mode foto CV aktif', 'Hapus semua foto CV dulu jika ingin mengunggah PDF.', 'info');
                }
                const input = document.createElement('input');
                input.type = 'file';
                input.accept = '.pdf,application/pdf';
                input.onchange = async () => {
                    const file = input.files?.[0];
                    if (!file) return;
                    if (!isPdfMime(file.type, file.name)) {
                        return Swal.fire('Format', 'Hanya PDF di slot ini. Untuk gambar gunakan slot Foto CV.', 'warning');
                    }
                    if (file.size > CV_MAX_BYTES) return showUploadFailurePopupHrd('pdf_size');
                    try {
                        Swal.fire({ title: 'Membaca file...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
                        const data = await readFileAsDataURL(file);
                        Swal.close();
                        if (data.length * 0.75 > CV_MAX_BYTES) return showUploadFailurePopupHrd('pdf_size');
                        clearDocImagesHrd();
                        state.formCvFile = { name: file.name, mime: file.type || 'application/pdf', data };
                        state.cvMode = 'pdf';
                        renderPdfSlotHrd();
                        applyCvModeUiHrd();
                    } catch {
                        Swal.close();
                        Swal.fire('Gagal membaca file', '', 'error');
                    }
                };
                input.click();
            });

            document.querySelectorAll('#hrd-form-pelamar .doc-photo-slot-hrd').forEach((slot) => {
                slot.addEventListener('click', () => {
                    if (state.cvMode === 'pdf') {
                        return Swal.fire('Mode PDF aktif', 'Hapus PDF dulu jika ingin mengunggah foto CV.', 'info');
                    }
                    const idx = parseInt(slot.dataset.docIdx, 10);
                    const input = document.createElement('input');
                    input.type = 'file';
                    input.accept = 'image/jpeg,image/png,image/webp,image/heic,image/heif,image/*';
                    input.onchange = async () => {
                        const file = input.files?.[0];
                        if (!file) return;
                        try {
                            Swal.fire({ title: 'Mengompres...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
                            state.formDocPhotos[idx] = await processDocPhotoFile(file);
                            state.cvMode = 'images';
                            state.formCvFile = null;
                            renderPdfSlotHrd();
                            Swal.close();
                            renderDocPhotoSlotHrd(idx, state.formDocPhotos[idx]);
                            applyCvModeUiHrd();
                        } catch (err) {
                            Swal.close();
                            Swal.fire('Gagal', hrdImageProcessErrorMessage(err), 'error');
                        }
                    };
                    input.click();
                });
            });

            renderPdfSlotHrd();
            for (let i = 0; i < MAX_DOC_PHOTOS; i++) renderDocPhotoSlotHrd(i, state.formDocPhotos[i]);
            applyCvModeUiHrd();
        }

        // --- CV upload (legacy removed) ---
        /** Muat 3 posisi + 3 pelamar contoh jika database masih kosong. */
        async function seedDummyDataIfEmpty() {
            try {
                const [posSnap, appSnap] = await Promise.all([
                    getDocs(collection(db, COL_POSITIONS)),
                    getDocs(collection(db, COL_APPLICANTS))
                ]);
                if (!posSnap.empty || !appSnap.empty) return;

                for (const name of DEFAULT_POSITIONS) {
                    await setDoc(doc(db, COL_POSITIONS, positionDocId(name)), { name, createdAt: serverTimestamp() }, { merge: true });
                }

                const samples = [
                    {
                        nama: 'Ayu Lestari',
                        tanggalLahir: '1998-04-12',
                        umurSaatInput: calcAgeFromBirthdate('1998-04-12'),
                        posisi: 'WAITER',
                        posisiList: ['WAITER'],
                        status: 'diterima',
                        photos: [],
                        catatanList: [
                            { judul: 'Keunggulan', isi: 'Pengalaman barista 2 tahun, ramah pelanggan, bisa latte art dasar.' },
                            { judul: 'Catatan wawancara', isi: 'Tersedia mulai 1 Juni. Siap shift pagi\u2013sore.' }
                        ],
                        catatan: ''
                    },
                    {
                        nama: 'Budi Santoso',
                        tanggalLahir: '1995-11-03',
                        umurSaatInput: calcAgeFromBirthdate('1995-11-03'),
                        posisi: 'SUPERVISI',
                        posisiList: ['SUPERVISI'],
                        status: 'pertimbangkan',
                        photos: [],
                        catatanList: [
                            { judul: 'Pengalaman', isi: '5 tahun F&B, pernah memimpin tim 8 orang di kafe serupa.' },
                            { judul: 'Perlu diskusi', isi: 'Ekspektasi gaji di atas range awal - perlu approval manajemen.' }
                        ],
                        catatan: ''
                    },
                    {
                        nama: 'Citra Dewi',
                        tanggalLahir: '2000-07-22',
                        umurSaatInput: calcAgeFromBirthdate('2000-07-22'),
                        posisi: 'COOK HELPER',
                        posisiList: ['COOK HELPER'],
                        status: 'belum_dinilai',
                        photos: [],
                        catatanList: [
                            { judul: 'Sertifikasi', isi: 'Sertifikat hygiene food handling (2024). Familiar prep kitchen cepat saji.' }
                        ],
                        catatan: ''
                    }
                ];
                for (const row of samples) {
                    await addDoc(collection(db, COL_APPLICANTS), {
                        ...row,
                        createdAt: serverTimestamp(),
                        updatedAt: serverTimestamp()
                    });
                }
            } catch (e) {
                console.warn('seedDummyDataIfEmpty', e);
            }
        }

        /** Seed posisi default hanya saat koleksi masih kosong — jangan timpa ubah/hapus HRD */
        async function ensureDefaultPositions() {
            try {
                const posSnap = await getDocs(collection(db, COL_POSITIONS));
                if (!posSnap.empty) return;
                const metaSnap = await getDoc(doc(db, COL_META, META_DOC));
                const deleted = Array.isArray(metaSnap.data()?.deletedPositionKeys)
                    ? metaSnap.data().deletedPositionKeys
                    : [];
                for (const name of DEFAULT_POSITIONS) {
                    const n = normalizePosisiName(name);
                    if (!n) continue;
                    const key = vacancyTitleKey(n);
                    if (RETIRED_POSITION_KEYS.has(key) || deleted.includes(key)) continue;
                    await setDoc(doc(db, COL_POSITIONS, positionDocId(n)), {
                        name: n,
                        createdAt: serverTimestamp()
                    });
                }
            } catch (e) {
                console.warn('ensureDefaultPositions', e);
            }
        }

        /** Metadata saja - password admin TIDAK disimpan di Firestore (hindari dibaca user anonim). */
        async function ensureAppMeta() {
            const ref = doc(db, COL_META, META_DOC);
            const snap = await getDoc(ref);
            if (!snap.exists()) {
                await setDoc(ref, {
                    app: 'hrd_sencha',
                    version: 2,
                    createdAt: serverTimestamp()
                });
            }
        }

        /** Pindahkan info utama lama (app_meta.broadcast) ke blog_posts sekali jika blog masih kosong */
        async function migrateBroadcastToBlogOnce() {
            try {
                const blogSnap = await getDocs(collection(db, COL_BLOG));
                if (!blogSnap.empty) return;
                const metaSnap = await getDoc(doc(db, COL_META, META_DOC));
                const b = metaSnap.exists() ? metaSnap.data()?.broadcast : null;
                if (!b || b.active !== true) return;
                const title = String(b.title || '').trim();
                const message = String(b.message || '').trim();
                const photos = Array.isArray(b.photos) ? b.photos.filter(Boolean) : [];
                if (!title && !message && !photos.length) return;
                await addDoc(collection(db, COL_BLOG), {
                    title: title || 'Informasi',
                    body: message,
                    photos,
                    published: true,
                    createdAt: serverTimestamp(),
                    updatedAt: serverTimestamp(),
                    publishedAt: serverTimestamp(),
                    migratedFromBroadcast: true
                });
            } catch (e) {
                console.warn('migrateBroadcastToBlogOnce', e);
            }
        }

        /** Salin riwayat lama applicants/.../visits ke activity_log sekali (satu log aktivitas) */
        async function migrateVisitsToActivityLogOnce() {
            try {
                const metaRef = doc(db, COL_META, META_DOC);
                const metaSnap = await getDoc(metaRef);
                if (metaSnap.exists() && metaSnap.data()?.visitsMigratedToActivityLog) return;

                const applicantsSnap = await getDocs(collection(db, COL_APPLICANTS));
                let count = 0;
                for (const appDoc of applicantsSnap.docs) {
                    const applicantId = appDoc.id;
                    const applicant = appDoc.data();
                    const posisi = getPosisiDisplay(applicant);
                    const visitsSnap = await getDocs(collection(db, COL_APPLICANTS, applicantId, SUB_VISITS));
                    for (const vDoc of visitsSnap.docs) {
                        const v = vDoc.data();
                        const page = String(v.page || 'umum');
                        const type = page === 'daftar' ? 'lamaran_baru' : 'kunjungan';
                        await addDoc(collection(db, COL_ACTIVITY), sanitizeFirestorePayload({
                            type,
                            applicantId,
                            applicantName: applicant.nama || '',
                            posisi,
                            page,
                            source: 'migrasi_visits',
                            at: v.at || serverTimestamp()
                        }));
                        count++;
                    }
                }
                await setDoc(metaRef, {
                    visitsMigratedToActivityLog: true,
                    visitsMigratedCount: count,
                    visitsMigratedAt: serverTimestamp()
                }, { merge: true });
                if (count > 0) {
                    console.info('[activity_log] Migrasi dari visits:', count, 'baris');
                }
            } catch (e) {
                console.warn('migrateVisitsToActivityLogOnce', e);
            }
        }

        function subscribePositions() {
            if (!db) return;
            if (positionsUnsub) positionsUnsub();
            positionsUnsub = onSnapshot(
                collection(db, COL_POSITIONS),
                (snap) => {
                    state.positions = snap.docs.map((d) => ({ id: d.id, ...d.data() }))
                        .sort((a, b) => (a.name || '').localeCompare(b.name || '', 'id'));
                    syncPosisiOptions();
                    if (!$('panel-form')?.classList.contains('view-hidden')) {
                        renderFormPosisiMulti(getFormPosisiList());
                    }
                    const route = parseRoute();
                    if (route.view === 'posisi') renderPosisiPanel();
                    if (route.view === 'undangan') renderUndanganPosisiCheckboxes();
                },
                (err) => console.error('positions snapshot', err)
            );
        }

        /** Pastikan SPV & SERVER ASSISTANT tidak hidup lagi di master/meta */
        async function ensureRetiredPositionsCleanup() {
            try {
                const metaSnap = await getDoc(doc(db, COL_META, META_DOC));
                const deleted = Array.isArray(metaSnap.data()?.deletedPositionKeys)
                    ? metaSnap.data().deletedPositionKeys
                    : [];
                for (const key of RETIRED_POSITION_KEYS) {
                    if (!deleted.includes(key)) {
                        const label = key === 'spv' ? 'SPV' : 'SERVER ASSISTANT';
                        await markPositionDeletedInMeta(label);
                    }
                }
                const posSnap = await getDocs(collection(db, COL_POSITIONS));
                const batch = writeBatch(db);
                let removed = 0;
                posSnap.docs.forEach((d) => {
                    const name = d.data()?.name;
                    if (name && isPositionDeleted(name)) {
                        batch.delete(d.ref);
                        removed++;
                    }
                });
                if (removed) await batch.commit();
            } catch (e) {
                console.warn('ensureRetiredPositionsCleanup', e);
            }
        }

        /** Migrasi sekali jalan — tidak boleh memblokir tampilan utama (bisa lama di DB produksi). */
        async function runBootMigrationsInBackground() {
            try {
                await ensureAppMeta();
                await ensureRetiredPositionsCleanup();
                await ensureDefaultPositions();
                const removedDupes = await dedupePositionMaster();
                if (removedDupes > 0) showToast(`${removedDupes} posisi duplikat dibersihkan`);
                await migrateBroadcastToBlogOnce();
                await migrateVisitsToActivityLogOnce();
                await runActivityLogRetentionMaintenance();
                await seedDummyDataIfEmpty();
            } catch (e) {
                console.warn('runBootMigrationsInBackground', e);
            }
        }

        // --- Firebase boot (getFirestore default, tanpa persistentLocalCache) ---
        async function bootFirebase() {
            let connected = false;
            try {
                const sencha = await window.__SENCHA__.ready();
                db = sencha.db;
                auth = sencha.auth;
                if (!db) throw new Error('Database lokal belum siap');
                setConn('connecting', 'Menghubungkan...');
                await ensureAnonAuth();
                if (!hrdSubsStarted) {
                    hrdSubsStarted = true;
                    subscribePositions();
                    subscribeJobVacancies();
                    subscribeAppMeta();
                    subscribeInterviewPeriods();
                subscribeInterviewSessions();
                }
                runBootMigrationsInBackground();
                await loadApplicantsList({ force: true, silent: true });
                connected = true;
                setConn('connected', 'Terhubung');
            } catch (err) {
                console.error('bootFirebase', err);
                setConn('error', 'Gagal hubung');
                $('boot-loader-text').textContent = err?.message || 'Gagal inisialisasi HRD.';
            } finally {
                hideBootHrd();
                if (connected) state.loaded = true;
            }
        }

        function bindUi() {
            bindMigrationBackupUi();
            window.addEventListener('hashchange', () => {
            if (!getSession() || window.__SENCHA__.role !== 'hrd') return;
            navigate();
        });
            $('form-tgl-lahir')?.addEventListener('change', updateUmurPreview);
            $('form-tgl-lahir')?.addEventListener('input', updateUmurPreview);
            $('form-pelamar')?.addEventListener('submit', savePelamar);
            $('btn-posisi-tambah')?.addEventListener('click', async () => {
                const name = await promptPosisiName('Tambah Posisi Baru');
                if (name) await addPositionMaster(name);
            });
            $('posisi-tbody')?.addEventListener('click', async (e) => {
                const editBtn = e.target.closest('.btn-edit-posisi');
                const delBtn = e.target.closest('.btn-del-posisi');
                if (editBtn) {
                    const id = editBtn.dataset.id;
                    const row = state.positions.find((p) => p.id === id);
                    if (!row) return;
                    const newName = await promptPosisiName('Ubah Nama Posisi', row.name);
                    if (newName) await renamePositionMaster(id, row.name, newName);
                }
                if (delBtn) {
                    const id = delBtn.dataset.id;
                    const row = state.positions.find((p) => p.id === id);
                    if (row) await deletePositionMaster(id, row.name);
                }
            });
            $('btn-pelamar-refresh')?.addEventListener('click', async () => {
                invalidateApplicantsCache();
                const ok = await loadApplicantsList({ force: true });
                if (ok) {
                    renderPelamarTable();
                    const route = parseRoute();
                    if (route.view === 'dashboard') renderDashboard();
                    showToast('Daftar pelamar diperbarui');
                } else {
                    Swal.fire('Gagal', 'Tidak bisa memuat daftar pelamar.', 'error');
                }
            });
            $('filter-search')?.addEventListener('input', () => { resetListPage('pelamar'); state.pelamarCurrentPage = 1; renderPelamarTable(); });
            $('filter-status')?.addEventListener('change', () => { resetListPage('pelamar'); state.pelamarCurrentPage = 1; renderPelamarTable(); });
            $('filter-posisi')?.addEventListener('change', () => { resetListPage('pelamar'); state.pelamarCurrentPage = 1; renderPelamarTable(); });
            $('filter-fase-undangan')?.addEventListener('change', () => { resetListPage('pelamar'); state.pelamarCurrentPage = 1; renderPelamarTable(); });
            $('filter-rsvp-undangan')?.addEventListener('change', () => { resetListPage('pelamar'); state.pelamarCurrentPage = 1; renderPelamarTable(); });
            $('btn-pelamar-load-more')?.addEventListener('click', () => loadMoreListPage('pelamar', renderPelamarTable));
            $('btn-aktivitas-load-more')?.addEventListener('click', () => loadMoreListPage('aktivitas', renderActivityLogList));
            $('btn-chat-load-more')?.addEventListener('click', () => loadMoreListPage('chat', renderChatInbox));
            $('btn-blog-load-more')?.addEventListener('click', () => loadMoreListPage('blog', renderBlogList));
            $('btn-broadcast-load-more')?.addEventListener('click', () => loadMoreListPage('broadcast', renderBroadcastList));
            $('btn-lowongan-load-more')?.addEventListener('click', () => loadMoreListPage('lowongan', renderJobVacancyList));
            bindWawancaraPanelEvents();
            $('hrd-btn-save-undangan-template')?.addEventListener('click', saveUndanganTemplate);
            $('hrd-btn-save-status-reject-template')?.addEventListener('click', saveStatusRejectTemplate);
            $('pelamar-card-list')?.addEventListener('click', async (e) => {
                const undangBtn = e.target.closest('.btn-undang-pelamar');
                if (undangBtn?.dataset?.id) {
                    e.preventDefault();
                    e.stopPropagation();
                    await undangPelamarManual(undangBtn.dataset.id);
                    return;
                }
                if (e.target.closest('.pelamar-card-actions')) return;
                const card = e.target.closest('.pelamar-card');
                if (card?.dataset?.id) location.hash = `#pelamar/${card.dataset.id}`;
            });
            $('pelamar-card-list')?.addEventListener('keydown', (e) => {
                if (e.key !== 'Enter' && e.key !== ' ') return;
                if (e.target.closest('.pelamar-card-actions')) return;
                const card = e.target.closest('.pelamar-card');
                if (card?.dataset?.id) {
                    e.preventDefault();
                    location.hash = `#pelamar/${card.dataset.id}`;
                }
            });
            $('form-blog')?.addEventListener('submit', saveBlogPost);
            $('form-broadcast')?.addEventListener('submit', saveBroadcastPost);
            $('blog-filter')?.addEventListener('change', () => { resetListPage('blog'); renderBlogList(); });
            $('broadcast-filter')?.addEventListener('change', () => { resetListPage('broadcast'); renderBroadcastList(); });
            $('aktivitas-filter')?.addEventListener('change', () => { resetListPage('aktivitas'); renderActivityLogList(); });
            $('chat-inbox-search')?.addEventListener('input', () => { resetListPage('chat'); renderChatInbox(); });
            $('chat-inbox-list')?.addEventListener('click', (e) => {
                const row = e.target.closest('.chat-inbox-row');
                const id = row?.dataset?.chatId;
                if (!id) return;
                location.hash = `#chat/${id}`;
                selectChatHubApplicant(id);
            });
            $('chat-hub-form')?.addEventListener('submit', sendChatHubMessage);
            $('aktivitas-list')?.addEventListener('click', (e) => {
                const btn = e.target.closest('.activity-log-row');
                const aid = btn?.dataset?.applicantId;
                if (aid) location.hash = `#pelamar/${aid}`;
            });
            $('blog-card-list')?.addEventListener('click', async (e) => {
                const openBtn = e.target.closest('.btn-blog-open');
                const t = e.target.closest('.btn-blog-toggle');
                const d = e.target.closest('.btn-blog-del');
                if (openBtn?.dataset?.id) openBlogPreviewModal(openBtn.dataset.id);
                if (t?.dataset?.id) await toggleBlogPublished(t.dataset.id);
                if (d?.dataset?.id) await deleteBlogPost(d.dataset.id);
            });
            $('broadcast-card-list')?.addEventListener('click', async (e) => {
                const openBtn = e.target.closest('.btn-broadcast-open');
                const t = e.target.closest('.btn-broadcast-toggle');
                const d = e.target.closest('.btn-broadcast-del');
                if (openBtn?.dataset?.id) openBroadcastPreviewModal(openBtn.dataset.id);
                if (t?.dataset?.id) await toggleBroadcastPublished(t.dataset.id);
                if (d?.dataset?.id) await deleteBroadcastPost(d.dataset.id);
            });
        }

        async function boot() {
            if (hrdBootInProgress) return;
            hrdBootInProgress = true;
            try {
                if (!hrdUiBound) {
                    hrdUiBound = true;
                    applyLoginHint();
                    syncStatusFilterOptions();
                    bindUi();
                    bindHrdMobileNav();
                    bindCatatanModal();
                    bindBlogPreviewModal();
                    bindBroadcastPreviewModal();
                    bindPhotoSlots();
                    bindBlogPhotoSlots();
                    bindBroadcastPhotoSlots();
                    bindHrdDocUploads();
                    bindBackupImport();
                    bindLowonganForm();
                    $('toggle-fake-activity')?.addEventListener('change', (e) => saveFakeActivitySetting(e.target.checked));
                    $('pdf-preview-close')?.addEventListener('click', closePdfPreview);
                    $('pdf-preview-modal')?.addEventListener('click', (e) => {
                        if (e.target.id === 'hrd-pdf-preview-modal') closePdfPreview();
                    });
                    $('image-preview-close')?.addEventListener('click', closeImagePreview);
                    $('image-preview-modal')?.addEventListener('click', (e) => {
                        if (e.target.id === 'hrd-image-preview-modal') closeImagePreview();
                    });
                    document.addEventListener('keydown', (e) => {
                        if (e.key === 'Escape' && $('image-preview-modal')?.classList.contains('is-open')) closeImagePreview();
                    });
                }
                if (getSession()) location.hash = location.hash || '#dashboard';
                await bootFirebase();
                navigate();
            } finally {
                hrdBootInProgress = false;
            }
        }

        window.__SENCHA__.registerHrd({ boot, verifyLogin, setSession, clearSession, getSession, navigate });
        window.dispatchEvent(new Event('sencha-hrd-registered'));
        window.addEventListener('sencha-show-hrd', () => { boot(); });
    
</script>
</body>
</html>