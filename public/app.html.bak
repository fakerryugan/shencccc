        function getPosisiList(a) {
            if (Array.isArray(a?.posisiList) && a.posisiList.length) return a.posisiList.map(normalizePosisi).filter(Boolean);
            const one = normalizePosisi(a?.posisi);
            return one ? [one] : [];
        }

        function getUndanganByPosisi(a) {
            const raw = a?.undanganByPosisi;
            return raw && typeof raw === 'object' ? raw : {};
        }

        function getUndanganEntry(a, posisiName) {
            const key = normalizePosisi(posisiName);
            if (!key) return null;
            const e = getUndanganByPosisi(a)[key];
            return e && typeof e === 'object' ? e : null;
        }

        function rsvpLabelPelamar(rsvp) {
            if (rsvp === 'hadir') return 'Hadir';
            if (rsvp === 'tidak_hadir') return 'Tidak bisa hadir';
            return 'Menunggu konfirmasi';
        }

        function faseUndanganLabelPelamar(fase) {
            if (fase === 'undangan') return 'Undangan wawancara';
            if (fase === 'undangan_selesai') return 'Undangan selesai';
            return '—';
        }

        function formatDateIdShortPelamar(dateStr) {
            if (!dateStr) return '—';
            try {
                return new Date(dateStr + 'T12:00:00').toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' });
            } catch { return dateStr; }
        }

        function hasPendingUndanganRsvp() {
            const a = state.myApplicant;
            if (!a) return false;
            for (const p of getPosisiList(a)) {
                const e = getUndanganEntry(a, p);
                if (e?.fase === 'undangan' && (!e.rsvp || e.rsvp === 'menunggu')) return true;
            }
            for (const m of state.messages) {
                if (m?.type === 'undangan_wawancara' && m.from === 'hrd') {
                    const r = m.rsvp || 'menunggu';
                    if (r !== 'hadir' && r !== 'tidak_hadir') return true;
                }
            }
            return false;
        }

        function renderUndanganAkunHtml(a) {
            const list = getPosisiList(a);
            if (!list.length) return '';
            const rows = list.map((p) => {
                const e = getUndanganEntry(a, p);
                const fase = e?.fase || '';
                if (!fase) {
                    return `<tr><td class="py-2 font-semibold">${escapeHtml(p)}</td><td class="py-2 text-[#5c5c5c]">—</td><td class="py-2 text-[#5c5c5c]">—</td></tr>`;
                }
                let pill = 'undangan-pill-p';
                if (fase === 'undangan_selesai') pill += ' selesai';
                if (e.rsvp === 'hadir') pill += ' rsvp-hadir';
                if (e.rsvp === 'tidak_hadir') pill += ' rsvp-tidak';
                const jadwal = e.tanggal ? `${formatDateIdShortPelamar(e.tanggal)} · ${escapeHtml(e.jam || '')}` : '—';
                return `<tr><td class="py-2 font-semibold">${escapeHtml(p)}</td>
                    <td class="py-2"><span class="${pill}">${escapeHtml(faseUndanganLabelPelamar(fase))}</span></td>
                    <td class="py-2 text-xs">${fase === 'undangan' ? escapeHtml(rsvpLabelPelamar(e.rsvp || 'menunggu')) + (jadwal !== '—' ? `<br><span class="text-[#7A9168]">${jadwal} · ${escapeHtml(UNDANGAN_LOKASI)}</span>` : '') : jadwal}</td></tr>`;
            }).join('');
            return `<div class="mt-4 rounded-xl border border-[#9CAF88]/40 overflow-hidden">
                <p class="text-xs font-bold uppercase text-[#7A9168] px-3 py-2 bg-[#f5f8f2]">Undangan wawancara per posisi</p>
                <table class="w-full text-sm px-3"><thead><tr class="text-[10px] uppercase text-[#9CAF88] border-b border-[#e8ebe0]">
                    <th class="text-left py-2">Posisi</th><th class="text-left py-2">Fase</th><th class="text-left py-2">Konfirmasi / jadwal</th>
                </tr></thead><tbody>${rows}</tbody></table>
                <p class="text-[10px] text-[#5c5c5c] px-3 py-2">Konfirmasi kehadiran lewat tab <strong>Pesan</strong> jika ada undangan aktif.</p>
            </div>`;
        }

        function setPelamarSwalOpen(open) {
            document.body.classList.toggle('swal-pelamar-open', !!open);
        }

        function pelamarSwal(opts) {
            setPelamarSwalOpen(true);
            const userDidClose = opts?.didClose;
            const userDidDestroy = opts?.didDestroy;
            return Swal.fire({
                ...opts,
                didClose: () => {
                    setPelamarSwalOpen(false);
                    if (typeof userDidClose === 'function') userDidClose();
                },
                didDestroy: () => {
                    setPelamarSwalOpen(false);
                    if (typeof userDidDestroy === 'function') userDidDestroy();
                }
            }).finally(() => setPelamarSwalOpen(false));
        }

        function renderPelamarMessageContent(m) {
            if (m?.type === 'undangan_wawancara') {
                const key = m.inviteKey || normalizePosisi(m.posisi);
                const fromApplicant = state.myApplicant ? getUndanganEntry(state.myApplicant, key)?.rsvp : '';
                const rsvp = (fromApplicant && fromApplicant !== 'menunggu') ? fromApplicant : (m.rsvp || 'menunggu');
                const booking = state.myApplicant?.interviewBooking;
                const rsvpDone = rsvp === 'hadir' || rsvp === 'tidak_hadir';
                const bookingLine = rsvp === 'hadir' && booking
                    ? `<p class="text-[10px] mt-1 text-[#7A9168]">Jadwal: ${formatInterviewDateId(booking.tanggal)} · ${escapeHtml(booking.label || '')} (${formatJamRange(booking.jamMulai, booking.jamSelesai)})</p>`
                    : '';
                const rsvpBlock = !rsvpDone
                    ? `<p class="text-[10px] font-bold mt-2 mb-1 text-[#7A9168]">Konfirmasi kehadiran (wajib):</p>
                       <div class="flex flex-wrap gap-1.5" data-invite-key="${escapeHtml(m.inviteKey || normalizePosisi(m.posisi) || '')}">
                         <button type="button" class="btn-rsvp-undangan px-2.5 py-1 rounded-lg bg-[#2d6a3e] text-white text-[10px] font-bold" data-rsvp="hadir">Saya hadir</button>
                         <button type="button" class="btn-rsvp-undangan px-2.5 py-1 rounded-lg bg-red-600 text-white text-[10px] font-bold" data-rsvp="tidak_hadir">Tidak bisa hadir</button>
                       </div>`
                    : `<p class="text-[10px] font-bold mt-2 text-[#2d6a3e]">o" ${escapeHtml(rsvpLabelPelamar(rsvp))}</p>${bookingLine}`;
                return `<div class="invite-card-pelamar text-left w-full">
                    <p class="font-bold text-[#7A9168] text-[10px] uppercase mb-1">Undangan wawancara · ${escapeHtml(m.posisi || '')}</p>
                    <p class="whitespace-pre-wrap leading-relaxed">${escapeHtml(m.text || '')}</p>${rsvpBlock}</div>`;
            }
            if (m?.type === 'undangan_rsvp') {
                return `<p class="italic text-[#5c5c5c]">${escapeHtml(m.text || '')}</p>`;
            }
            if (m?.type === 'status_notif') {
                return `<div class="rounded-lg border border-[#e8ebe0] bg-white/80 px-2.5 py-2 text-left w-full">
                    <p class="text-[10px] font-bold uppercase text-[#7A9168] mb-1">Informasi status lamaran</p>
                    <p class="whitespace-pre-wrap leading-relaxed">${escapeHtml(m.text || '')}</p>
                </div>`;
            }
            return `<div>${escapeHtml(m.text || '')}</div>`;
        }

        async function submitRsvpUndangan(inviteKey, rsvp) {
            if (!db || !state.session?.applicantId || !inviteKey) return;
            if (state.rsvpSubmitting) return;
            const a = state.myApplicant;
            if (!a) return;
            state.rsvpSubmitting = true;
            const key = normalizePosisi(inviteKey);
            const entry = getUndanganEntry(a, key);
            if (!entry || entry.fase !== 'undangan') {
                pelamarSwal({ icon: 'info', title: 'Tidak aktif', text: 'Undangan untuk posisi ini sudah tidak aktif.' });
                return;
            }
            if (entry.rsvp === 'hadir' || entry.rsvp === 'tidak_hadir') {
                pelamarSwal({ icon: 'info', title: 'Sudah dikonfirmasi', text: 'Anda sudah memilih konfirmasi kehadiran.' });
                return;
            }
            let sessionId = null;
            if (rsvp === 'hadir') {
                state.rsvpSubmitting = false;
                sessionId = await openSlotPickerPopup(key);
                if (!sessionId) return;
                state.rsvpSubmitting = true;
            }
            const label = rsvp === 'hadir' ? 'Saya hadir' : 'Tidak bisa hadir';
            const map = { ...getUndanganByPosisi(a) };
            if (rsvp === 'tidak_hadir') map[key] = { ...entry, rsvp: 'tidak_hadir' };
            const posisiDisplay = key;
            pelamarSwal({
                title: 'Menyimpan konfirmasi…',
                html: `<p class="text-sm">Memproses: <strong>${escapeHtml(label)}</strong></p>`,
                allowOutsideClick: false,
                showConfirmButton: false,
                didOpen: () => Swal.showLoading()
            });
            try {
                if (rsvp === 'hadir') {
                    await bookInterviewSlotPelamar(sessionId, key);
                    map[key] = { ...entry, rsvp: 'hadir' };
                }
                await updateDoc(doc(db, COL_APPLICANTS, state.session.applicantId), {
                    undanganByPosisi: map,
                    updatedAt: serverTimestamp()
                });
                const booking = state.myApplicant?.interviewBooking;
                const jadwalTxt = booking
                    ? ` ${formatInterviewDateId(booking.tanggal)} · ${escapeHtml(booking.label || '')} (${formatJamRange(booking.jamMulai, booking.jamSelesai)})`
                    : '';
                const msgText = rsvp === 'hadir'
                    ? `Konfirmasi kehadiran wawancara (${posisiDisplay}): Saya hadir —${jadwalTxt}`
                    : `Konfirmasi kehadiran wawancara (${posisiDisplay}): Tidak bisa hadir`;
                const rsvpRef = doc(db, COL_APPLICANTS, state.session.applicantId, SUB_MESSAGES, undanganMessageDocId('rsvp', key));
                await setDoc(rsvpRef, {
                    type: 'undangan_rsvp',
                    from: 'pelamar',
                    rsvp,
                    posisi: posisiDisplay,
                    inviteKey: key,
                    text: msgText,
                    createdAt: serverTimestamp()
                }, { merge: true });
                await setDoc(doc(db, COL_APPLICANTS, state.session.applicantId, SUB_MESSAGES, undanganMessageDocId('invite', key)), {
                    rsvp
                }, { merge: true });
                await touchChatThreadPelamar('pelamar', msgText);
                await logActivity({
                    type: rsvp === 'hadir' ? 'undangan_rsvp_hadir' : 'undangan_rsvp_tidak',
                    applicantId: state.session.applicantId,
                    applicantName: a.nama,
                    posisi: posisiDisplay,
                    page: 'pesan',
                    source: 'portal'
                });
                Swal.close();
                setPelamarSwalOpen(false);
                await pelamarSwal({
                    icon: 'success',
                    title: 'Tersimpan',
                    text: `Konfirmasi "${label}" sudah dikirim ke HRD.`,
                    timer: 2400,
                    showConfirmButton: false
                });
            } catch (err) {
                Swal.close();
                setPelamarSwalOpen(false);
                await pelamarSwal({ icon: 'error', title: 'Gagal', text: err.message || 'Tidak bisa menyimpan' });
            } finally {
                state.rsvpSubmitting = false;
            }
        }

        function calcAge(dateStr) {
            if (!dateStr) return null;
            const birth = new Date(dateStr + 'T12:00:00');
            if (isNaN(birth)) return null;
            const t = new Date();
            let age = t.getFullYear() - birth.getFullYear();
            const m = t.getMonth() - birth.getMonth();
            if (m < 0 || (m === 0 && t.getDate() < birth.getDate())) age--;
            return age >= 0 ? age : null;
        }
        function normalizeWhatsapp(raw) {
            let d = String(raw || '').replace(/\D/g, '');
            if (!d) return '';
            if (d.startsWith('0')) d = '62' + d.slice(1);
            if (!d.startsWith('62')) d = '62' + d;
            return d;
        }

        function normalizeNameForLogin(n) {
            return String(n || '').trim().replace(/\s+/g, ' ').toLowerCase();
        }
        function getMasihBekerjaFromForm() {
            const el = document.querySelector('input[name="f-bekerja"]:checked');
            if (!el) return null;
            return el.value === 'ya';
        }
        function getMasihBekerjaFromEditForm() {
            const el = document.querySelector('input[name="ef-bekerja"]:checked');
            if (!el) return null;
            return el.value === 'ya';
        }
        function setMasihBekerjaEditForm(val) {
            const v = val === true || val === 'ya' ? 'ya' : 'tidak';
            const el = document.querySelector(`input[name="ef-bekerja"][value="${v}"]`);
            if (el) el.checked = true;
        }
        function formatMasihBekerjaLabel(v) {
            if (v === true || v === 'ya') return 'Ya';
            if (v === false || v === 'tidak') return 'Tidak';
            return '—';
        }
        function generateAccessToken() {
            const arr = new Uint8Array(16);
            crypto.getRandomValues(arr);
            return Array.from(arr, (b) => b.toString(16).padStart(2, '0')).join('');
        }
        function getSession() {
            try {
                const raw = localStorage.getItem(SESSION_KEY);
                if (!raw) return null;
                const s = JSON.parse(raw);
                if (!s?.applicantId || !s?.accessToken) return null;
                return s;
            } catch { return null; }
        }
        function saveSession(s) {
            clearWalkInSession();
            state.session = s;
            localStorage.setItem(SESSION_KEY, JSON.stringify(s));
        }
        function getWalkInSession() {
            try {
                const raw = localStorage.getItem(WALKIN_SESSION_KEY);
                if (!raw) return null;
                const s = JSON.parse(raw);
                if (!s?.applicantId || !s?.sessionId) return null;
                return s;
            } catch { return null; }
        }
        function saveWalkInSession(s) {
            state.walkInSession = s;
            localStorage.setItem(WALKIN_SESSION_KEY, JSON.stringify(s));
        }
        function clearWalkInSession() {
            state.walkInSession = null;
            localStorage.removeItem(WALKIN_SESSION_KEY);
            unsubscribeInterviewQueuePelamar();
        }
        function isWalkInMode() {
            return !!state.walkInSession && !state.session;
        }
        function getPortalApplicantId() {
            return state.session?.applicantId || state.walkInSession?.applicantId || null;
        }
        function clearSession() {
            state.session = null;
            localStorage.removeItem(SESSION_KEY);
            teardownMySubscriptions();
            state.myApplicant = null;
            state.messages = [];
        }
        function setEverRegistered() {
            localStorage.setItem(EVER_KEY, '1');
        }
        function hasEverRegistered() {
            return localStorage.getItem(EVER_KEY) === '1';
        }
        function maybeResetSimulationGuest() {
            if (new URLSearchParams(location.search).get('baru') !== '1') return;
            localStorage.removeItem(EVER_KEY);
            localStorage.removeItem(SESSION_KEY);
            state.session = null;
        }
        function restoreSessionFromStorage() {
            state.session = getSession();
            state.walkInSession = state.session ? null : getWalkInSession();
        }
        function formatTsId(ts) {
            if (!ts) return '—';
            try {
                const d = ts.toDate ? ts.toDate() : new Date(ts);
                return d.toLocaleString('id-ID', { day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' });
            } catch { return '—'; }
        }
        function messageSortKey(m) {
            const t = m?.createdAt;
            if (t?.toMillis) return t.toMillis();
            if (t?.seconds) return t.seconds * 1000;
            return 0;
        }
        function countUnreadHrdMessagesFallback() {
            if (!state.session?.applicantId || !state.messages?.length) return 0;
            const through = state.pelamarChatReadThroughMs || 0;
            let n = 0;
            for (const m of state.messages) {
                if (m.from === 'hrd' && messageSortKey(m) > through) n++;
            }
            return n;
        }
        function pelamarUnreadCount() {
            const fromThread = Number(state.chatThread?.unreadPelamar) || 0;
            return Math.max(fromThread, countUnreadHrdMessagesFallback());
        }
        function syncPelamarChatReadThrough() {
            let max = state.pelamarChatReadThroughMs || 0;
            for (const m of state.messages) {
                if (m.from === 'hrd') max = Math.max(max, messageSortKey(m));
            }
            state.pelamarChatReadThroughMs = max;
        }

        function updatePelamarChatBadges() {
            const n = pelamarUnreadCount();
            ['header-notif-badge', 'nav-pesan-badge', 'chat-fab-badge'].forEach((id) => {
                const el = $(id);
                if (!el) return;
                el.textContent = n > 9 ? '9+' : String(n);
                el.classList.toggle('hidden', n <= 0);
            });
        }

        async function touchChatThreadPelamar(from, text) {
            if (!db || !state.session?.applicantId) return;
            const a = state.myApplicant;
            const patch = {
                applicantId: state.session.applicantId,
                applicantName: a?.nama || state.session.nama || 'Pelamar',
                posisi: a ? getPosisiList(a).join(', ') : '',
                lastMessage: String(text || '').slice(0, 280),
                lastFrom: from,
                lastMessageAt: serverTimestamp(),
                updatedAt: serverTimestamp()
            };
            if (from === 'pelamar') patch.unreadHrd = increment(1);
            if (from === 'hrd') patch.unreadPelamar = increment(1);
            await setDoc(doc(db, COL_CHAT_THREADS, state.session.applicantId), patch, { merge: true });
        }

        async function markPelamarThreadRead() {
            if (!state.session?.applicantId) return;
            syncPelamarChatReadThrough();
            updatePelamarChatBadges();
            if (!db) return;
            await setDoc(doc(db, COL_CHAT_THREADS, state.session.applicantId), { unreadPelamar: 0 }, { merge: true });
        }

        function subscribeChatThreadPelamar() {
            if (state.chatThreadUnsub) {
                state.chatThreadUnsub();
                state.chatThreadUnsub = null;
            }
            const id = state.session?.applicantId;
            if (!db || !id) return;
            state.chatThreadUnsub = onSnapshot(doc(db, COL_CHAT_THREADS, id), (snap) => {
                state.chatThread = snap.exists() ? snap.data() : null;
                updatePelamarChatBadges();
                renderNotifDrawer();
            }, (err) => console.error('chat_thread', err));
        }

        function renderChatBubblesHtml(msgs, boxId) {
            if (!msgs.length) {
                return '<p class="text-xs text-[#5c5c5c] py-4 text-center">Belum ada pesan. HRD akan menghubungi Anda di sini jika diperlukan.</p>';
            }
            return msgs.map((m) => {
                const fromHrd = m.from === 'hrd';
                const isInvite = m?.type === 'undangan_wawancara';
                const bubbleCls = isInvite && fromHrd
                    ? 'chat-bubble hrd invite-bubble-wide'
                    : `chat-bubble ${fromHrd ? 'hrd' : 'pelamar'}`;
                return `<div class="flex ${fromHrd ? 'justify-start' : 'justify-end'}${isInvite ? ' w-full' : ''}">
                    <div class="${bubbleCls}">
                        ${renderPelamarMessageContent(m)}
                        <p class="chat-meta">${fromHrd ? 'HRD' : 'Anda'} · ${formatTsId(m.createdAt)}</p>
                    </div>
                </div>`;
            }).join('');
        }

        function renderNotifDrawer() {
            const box = $('notif-drawer-body');
            if (!box) return;
            if (!state.session) {
                box.innerHTML = '<p class="text-xs text-[#5c5c5c]">Login dulu.</p>';
                return;
            }
            if (!state.messages.length) {
                box.innerHTML = '<p class="text-xs text-[#5c5c5c] py-4 text-center">Belum ada pesan dari HRD.</p>';
                return;
            }
            const recent = [...state.messages].reverse().slice(0, 12);
            box.innerHTML = recent.map((m) => {
                const fromHrd = m.from === 'hrd';
                return `<div class="rounded-lg p-2.5 ${fromHrd ? 'bg-[#f5f8f2] border border-[#e8ebe0]' : 'bg-[#9CAF88]/15'}">
                    <p class="text-[10px] font-bold text-[#7A9168]">${fromHrd ? 'HRD' : 'Anda'} · ${formatTsId(m.createdAt)}</p>
                    <p class="text-xs mt-0.5">${escapeHtml(m.text || '')}</p>
                </div>`;
            }).join('');
        }

        function openNotifDrawer() {
            markPelamarThreadRead();
            $('notif-backdrop')?.classList.add('is-open');
            $('notif-drawer')?.classList.add('is-open');
            renderNotifDrawer();
        }

        function closeNotifDrawer() {
            $('notif-backdrop')?.classList.remove('is-open');
            $('notif-drawer')?.classList.remove('is-open');
        }

        function isMobileChatViewport() {
            return window.matchMedia('(max-width: 767px)').matches;
        }

        function scrollChatToBottom(el) {
            const box = el || $('chat-thread') || $('chat-float-thread');
            if (!box) return;
            const go = () => { box.scrollTop = box.scrollHeight; };
            go();
            requestAnimationFrame(() => {
                go();
                requestAnimationFrame(go);
            });
        }

        function openChatFloat() {
            markPelamarThreadRead();
            state.chatFloatOpen = true;
            $('chat-float-backdrop')?.classList.add('is-open');
            $('chat-float-panel')?.classList.add('is-open');
            renderChatFloatThread();
        }

        function closeChatFloat() {
            state.chatFloatOpen = false;
            $('chat-float-backdrop')?.classList.remove('is-open');
            $('chat-float-panel')?.classList.remove('is-open');
        }

        /** Mobile: halaman chat penuh. Desktop: popup mengambang. */
        function openPelamarChat() {
            markPelamarThreadRead();
            if (isMobileChatViewport()) {
                closeChatFloat();
                closeNotifDrawer();
                const activeTab = document.querySelector('.nav-tab.active')?.dataset?.tab;
                if (activeTab && activeTab !== 'pesan') state.chatReturnTab = activeTab;
                showTab('pesan');
                renderChatThread();
                scrollChatToBottom($('chat-thread'));
            } else if (state.chatFloatOpen) {
                closeChatFloat();
            } else {
                openChatFloat();
            }
        }

        function renderChatFloatThread() {
            const box = $('chat-float-thread');
            if (!box) return;
            box.innerHTML = renderChatBubblesHtml(state.messages, 'float');
            scrollChatToBottom(box);
        }

        function updateAuthUi() {
            const loggedIn = !!state.session;
            const walkIn = isWalkInMode();
            const portalUser = loggedIn || walkIn;
            $('header-auth-tools')?.classList.toggle('view-hidden', !portalUser);
            $('chat-fab-wrap')?.classList.toggle('view-hidden', !loggedIn);
            $('btn-notif-open')?.classList.toggle('view-hidden', walkIn);
            $('btn-login-open')?.classList.toggle('view-hidden', portalUser);
            $('btn-walkin-open')?.classList.add('view-hidden');
            document.querySelectorAll('.nav-tab-auth').forEach((el) => el.classList.toggle('view-hidden', !loggedIn));
            document.querySelectorAll('.nav-tab-guest').forEach((el) => el.classList.toggle('view-hidden', loggedIn || walkIn));
            document.body.classList.toggle('walk-in-mode', walkIn);
            const greet = $('header-greeting');
            const logoutBtn = $('btn-logout');
            if (walkIn) {
                const n = state.walkInSession?.nama || '';
                const no = state.walkInSession?.queueNo;
                if (greet) greet.textContent = n ? `Antrian #${no || '—'} · ${n.split(' ')[0]}` : 'Antrian walk-in';
                if (logoutBtn) logoutBtn.textContent = 'Selesai';
            } else if (loggedIn) {
                const nama = state.myApplicant?.nama || state.session?.nama || '';
                if (greet) greet.textContent = nama ? `Halo, ${nama.split(' ')[0]}` : 'Akun saya';
                if (logoutBtn) logoutBtn.textContent = 'Logout';
            }
            if (walkIn) {
                if (!document.querySelector('.nav-tab-interview.active')) showTab('interview');
            } else if (loggedIn) {
                const activeAuth = document.querySelector('.nav-tab-auth.active');
                const onInterview = document.querySelector('.nav-tab-interview.active');
                if (!activeAuth && !onInterview) showTab('akun');
            } else if (!document.querySelector('.nav-tab-guest.active') && !document.querySelector('[data-tab="lowongan"].active')) {
                showTab('lowongan');
            }
            updateInterviewUi();
            updateCheckinFloatCta();
            updateCariSubtitle();
            if (!portalUser) renderSearchResults($('search-nama')?.value || '');
        }
        function updateCariSubtitle() {
            const el = $('cari-subtitle');
            if (!el) return;
            el.textContent = 'Ketik awal nama (min. 2 huruf) atau nomor WhatsApp untuk cek status — tidak memuat semua data pelamar. Sudah punya akun? Gunakan Login.';
        }
        function goToLamaranTab() {
            closeLoginModal();
            if (parseInfoRoute().view !== 'preview') showInfoPreview();
            showTab('lamaran');
        }
        function setPelamarLoginBusy(on) {
            const busy = $('pelamar-login-busy');
            const form = $('form-login');
            if (busy) busy.classList.toggle('hidden', !on);
            if (form) {
                form.querySelectorAll('input, button[type="submit"]').forEach((el) => { el.disabled = !!on; });
            }
            $('pelamar-login-close')?.toggleAttribute('disabled', !!on);
        }
        function setCariSearchBusy(on) {
            const busy = $('cari-search-busy');
            if (busy) busy.classList.toggle('hidden', !on);
            if ($('btn-search')) $('btn-search').disabled = !!on;
            if ($('search-nama')) $('search-nama').disabled = !!on;
        }
        async function suggestLamaranAfterLoginFail(title, html) {
            setPelamarLoginBusy(false);
            Swal.close();
            const res = await Swal.fire({
                icon: 'info',
                title,
                html,
                showCancelButton: true,
                confirmButtonText: 'Ke formulir lamaran',
                cancelButtonText: 'Tutup',
                confirmButtonColor: '#9CAF88',
                width: 420
            });
            if (res.isConfirmed) goToLamaranTab();
        }
        function openLoginModal(prefillNama) {
            window.__SENCHA__.openLoginModal('pelamar', prefillNama);
        }
        function closeLoginModal() {
            window.__SENCHA__.closeLoginModal();
        }
        function doLogout() {
            const wasWalkIn = isWalkInMode();
            clearWalkInSession();
            clearSession();
            state.searchPerformed = false;
            const sn = $('search-nama');
            if (sn) sn.value = '';
            updateAuthUi();
            showTab(wasWalkIn ? 'lowongan' : 'cari');
            renderLowonganPanel();
            renderPublicBlogList();
            hideBoot();
            Swal.fire({
                icon: 'info',
                title: wasWalkIn ? 'Selesai' : 'Logout',
                text: wasWalkIn
                    ? 'Sesi antrian walk-in ditutup. Untuk melamar lengkap, gunakan tab Lamaran.'
                    : 'Anda keluar dari akun di perangkat ini.',
                timer: 2500,
                showConfirmButton: false
            });
        }
        function readLoginFormFields() {
            return {
                nama: ($('login-nama')?.value || '').trim(),
                wa: normalizeWhatsapp($('login-wa')?.value || '')
            };
        }
        async function submitLogin(e) {
            e.preventDefault();
            if (!db) return Swal.fire('Belum siap', 'Koneksi Firebase belum aktif.', 'error');
            const { nama, wa } = readLoginFormFields();
            if (!nama || !wa) return Swal.fire('Lengkapi', 'Nama dan WhatsApp wajib.', 'warning');
            setPelamarLoginBusy(true);
            try {
                const idx = await getDoc(doc(db, COL_LOGIN_INDEX, wa));
                if (!idx.exists()) {
                    return suggestLamaranAfterLoginFail(
                        'Belum terdaftar',
                        'Nomor WhatsApp ini belum ada di sistem.<br><br>Pastikan Anda sudah <strong>mengirim lamaran</strong> dengan nama dan nomor yang sama. Jika belum, lanjut ke formulir lamaran.'
                    );
                }
                const d = idx.data();
                if (d.namaNormalized !== normalizeNameForLogin(nama)) {
                    return suggestLamaranAfterLoginFail(
                        'Nama tidak cocok',
                        'Nama tidak sesuai dengan nomor WhatsApp terdaftar.<br><br>Periksa ejaan nama (harus sama seperti saat lamaran), atau kirim lamaran baru jika Anda belum pernah mendaftar.'
                    );
                }
                const appSnap = await getDoc(doc(db, COL_APPLICANTS, d.applicantId));
                if (!appSnap.exists()) {
                    setPelamarLoginBusy(false);
                    return Swal.fire('Data hilang', 'Lamaran tidak ditemukan. Hubungi HRD.', 'error');
                }
                const app = appSnap.data();
                if (app.accessToken && app.accessToken !== d.accessToken) {
                    setPelamarLoginBusy(false);
                    return Swal.fire('Perlu bantuan HRD', 'Akun perlu diverifikasi ulang.', 'warning');
                }
                saveSession({ applicantId: d.applicantId, accessToken: d.accessToken, nama: app.nama || nama });
                setEverRegistered();
                teardownApplicantsSearch();
                state.myApplicant = { id: d.applicantId, ...app };
                subscribeMyApplicant();
                closeLoginModal();
                setPelamarLoginBusy(false);
                updateAuthUi();
                showTab('akun');
                logPortalVisit('login');
                scheduleCheckinUiRefresh();
            } catch (err) {
                setPelamarLoginBusy(false);
                const hint = err?.code === 'permission-denied'
                    ? 'Rules Firestore belum lengkap. Salin file firestore.rules lalu Publish di Firebase Console.'
                    : (err.message || 'Login gagal');
                Swal.fire('Gagal', hint, 'error');
            }
        }
        function teardownMySubscriptions() {
            if (state.myApplicantRefreshTimer) {
                clearInterval(state.myApplicantRefreshTimer);
                state.myApplicantRefreshTimer = null;
            }
            if (state.myApplicantUnsub) { state.myApplicantUnsub(); state.myApplicantUnsub = null; }
            if (state.messagesUnsub) { state.messagesUnsub(); state.messagesUnsub = null; }
            if (state.chatThreadUnsub) { state.chatThreadUnsub(); state.chatThreadUnsub = null; }
            unsubscribeInterviewQueuePelamar();
            state.chatThread = null;
            state.pelamarChatReadThroughMs = 0;
            closeChatFloat();
            closeNotifDrawer();
            updatePelamarChatBadges();
        }
        function applyMyApplicantSnapshot(snap) {
            state.myApplicant = snap.exists() ? { id: snap.id, ...snap.data() } : null;
            updateInterviewUi();
            if (document.querySelector('.nav-tab[data-tab="interview"]')?.classList.contains('active')) {
                renderInterviewPanelPelamar();
            }
            const onAkun = document.querySelector('.nav-tab[data-tab="akun"]')?.classList.contains('active');
            if (onAkun) renderAkunDashboard();
        }
        async function refreshMyApplicant() {
            if (!db || !state.session?.applicantId) return;
            try {
                const snap = await getDoc(doc(db, COL_APPLICANTS, state.session.applicantId));
                applyMyApplicantSnapshot(snap);
            } catch (e) {
                console.error('refreshMyApplicant', e);
            }
        }
        function subscribeMyApplicant() {
            if (!db || !state.session?.applicantId) return;
            teardownMySubscriptions();
            const id = state.session.applicantId;
            void refreshMyApplicant();
            state.myApplicantRefreshTimer = setInterval(() => {
                if (!document.hidden && state.session?.applicantId) void refreshMyApplicant();
            }, 90000);
            state.myApplicantUnsub = onSnapshot(doc(db, COL_APPLICANTS, id), (snap) => {
                applyMyApplicantSnapshot(snap);
            }, (err) => console.error('myApplicant snapshot', err));
            state.messagesUnsub = onSnapshot(collection(db, COL_APPLICANTS, id, SUB_MESSAGES), (snap) => {
                state.messages = snap.docs.map((d) => ({ id: d.id, ...d.data() }))
                    .sort((a, b) => messageSortKey(a) - messageSortKey(b));
                renderChatThread();
                renderChatFloatThread();
                renderNotifDrawer();
                updatePelamarChatBadges();
            }, (err) => {
                console.error('messages', err);
                if (err?.code === 'permission-denied') {
                    Swal.fire('Akses ditolak', 'Publish rules Firestore terbaru (applicant_login_index, messages, visits).', 'error');
                }
            });
            subscribeChatThreadPelamar();
            logPortalVisit('buka');
        }
        async function logPortalVisit(page) {
            if (!db || !state.session?.applicantId) return;
            const key = String(page || 'umum');
            const now = Date.now();
            if (now - (state.lastVisitLog[key] || 0) < VISIT_THROTTLE_MS) return;
            state.lastVisitLog[key] = now;
            const a = state.myApplicant;
            const posisi = a ? getPosisiList(a).join(', ') : '';
            try {
                await logActivity({
                    type: 'kunjungan',
                    applicantId: state.session.applicantId,
                    applicantName: a?.nama || state.session.nama || '',
                    posisi,
                    page: key,
                    source: 'portal'
                });
            } catch (e) { console.warn('logActivity', e); }
        }
        function getKelebihanFromApplicant(a) {
            const list = Array.isArray(a?.catatanList) ? a.catatanList : [];
            const item = list.find((c) => {
                const j = String(c?.judul || '').toLowerCase();
                return j.includes('kelebihan') || j.includes('skill');
            });
            return item?.isi ? String(item.isi).trim() : '';
        }

        function renderAkunDashboard() {
            const box = $('akun-dashboard');
            if (!box) return;
            const a = state.myApplicant;
            if (!a) {
                box.innerHTML = '<p class="text-sm text-[#5c5c5c]">Memuat data akun...</p>';
                return;
            }
            const age = calcAge(a.tanggalLahir);
            const pos = getPosisiList(a).join(', ') || '—';
            const kelebihan = getKelebihanFromApplicant(a);
            const kelebihanPreview = kelebihan
                ? `<div class="mt-3 rounded-lg bg-white/70 border border-[#e8ebe0] px-3 py-2">
                    <p class="text-[10px] font-bold uppercase text-[#7A9168]">Skill / kelebihan yang terkirim</p>
                    <p class="text-xs text-[#5c5c5c] mt-1 whitespace-pre-wrap leading-relaxed">${escapeHtml(kelebihan.length > 320 ? kelebihan.slice(0, 320) + '…' : kelebihan)}</p>
                   </div>`
                : `<p class="text-xs text-[#7A9168] mt-3">Anda belum mengisi deskripsi skill di lamaran. Segera sampaikan ke HRD lewat chat.</p>`;
            box.innerHTML = `
                <div class="flex flex-wrap justify-between gap-2 items-start">
                    <div>
                        <h2 class="font-bold text-xl">${escapeHtml(a.nama)}</h2>
                        <p class="text-sm text-[#5c5c5c] mt-1">${escapeHtml(pos)}</p>
                    </div>
                    <span class="${statusClass(a.status)}">${statusLabel(a.status)}</span>
                </div>
                <dl class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm">
                    <div><dt class="text-[10px] font-bold uppercase text-[#9CAF88]">Tanggal lahir</dt><dd class="font-semibold">${escapeHtml(a.tanggalLahir || '—')}${age != null ? ` (${age} th)` : ''}</dd></div>
                    <div><dt class="text-[10px] font-bold uppercase text-[#9CAF88]">WhatsApp</dt><dd class="font-semibold">${escapeHtml(a.whatsapp || '—')}</dd></div>
                    <div><dt class="text-[10px] font-bold uppercase text-[#9CAF88]">Masih bekerja</dt><dd class="font-semibold">${escapeHtml(formatMasihBekerjaLabel(a.masihBekerja))}</dd></div>
                </dl>
                <div class="p-4 mt-4 rounded-xl border border-[#9CAF88]/40 bg-[#f5f8f2]">
                    <p class="text-xs font-bold text-[#7A9168] uppercase tracking-wide"><i class="fa-solid fa-file-pen mr-1"></i> Perubahan lamaran / CV</p>
                    <p class="text-xs text-[#5c5c5c] mt-2">${escapeHtml(formatCvUpdateInfo(a))}</p>
                    ${kelebihanPreview}
                    <button type="button" id="btn-akun-edit-cv" class="mt-4 px-4 py-2.5 rounded-xl btn-sencha text-xs font-bold shadow-sm w-full sm:w-auto"><i class="fa-solid fa-pen-to-square mr-1"></i> Perbarui lamaran / CV</button>
                </div>
                ${renderAkunInterviewBannerHtml()}
                ${renderUndanganAkunHtml(a)}
                <p class="text-xs text-[#5c5c5c] border-t border-[#e8ebe0] pt-3 mt-4">Status dinilai tim HRD. Pesan HRD lewat tab <strong>Pesan</strong> atau ikon lonceng.</p>`;
            $('btn-akun-edit-cv')?.addEventListener('click', () => showAkunEditMode(true));
            $('btn-akun-ambil-antrian')?.addEventListener('click', () => onCheckinFloatTap());
        }
        function renderAkunInterviewBannerHtml() {
            return '';
        }
        function renderChatThread() {
            const box = $('chat-thread');
            if (!box) return;
            if (!state.session) {
                box.innerHTML = '<p class="text-xs text-[#5c5c5c]">Login untuk melihat pesan.</p>';
                return;
            }
            box.innerHTML = renderChatBubblesHtml(state.messages, 'main');
            if (!$('panel-pesan')?.classList.contains('view-hidden')) {
                scrollChatToBottom(box);
            }
        }
        async function sendPelamarMessage(e) {
            e.preventDefault();
            if (!db || !state.session?.applicantId) return;
            if (hasPendingUndanganRsvp()) {
                pelamarSwal({
                    icon: 'info',
                    title: 'Konfirmasi undangan dulu',
                    text: 'Anda punya undangan wawancara yang belum dikonfirmasi. Pilih Saya hadir atau Tidak bisa hadir di kartu undangan.',
                    confirmButtonColor: '#9CAF88'
                });
                return;
            }
            const text = (($('chat-input')?.value || '') || ($('chat-float-input')?.value || '')).trim();
            if (!text) return;
            try {
                await addDoc(collection(db, COL_APPLICANTS, state.session.applicantId, SUB_MESSAGES), {
                    from: 'pelamar',
                    text,
                    createdAt: serverTimestamp()
                });
                await touchChatThreadPelamar('pelamar', text);
                $('chat-input').value = '';
                if ($('chat-float-input')) $('chat-float-input').value = '';
            } catch (err) {
                Swal.fire('Gagal', err.message || 'Pesan tidak terkirim', 'error');
            }
        }

        function hideBoot() {
            $('boot-loader')?.classList.add('view-hidden');
        }

        // --- Wawancara: booking slot (pelamar) ---
        function getMyInterviewBooking() {
            return state.myApplicant?.interviewBooking || null;
        }

        function sessionHasSlotPelamar(s) {
            if (!s || s.registrationClosed) return false;
            if (s.tanggal < todayYmdLocal()) return false;
            return (s.terdaftar || 0) < (s.kuotaMax || 0);
        }

        function getBookableSessionsForInvite(periodId, posisiKey) {
            const pk = normalizePosisiInterview(posisiKey);
            return state.interviewSessions.filter((s) =>
                s.periodId === periodId &&
                sessionHasSlotPelamar(s) &&
                (s.posisiList || []).some((p) => normalizePosisiInterview(p) === pk)
            ).sort((a, b) => (a.tanggal || '').localeCompare(b.tanggal || '') || (a.slot || '').localeCompare(b.slot || ''));
        }

        function buildSlotPickerDots(terdaftar, kuota) {
            const show = Math.min(kuota || 0, 12);
            let html = '';
            for (let i = 0; i < show; i++) {
                html += `<span class="slot-picker-dot ${i < terdaftar ? 'filled' : 'empty'}"></span>`;
            }
            return html;
        }

        function buildSlotPickerHtml(sessions, posisiLabel) {
            const byDate = {};
            sessions.forEach((s) => {
                if (!byDate[s.tanggal]) byDate[s.tanggal] = [];
                byDate[s.tanggal].push(s);
            });
            const dates = Object.keys(byDate).sort();
            return `<p class="text-xs text-slate-500 mb-3">Pilih satu sesi untuk <strong>${escapeHtml(posisiLabel)}</strong>. Lokasi: ${escapeHtml(UNDANGAN_LOKASI)}</p>
                <div class="slot-picker-grid" id="slot-picker-grid">
                ${dates.map((d) => {
                    const cells = byDate[d].map((s) => {
                        const full = (s.terdaftar || 0) >= (s.kuotaMax || 0);
                        const disabled = full || s.registrationClosed;
                        return `<button type="button" class="slot-picker-cell ${disabled ? 'is-full' : ''}" data-sid="${s.id}" ${disabled ? 'disabled' : ''}>
                            <p class="slot-label">${escapeHtml(s.label || s.slot)}</p>
                            <p class="slot-time">${formatJamRange(s.jamMulai, s.jamSelesai)}</p>
                            <div class="slot-picker-dots">${buildSlotPickerDots(s.terdaftar || 0, s.kuotaMax || 0)}</div>
                            <p class="slot-picker-cap ${full ? 'is-full' : ''}">${full ? 'PENUH' : `${s.terdaftar || 0}/${s.kuotaMax || 0}`}</p>
                        </button>`;
                    }).join('');
                    return `<div><p class="slot-picker-day">${formatInterviewDateId(d)}</p><div class="slot-picker-sessions">${cells}</div></div>`;
                }).join('')}
                </div>`;
        }

        async function openSlotPickerPopup(inviteKey) {
            const key = normalizePosisi(inviteKey);
            const entry = getUndanganEntry(state.myApplicant, key);
            const periodId = entry?.periodId;
            if (!periodId) {
                await pelamarSwal({ icon: 'warning', title: 'Jadwal belum tersedia', text: 'Hubungi HRD lewat chat.' });
                return null;
            }
            const sessions = getBookableSessionsForInvite(periodId, key);
            if (!sessions.length) {
                await pelamarSwal({
                    icon: 'info',
                    title: 'Semua sesi penuh',
                    html: 'Maaf, tidak ada slot tersedia. Silakan hubungi HRD lewat chat untuk penjadwalan manual.'
                });
                return null;
            }
            let selectedId = null;
            const res = await Swal.fire({
                title: 'Pilih jadwal wawancara',
                html: buildSlotPickerHtml(sessions, key),
                customClass: { popup: 'swal-slot-picker' },
                showCancelButton: true,
                confirmButtonText: 'Konfirmasi',
                cancelButtonText: 'Batal',
                confirmButtonColor: '#7c3aed',
                focusConfirm: false,
                didOpen: () => {
                    const grid = document.getElementById('slot-picker-grid');
                    grid?.querySelectorAll('.slot-picker-cell:not(.is-full)').forEach((cell) => {
                        cell.addEventListener('click', () => {
                            grid.querySelectorAll('.slot-picker-cell').forEach((c) => c.classList.remove('is-selected'));
                            cell.classList.add('is-selected');
                            selectedId = cell.dataset.sid || null;
                        });
                    });
                },
                preConfirm: () => {
                    if (!selectedId) {
                        Swal.showValidationMessage('Pilih tanggal dan sesi terlebih dahulu');
                        return false;
                    }
                    return selectedId;
                }
            });
            if (!res.isConfirmed || !res.value) return null;
            return res.value;
        }

        async function bookInterviewSlotPelamar(sessionId, inviteKey) {
            const applicantId = state.session.applicantId;
            const a = state.myApplicant;
            const key = normalizePosisi(inviteKey);
            const sessionRef = doc(db, COL_INTERVIEW_SESSIONS, sessionId);
            const bookingRef = doc(db, COL_INTERVIEW_SESSIONS, sessionId, SUB_BOOKINGS, applicantId);
            const applicantRef = doc(db, COL_APPLICANTS, applicantId);
            await runTransaction(db, async (tx) => {
                const sSnap = await tx.get(sessionRef);
                if (!sSnap.exists()) throw new Error('Sesi tidak ditemukan');
                const s = sSnap.data();
                if (s.registrationClosed) throw new Error('Pendaftaran sesi sudah ditutup');
                if (s.tanggal < todayYmdLocal()) throw new Error('Sesi sudah lewat');
                const max = s.kuotaMax || 0;
                const cur = s.terdaftar || 0;
                if (cur >= max) throw new Error('Kuota sesi sudah penuh');
                const existBook = await tx.get(bookingRef);
                if (existBook.exists()) throw new Error('Sudah terdaftar di sesi ini');
                const appSnap = await tx.get(applicantRef);
                if (appSnap.exists() && appSnap.data()?.interviewBooking?.sessionId) {
                    throw new Error('Anda sudah punya booking di sesi lain');
                }
                tx.update(sessionRef, { terdaftar: cur + 1, updatedAt: serverTimestamp() });
                tx.set(bookingRef, {
                    applicantId,
                    nama: a?.nama || state.session.nama || '',
                    posisi: key,
                    source: 'portal',
                    bookedAt: serverTimestamp()
                });
                tx.update(applicantRef, {
                    interviewBooking: {
                        periodId: s.periodId || '',
                        sessionId,
                        tanggal: s.tanggal,
                        slot: s.slot,
                        label: s.label || s.slot,
                        jamMulai: s.jamMulai,
                        jamSelesai: s.jamSelesai,
                        posisi: key,
                        lokasi: UNDANGAN_LOKASI
                    },
                    updatedAt: serverTimestamp()
                });
            });
            const snap = await getDoc(applicantRef);
            if (snap.exists()) state.myApplicant = { id: applicantId, ...snap.data() };
        }

        function hasActiveUndanganWithPeriod() {
            if (!state.myApplicant) return false;
            const map = getUndanganByPosisi(state.myApplicant);
            return Object.values(map).some((e) => e?.fase === 'undangan' && e?.periodId);
        }

        function subscribeInterviewSessionsPelamar() {
            if (!db) return;
            if (state.interviewSessionsUnsub) state.interviewSessionsUnsub();
            state.interviewSessionsUnsub = onSnapshot(
                collection(db, COL_INTERVIEW_SESSIONS),
                (snap) => {
                    state.interviewSessions = snap.docs.map((d) => ({ id: d.id, ...d.data() }));
                    updateInterviewUi();
                    if (state.session?.applicantId) renderInterviewPanelPelamar();
                },
                (err) => console.error('interview_sessions pelamar', err)
            );
        }

        function renderInterviewPanelPelamar() {
            const summary = $('interview-my-summary');
            if (!summary) return;
            const booking = getMyInterviewBooking();
            if (!booking?.sessionId) {
                if (hasActiveUndanganWithPeriod()) {
                    summary.innerHTML = '<p class="text-sm text-[#5c5c5c]">Anda diundang wawancara. Buka tab <strong>Pesan</strong>, tekan <strong>Saya hadir</strong>, lalu pilih jadwal yang tersedia.</p>';
                } else {
                    summary.innerHTML = '<p class="text-sm text-[#5c5c5c]">Belum ada jadwal wawancara.</p>';
                }
                return;
            }
            summary.innerHTML = `
                <p class="text-[10px] font-bold uppercase text-[#7A9168]">${escapeHtml(booking.label || 'Wawancara')}</p>
                <p class="text-lg font-black text-[#2d6a3e] mt-1">${formatInterviewDateId(booking.tanggal)}</p>
                <p class="text-sm font-semibold mt-1">${formatJamRange(booking.jamMulai, booking.jamSelesai)} · ${escapeHtml(booking.posisi || '')}</p>
                <p class="text-xs text-[#5c5c5c] mt-2"><i class="fa-solid fa-location-dot mr-1"></i>${escapeHtml(booking.lokasi || UNDANGAN_LOKASI)}</p>
                <p class="text-[10px] text-[#7A9168] mt-3">Ubah jadwal? Hubungi HRD lewat chat.</p>`;
        }

        function updateInterviewUi() {
            const hasBooking = !!getMyInterviewBooking()?.sessionId;
            const hasInvite = hasActiveUndanganWithPeriod();
            document.querySelectorAll('.nav-tab-interview').forEach((el) => {
                el.classList.toggle('view-hidden', !hasBooking && !hasInvite);
            });
        }

        function showTab(name) {
            if (isWalkInMode()) {
                if (name !== 'interview' && name !== 'lowongan') name = 'interview';
            }
            if (state.session && (name === 'lamaran' || name === 'cari')) name = 'akun';
            if (!state.session && !isWalkInMode() && (name === 'akun' || name === 'pesan' || name === 'interview')) return;
            if (name !== 'pesan') closeChatFloat();
            document.body.classList.toggle('tab-pesan', name === 'pesan');
            document.querySelectorAll('.nav-tab').forEach((btn) => {
                btn.classList.toggle('active', btn.dataset.tab === name);
            });
            $('panel-lowongan')?.classList.toggle('view-hidden', name !== 'lowongan');
            $('panel-akun')?.classList.toggle('view-hidden', name !== 'akun');
            $('panel-pesan')?.classList.toggle('view-hidden', name !== 'pesan');
            $('panel-cari')?.classList.toggle('view-hidden', name !== 'cari');
            $('panel-lamaran')?.classList.toggle('view-hidden', name !== 'lamaran');
            $('panel-interview')?.classList.toggle('view-hidden', name !== 'interview');
            if (name === 'lowongan') renderLowonganPanel();
            if (name === 'interview') renderInterviewPanelPelamar();
            if (name === 'akun' && state.session) void refreshMyApplicant();
            if (name === 'pesan') markPelamarThreadRead();
            if (name === 'pesan') {
                renderChatThread();
                setTimeout(() => scrollChatToBottom($('chat-thread')), 50);
            }
            if (name === 'akun') {
                showAkunEditMode(false);
                renderAkunDashboard();
            }
            if (name === 'cari' && !state.session) renderSearchResults($('search-nama')?.value || '');
            if (state.session) {
                logPortalVisit(name === 'pesan' ? 'pesan' : 'akun');
            }
            if (isWalkInMode() && name === 'interview') renderInterviewPanelPelamar();
        }

        function blogPublicSortKey(p) {
            const t = p.publishedAt || p.updatedAt;
            if (t?.toMillis) return t.toMillis();
            if (t?.seconds) return t.seconds * 1000;
            return 0;
        }

        function formatBlogDate(ts) {
            if (!ts) return '';
            try {
                const d = ts.toDate ? ts.toDate() : new Date(ts);
                return d.toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' });
            } catch { return ''; }
        }

        function excerpt(text, max = 120) {
            const s = String(text || '').trim();
            if (s.length <= max) return s;
            return s.slice(0, max).trim() + '…';
        }

        function parseInfoRoute() {
            const parts = (location.hash || '').replace(/^#/, '').split('/').filter(Boolean);
            if (parts[0] === 'artikel' && parts[1]) return { view: 'detail', id: parts[1] };
            if (parts[0] === 'informasi') return { view: 'list' };
            return { view: 'preview' };
        }

        function clearInfoHash() {
            if (location.hash) history.replaceState(null, '', location.pathname + location.search);
        }

        function syncInfoFromHash() {
            const route = parseInfoRoute();
            if (route.view === 'detail') {
                const p = state.blogPosts.find((x) => x.id === route.id && x.published === true);
                if (p) showInfoDetail(route.id, { skipHash: true });
                else {
                    showInfoPreview({ skipHash: true });
                    clearInfoHash();
                }
            } else if (route.view === 'list') {
                showInfoListAll({ skipHash: true });
            } else {
                showInfoPreview({ skipHash: true });
            }
        }

        function getPublishedBlogPosts() {
            return state.blogPosts
                .filter((p) => p.published === true && (p.title || p.body))
                .sort((a, b) => blogPublicSortKey(b) - blogPublicSortKey(a));
        }

        function renderBlogThumbHtml(photos) {
            const list = Array.isArray(photos) ? photos.filter(Boolean) : [];
            if (list[0]) {
                return `<div class="blog-card-thumb"><img src="${list[0]}" alt=""></div>`;
            }
            return `<div class="blog-card-thumb flex items-center justify-center text-[#9CAF88]"><i class="fa-solid fa-newspaper text-lg"></i></div>`;
        }

        function renderBlogCardInner(p) {
            return `
                <div class="flex gap-3 p-3">
                    ${renderBlogThumbHtml(p.photos)}
                    <div class="min-w-0 flex-1">
                        <p class="text-[10px] font-bold uppercase text-[#7A9168]">${formatBlogDate(p.publishedAt || p.updatedAt)}</p>
                        <h3 class="font-bold text-sm text-[#1a1a1a] mt-0.5 leading-snug">${escapeHtml(p.title || 'Informasi')}</h3>
                        <p class="blog-card-excerpt text-xs text-[#5c5c5c] mt-1">${escapeHtml(excerpt(p.body, 80))}</p>
                        <span class="inline-block mt-2 text-[10px] font-bold text-[#7A9168]">Baca selengkapnya →</span>
                    </div>
                </div>`;
        }

        function renderBlogCarousel(published) {
            const track = $('blog-carousel-track');
            const prev = $('blog-carousel-prev');
            const next = $('blog-carousel-next');
            const btnAll = $('btn-lihat-semua-informasi');
            if (!track) return;
            track.innerHTML = published.map((p) => `
                <button type="button" class="blog-carousel-card blog-card block text-left rounded-xl border border-[#e8ebe0] bg-white shadow-sm overflow-hidden hover:border-[#9CAF88] transition-colors" data-id="${p.id}">
                    ${renderBlogCardInner(p)}
                </button>
            `).join('');
            const multi = published.length > 1;
            prev?.classList.toggle('view-hidden', !multi);
            next?.classList.toggle('view-hidden', !multi);
            btnAll?.classList.toggle('view-hidden', published.length <= 1);
        }

        function scrollBlogCarousel(dir) {
            const track = $('blog-carousel-track');
            if (!track) return;
            const card = track.querySelector('.blog-carousel-card');
            const step = card ? card.offsetWidth + 12 : 280;
            track.scrollBy({ left: dir * step, behavior: 'smooth' });
        }

        function renderBlogFullList(published) {
            const list = $('blog-public-list');
            if (!list) return;
            list.innerHTML = published.map((p) => `
                <button type="button" class="blog-card w-full text-left rounded-xl border border-[#e8ebe0] bg-white shadow-sm overflow-hidden hover:border-[#9CAF88] transition-colors" data-id="${p.id}">
                    ${renderBlogCardInner(p)}
                </button>
            `).join('');
        }

        function showInfoPreview(opts = {}) {
            state.openBlogId = null;
            $('info-preview-view')?.classList.remove('view-hidden');
            $('info-list-view')?.classList.add('view-hidden');
            $('info-detail-view')?.classList.add('view-hidden');
            $('main')?.classList.remove('view-hidden');
            if (!opts.skipHash) clearInfoHash();
        }

        function showInfoListAll(opts = {}) {
            state.openBlogId = null;
            $('info-preview-view')?.classList.add('view-hidden');
            $('info-list-view')?.classList.remove('view-hidden');
            $('info-detail-view')?.classList.add('view-hidden');
            $('main')?.classList.add('view-hidden');
            renderBlogFullList(getPublishedBlogPosts());
            if (!opts.skipHash) location.hash = '#informasi';
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function showInfoDetail(id, opts = {}) {
            const p = state.blogPosts.find((x) => x.id === id);
            if (!p || p.published !== true) return;
            state.blogBackView = $('info-list-view')?.classList.contains('view-hidden') ? 'preview' : 'list';
            state.openBlogId = id;
            $('info-preview-view')?.classList.add('view-hidden');
            $('info-list-view')?.classList.add('view-hidden');
            $('info-detail-view')?.classList.remove('view-hidden');
            $('main')?.classList.add('view-hidden');
            $('info-detail-title').textContent = p.title || 'Informasi';
            $('info-detail-date').textContent = formatBlogDate(p.publishedAt || p.updatedAt);
            const body = $('info-detail-body');
            if (body) {
                body.textContent = p.body || '';
                body.classList.toggle('view-hidden', !p.body);
            }
            const photos = Array.isArray(p.photos) ? p.photos.filter(Boolean) : [];
            const gallery = $('info-detail-photos');
            if (gallery) {
                if (!photos.length) {
                    gallery.innerHTML = '';
                    gallery.classList.add('view-hidden');
                } else {
                    const cols = photos.length === 1 ? 'grid-cols-1' : photos.length === 2 ? 'grid-cols-2' : 'grid-cols-1 sm:grid-cols-3';
                    gallery.className = `broadcast-gallery grid gap-0.5 bg-[#e8ebe0] ${cols}`;
                    gallery.classList.remove('view-hidden');
                    gallery.innerHTML = photos.map((url) =>
                        `<div class="gallery-cell"><img src="${url}" alt=""></div>`
                    ).join('');
                }
            }
            if (!opts.skipHash) location.hash = `#artikel/${id}`;
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function renderPublicBlogList() {
            const empty = $('blog-public-empty');
            const feed = $('info-feed');
            const published = getPublishedBlogPosts();
            if (!published.length) {
                $('blog-carousel-track').innerHTML = '';
                $('blog-public-list').innerHTML = '';
                empty?.classList.remove('view-hidden');
                feed?.classList.add('view-hidden');
                return;
            }
            feed?.classList.remove('view-hidden');
            empty?.classList.add('view-hidden');
            renderBlogCarousel(published);
            renderBlogFullList(published);
        }

        /** Daftar posisi: lowongan tayang + master positions (tanpa posisi dihapus/retire) */
        function getPositionNamesForUI() {
            const fromVac = (state.jobVacancies || [])
                .filter((v) => v.published !== false)
                .map((v) => normalizePosisi(v.title))
                .filter((n) => n && !isPositionHidden(n));
            const fromDb = state.positions
                .map((p) => normalizePosisi(p.name))
                .filter((n) => n && !isPositionHidden(n));
            const merged = [...new Set([...fromVac, ...fromDb])];
            if (merged.length) return merged.sort((a, b) => a.localeCompare(b, 'id'));
            return DEFAULT_POSITIONS.filter((n) => !isPositionHidden(n));
        }

        function getPublishedVacancies() {
            return (state.jobVacancies || [])
                .filter((v) => v.published !== false && !isPositionHidden(v.title))
                .slice()
                .sort((a, b) => (a.title || '').localeCompare(b.title || '', 'id'));
        }

        function formatCvUpdateInfo(a) {
            let ms = 0;
            const ts = a?.lamaranDiperbaruiAt;
            if (ts?.toMillis) ms = ts.toMillis();
            else if (ts?.seconds) ms = ts.seconds * 1000;
            else if (Array.isArray(a?.cvUpdateLog) && a.cvUpdateLog.length) {
                const last = a.cvUpdateLog[a.cvUpdateLog.length - 1];
                const at = last?.at;
                if (at?.toMillis) ms = at.toMillis();
                else if (typeof at === 'string') ms = Date.parse(at) || 0;
            }
            if (!ms) return 'Belum ada pembaruan CV setelah lamaran terkirim.';
            const d = new Date(ms);
            return `Terakhir diperbarui: ${d.toLocaleString('id-ID', { dateStyle: 'medium', timeStyle: 'short' })} WIB`;
        }

        function renderLowonganPanel() {
            const list = $('lowongan-public-list');
            const empty = $('lowongan-public-empty');
            if (!list) return;
            const items = getPublishedVacancies();
            if (!items.length) {
                list.innerHTML = '';
                empty?.classList.remove('view-hidden');
                return;
            }
            empty?.classList.add('view-hidden');
            list.innerHTML = items.map((v) => {
                const open = v.status !== 'filled';
                const cardCls = open ? 'vacancy-card is-open' : 'vacancy-card is-filled';
                const badge = open
                    ? '<span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-emerald-100 text-emerald-800">Dibuka</span>'
                    : '<span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-red-100 text-red-800">Terisi</span>';
                const sections = (v.sections || []).map((s) => {
                    const body = s.body ? `<p class="text-sm text-[#5c5c5c] mt-1 whitespace-pre-wrap leading-relaxed">${escapeHtml(s.body)}</p>` : '';
                    return `<div class="py-3 border-b border-[#e8ebe0] last:border-0"><p class="font-bold text-sm text-[#1a1a1a]">${escapeHtml(s.title || '')}</p>${body}</div>`;
                }).join('') || '<p class="text-sm text-[#5c5c5c] py-2">Detail akan segera ditambahkan HRD.</p>';
                const btn = open && !state.session
                    ? `<button type="button" class="btn-lamar-posisi mt-3 w-full py-2.5 rounded-xl btn-sencha text-sm font-bold" data-title="${escapeHtml(v.title || '')}">Lamar posisi ini</button>`
                    : (state.session ? '<p class="text-xs text-[#5c5c5c] mt-3">Anda sudah terdaftar — perbarui lamaran di tab <strong>Akun</strong>.</p>' : '');
                return `<details class="vacancy-acc ${cardCls} border-2 rounded-2xl bg-white shadow-sm">
                    <summary class="px-4 py-3 flex flex-wrap gap-2 justify-between items-center">
                        <span class="font-bold text-lg">${escapeHtml(v.title || '—')}</span>
                        ${badge}
                    </summary>
                    <div class="px-4 pb-4">${sections}${btn}</div>
                </details>`;
            }).join('');
            list.querySelectorAll('.btn-lamar-posisi').forEach((btn) => {
                btn.addEventListener('click', () => prefillLamaranPosisi(btn.dataset.title || ''));
            });
        }

        function prefillLamaranPosisi(title) {
            const n = normalizePosisi(title);
            if (!n) return;
            if (state.session) {
                showTab('akun');
                return Swal.fire('Sudah terdaftar', 'Perbarui lamaran Anda di tab Akun → Perbarui CV.', 'info');
            }
            if (parseInfoRoute().view !== 'preview') showInfoPreview();
            showTab('lamaran');
            renderPosisiCheckboxes();
            document.querySelectorAll('#f-posisi-multi .posisi-chk').forEach((el) => {
                if (normalizePosisi(el.value).toLowerCase() === n.toLowerCase()) el.checked = true;
            });
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function getSelectedEditPosisi() {
            return [...document.querySelectorAll('#ef-posisi-multi .posisi-chk-edit:checked')]
                .map((el) => normalizePosisi(el.value)).filter(Boolean);
        }

        function renderEditPosisiCheckboxes() {
            const host = $('ef-posisi-multi');
            if (!host) return;
            const selected = new Set(getSelectedEditPosisi().map((n) => n.toLowerCase()));
            const names = getPositionNamesForUI();
            host.innerHTML = names.map((n) => {
                const on = selected.has(n.toLowerCase()) ? ' checked' : '';
                return `<label class="inline-flex items-center gap-2 px-3 py-2 rounded-xl border border-[#e8ebe0] bg-[#faf9f5] text-sm cursor-pointer">
                    <input type="checkbox" value="${escapeHtml(n)}" class="posisi-chk-edit rounded text-[#7A9168]"${on}>
                    <span>${escapeHtml(n)}</span>
                </label>`;
            }).join('');
            host.querySelectorAll('.posisi-chk-edit').forEach((el) => {
                el.addEventListener('change', () => {
                    const cnt = host.querySelectorAll('.posisi-chk-edit:checked').length;
                    if (cnt > MAX_POSISI_SELECT) {
                        el.checked = false;
                        Swal.fire('Maksimal 2 posisi', 'Pilih maksimal dua posisi.', 'info');
                    }
                    refreshEditSizeHint();
                });
            });
        }

        function showAkunEditMode(open) {
            $('akun-dashboard')?.classList.toggle('view-hidden', !!open);
            $('akun-edit-wrap')?.classList.toggle('view-hidden', !open);
            if (open && state.myApplicant) {
                $('akun-cv-update-info').textContent = formatCvUpdateInfo(state.myApplicant);
                loadEditFormFromApplicant(state.myApplicant);
                renderEditPosisiCheckboxes();
                applyEditCvModeUi();
                refreshEditSizeHint();
            }
        }

        function loadEditFormFromApplicant(a) {
            if (!a) return;
            $('ef-nama').value = a.nama || '';
            $('ef-tgl').value = a.tanggalLahir || '';
            $('ef-wa').value = a.whatsapp || '';
            $('ef-kelebihan').value = getKelebihanFromApplicant(a);
            const age = calcAge(a.tanggalLahir);
            $('ef-umur').textContent = age != null ? String(age) : '—';
            setMasihBekerjaEditForm(a.masihBekerja);
            state.editFormPhotos = Array.isArray(a.photos) && a.photos.length ? [a.photos[0]] : [null];
            state.editFormCvFile = a.cvFile || null;
            state.editFormDocPhotos = [null, null, null, null];
            if (a.cvMode === 'images' && Array.isArray(a.docPhotos)) {
                a.docPhotos.forEach((p, i) => { if (i < MAX_DOC_PHOTOS) state.editFormDocPhotos[i] = p; });
            }
            state.editCvMode = a.cvMode || (state.editFormCvFile ? 'pdf' : (state.editFormDocPhotos.some(Boolean) ? 'images' : null));
            renderEditPhotoSlot(0, state.editFormPhotos[0]);
            for (let i = 0; i < MAX_DOC_PHOTOS; i++) renderEditDocPhotoSlot(i, state.editFormDocPhotos[i]);
            renderEditPdfSlot();
            const pos = getPosisiList(a);
            setTimeout(() => {
                document.querySelectorAll('#ef-posisi-multi .posisi-chk-edit').forEach((el) => {
                    el.checked = pos.some((p) => p.toLowerCase() === normalizePosisi(el.value).toLowerCase());
                });
            }, 0);
        }

        function applyEditCvModeUi() {
            const pdfOn = state.editCvMode === 'pdf';
            const imgOn = state.editCvMode === 'images';
            $('akun-edit-wrap')?.querySelector('[data-edit-cv-pdf]')?.classList.toggle('disabled', imgOn);
            $('akun-edit-wrap')?.querySelectorAll('[data-edit-doc-idx]').forEach((s) => s.classList.toggle('disabled', pdfOn));
        }

        function renderEditPhotoSlot(i, url) {
            const slot = document.querySelector(`#akun-edit-wrap [data-edit-photo-idx="${i}"]`);
            if (!slot) return;
            if (url) {
                slot.innerHTML = `<img src="${url}" alt=""><button type="button" class="absolute top-1 right-1 w-6 h-6 rounded-full bg-red-600 text-white text-xs edit-photo-rm" data-i="${i}">×</button>`;
                slot.classList.add('relative');
                slot.querySelector('.edit-photo-rm')?.addEventListener('click', (e) => {
                    e.stopPropagation();
                    state.editFormPhotos[i] = null;
                    resetEditPhotoSlot(i);
                    refreshEditSizeHint();
                });
            } else resetEditPhotoSlot(i);
        }
        function resetEditPhotoSlot(i) {
            const slot = document.querySelector(`#akun-edit-wrap [data-edit-photo-idx="${i}"]`);
            if (!slot) return;
            slot.classList.remove('relative');
            slot.innerHTML = '<i class="fa-solid fa-camera text-2xl mb-1 text-[#9CAF88]"></i><span class="text-[10px] font-bold">Foto diri</span>';
        }
        function renderEditDocPhotoSlot(i, url) {
            const slot = document.querySelector(`#akun-edit-wrap [data-edit-doc-idx="${i}"]`);
            if (!slot) return;
            if (url) {
                slot.innerHTML = `<img src="${url}" alt=""><button type="button" class="absolute top-1 right-1 w-6 h-6 rounded-full bg-red-600 text-white text-xs edit-doc-rm" data-i="${i}">×</button>`;
                slot.classList.add('relative');
                slot.querySelector('.edit-doc-rm')?.addEventListener('click', (e) => {
                    e.stopPropagation();
                    state.editFormDocPhotos[i] = null;
                    resetEditDocPhotoSlot(i);
                    syncEditCvModeFromForm();
                    refreshEditSizeHint();
                });
            } else resetEditDocPhotoSlot(i);
        }
        function resetEditDocPhotoSlot(i) {
            const slot = document.querySelector(`#akun-edit-wrap [data-edit-doc-idx="${i}"]`);
            if (!slot) return;
            slot.classList.remove('relative');
            slot.innerHTML = `<i class="fa-solid fa-file-image text-xl mb-1 text-[#9CAF88]"></i><span class="text-[10px] font-bold">CV ${i + 1}</span>`;
        }
        function renderEditPdfSlot() {
            const slot = document.querySelector('#akun-edit-wrap [data-edit-cv-pdf]');
            if (!slot) return;
            const label = slot.querySelector('.edit-cv-slot-label');
            const file = state.editFormCvFile;
            if (file) {
                slot.classList.add('has-file');
                label.innerHTML = `${escapeHtml(file.name)} <button type="button" class="edit-cv-rm text-red-600 font-bold text-[10px] ml-1">Hapus</button>`;
                slot.querySelector('.edit-cv-rm')?.addEventListener('click', (e) => {
                    e.stopPropagation();
                    state.editFormCvFile = null;
                    syncEditCvModeFromForm();
                    renderEditPdfSlot();
                    refreshEditSizeHint();
                });
            } else {
                slot.classList.remove('has-file');
                label.textContent = 'Klik untuk unggah PDF';
            }
        }
        function clearEditDocImages() {
            state.editFormDocPhotos = [null, null, null, null];
            for (let i = 0; i < MAX_DOC_PHOTOS; i++) resetEditDocPhotoSlot(i);
        }
        function syncEditCvModeFromForm() {
            if (state.editFormCvFile) state.editCvMode = 'pdf';
            else if (state.editFormDocPhotos.some(Boolean)) state.editCvMode = 'images';
            else state.editCvMode = null;
            applyEditCvModeUi();
        }
        function buildEditDraftPayload() {
            const photos = state.editFormPhotos.filter(Boolean);
            const kelebihan = ($('ef-kelebihan')?.value || '').trim();
            const payload = {
                nama: $('ef-nama')?.value || 'x',
                tanggalLahir: $('ef-tgl')?.value || '2000-01-01',
                whatsapp: '6280000000000',
                masihBekerja: true,
                posisi: 'x',
                posisiList: ['x'],
                photos,
                catatanList: kelebihan ? [{ judul: 'Kelebihan & Skill', isi: kelebihan }] : []
            };
            attachDocFieldsToPayload(payload, state.editCvMode, state.editFormCvFile, state.editFormDocPhotos.filter(Boolean));
            return payload;
        }
        function refreshEditSizeHint() {
            const el = $('edit-size-hint');
            if (!el) return;
            const n = JSON.stringify(buildEditDraftPayload()).length;
            const pct = Math.min(100, Math.round((n / FIRESTORE_PAYLOAD_MAX) * 100));
            el.textContent = `Perkiraan ukuran: ${Math.round(n / 1024)} KB (${pct}% batas)`;
            el.className = n > FIRESTORE_PAYLOAD_MAX * 0.9 ? 'text-xs text-red-600 font-semibold' : 'text-xs text-[#7A9168] font-semibold';
        }

        function bindEditCvUploads() {
            const wrap = $('akun-edit-wrap');
            if (!wrap || wrap.dataset.bound === '1') return;
            wrap.dataset.bound = '1';
            wrap.querySelector('[data-edit-photo-idx="0"]')?.addEventListener('click', () => {
                pickImageFile(async (file) => {
                    try {
                        Swal.fire({ title: 'Mengompres foto...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
                        state.editFormPhotos[0] = await processPhoto(file);
                        Swal.close();
                        renderEditPhotoSlot(0, state.editFormPhotos[0]);
                        refreshEditSizeHint();
                    } catch (err) {
                        Swal.close();
                        Swal.fire('Gagal', imageProcessErrorMessage(err), 'error');
                    }
                });
            });
            wrap.querySelectorAll('[data-edit-doc-idx]').forEach((slot) => {
                slot.addEventListener('click', () => {
                    if (state.editCvMode === 'pdf') return Swal.fire('Mode PDF aktif', 'Hapus PDF dulu.', 'info');
                    const i = parseInt(slot.dataset.editDocIdx, 10);
                    pickImageFile(async (file) => {
                        try {
                            Swal.fire({ title: 'Mengompres gambar...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
                            state.editFormDocPhotos[i] = await processDocPhoto(file);
                            state.editCvMode = 'images';
                            state.editFormCvFile = null;
                            renderEditPdfSlot();
                            Swal.close();
                            renderEditDocPhotoSlot(i, state.editFormDocPhotos[i]);
                            applyEditCvModeUi();
                            refreshEditSizeHint();
                        } catch (err) {
                            Swal.close();
                            Swal.fire('Gagal', imageProcessErrorMessage(err), 'error');
                        }
                    });
                });
            });
            wrap.querySelector('[data-edit-cv-pdf]')?.addEventListener('click', (e) => {
                if (e.target.closest('.edit-cv-rm')) return;
                if (state.editCvMode === 'images') return Swal.fire('Mode foto CV aktif', 'Hapus foto CV dulu.', 'info');
                const input = document.createElement('input');
                input.type = 'file';
                input.accept = '.pdf,application/pdf';
                input.onchange = async () => {
                    const file = input.files?.[0];
                    if (!file) return;
                    if (!isPdfMime(file.type, file.name)) return Swal.fire('Format', 'Hanya PDF.', 'warning');
                    if (file.size > CV_MAX_BYTES) return showUploadFailurePopup('pdf_size');
                    try {
                        Swal.fire({ title: 'Membaca PDF...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
                        const data = await readFileAsDataURL(file);
                        Swal.close();
                        if (data.length * 0.75 > CV_MAX_BYTES) return showUploadFailurePopup('pdf_size');
                        clearEditDocImages();
                        state.editFormCvFile = { name: file.name, mime: file.type || 'application/pdf', data };
                        state.editCvMode = 'pdf';
                        renderEditPdfSlot();
                        applyEditCvModeUi();
                        refreshEditSizeHint();
                    } catch { Swal.close(); Swal.fire('Gagal', 'PDF tidak bisa dibaca.', 'error'); }
                };
                input.click();
            });
        }

        async function submitEditCv(e) {
            e.preventDefault();
            if (!db || !state.session?.applicantId || !state.myApplicant) return;
            const nama = $('ef-nama').value.trim();
            const tanggalLahir = $('ef-tgl').value;
            const whatsapp = normalizeWhatsapp($('ef-wa').value);
            const posisiList = getSelectedEditPosisi();
            const kelebihan = ($('ef-kelebihan').value || '').trim();
            const masihBekerja = getMasihBekerjaFromEditForm();
            const photos = state.editFormPhotos.filter(Boolean);
            if (!nama || !tanggalLahir || !whatsapp || !posisiList.length || masihBekerja === null || !photos.length || !kelebihan) {
                return Swal.fire('Lengkapi data', 'Semua field wajib harus terisi.', 'warning');
            }
            syncEditCvModeFromForm();
            const waNorm = normalizeWhatsapp(whatsapp);
            const oldWa = state.myApplicant.whatsappNormalized || normalizeWhatsapp(state.myApplicant.whatsapp);
            if (waNorm !== oldWa) {
                const idxSnap = await getDoc(doc(db, COL_LOGIN_INDEX, waNorm));
                if (idxSnap.exists() && idxSnap.data()?.applicantId !== state.session.applicantId) {
                    return Swal.fire('WhatsApp dipakai', 'Nomor ini terdaftar pada akun lain.', 'warning');
                }
            }
            const catatanList = [{ judul: 'Kelebihan & Skill', isi: kelebihan }];
            const payload = {
                nama,
                namaNormalized: normalizeNameForLogin(nama),
                whatsapp,
                whatsappNormalized: waNorm,
                tanggalLahir,
                umurSaatInput: calcAge(tanggalLahir),
                masihBekerja,
                posisi: posisiList.join(', '),
                posisiList,
                photos,
                catatanList,
                updatedAt: serverTimestamp(),
                lamaranDiperbaruiAt: serverTimestamp(),
                cvUpdateLog: arrayUnion({ at: new Date().toISOString(), source: 'pelamar' })
            };
            attachDocFieldsToPayload(payload, state.editCvMode, state.editFormCvFile, state.editFormDocPhotos.filter(Boolean));
            if (JSON.stringify(payload).length > FIRESTORE_PAYLOAD_MAX) return showUploadFailurePopup('total_size');
            Swal.fire({ title: 'Menyimpan...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
            try {
                const aid = state.session.applicantId;
                await updateDoc(doc(db, COL_APPLICANTS, aid), payload);
                if (waNorm !== oldWa) {
                    await deleteDoc(doc(db, COL_LOGIN_INDEX, oldWa));
                    await setDoc(doc(db, COL_LOGIN_INDEX, waNorm), {
                        applicantId: aid,
                        accessToken: state.session.accessToken,
                        namaNormalized: normalizeNameForLogin(nama),
                        nama,
                        updatedAt: serverTimestamp()
                    });
                } else {
                    await setDoc(doc(db, COL_LOGIN_INDEX, waNorm), {
                        nama,
                        namaNormalized: normalizeNameForLogin(nama),
                        updatedAt: serverTimestamp()
                    }, { merge: true });
                }
                saveSession({ ...state.session, nama });
                await logActivity({
                    type: 'cv_diperbarui',
                    applicantId: aid,
                    applicantName: nama,
                    posisi: posisiList.join(', '),
                    page: 'akun',
                    source: 'portal'
                });
                Swal.fire({ icon: 'success', title: 'Lamaran diperbarui', text: 'Perubahan CV tersimpan.', confirmButtonColor: '#9CAF88' });
                showAkunEditMode(false);
                await refreshMyApplicant();
                renderAkunDashboard();
            } catch (err) {
                Swal.fire('Gagal', firestoreErrHint(err), 'error');
            }
        }

        async function migrateBroadcastToBlogOnce(db) {
            try {
                const blogSnap = await getDocs(collection(db, COL_BLOG));
                if (!blogSnap.empty) return;
                const metaSnap = await getDoc(doc(db, COL_META, META_DOC));
                const b = metaSnap.exists() ? metaSnap.data()?.broadcast : null;
                if (!b || b.active !== true) return;
                const title = String(b.title || '').trim();
                const message = String(b.message || '').trim();
                const photos = Array.isArray(b.photos) ? b.photos.filter(Boolean) : [];
                if (!title && !message && !photos.length) return;
                await addDoc(collection(db, COL_BLOG), {
                    title: title || 'Informasi',
                    body: message,
                    photos,
                    published: true,
                    createdAt: serverTimestamp(),
                    updatedAt: serverTimestamp(),
                    publishedAt: serverTimestamp(),
                    migratedFromBroadcast: true
                });
            } catch (e) {
                console.warn('migrateBroadcastToBlogOnce', e);
            }
        }

        /** Seed posisi default hanya saat koleksi masih kosong — hormati daftar hapus HRD */
        async function ensureDefaultPositions(db) {
            try {
                const posSnap = await getDocs(collection(db, COL_POSITIONS));
                if (!posSnap.empty) return;
                const metaSnap = await getDoc(doc(db, COL_META, META_DOC));
                const deleted = Array.isArray(metaSnap.data()?.deletedPositionKeys)
                    ? metaSnap.data().deletedPositionKeys
                    : [];
                for (const name of DEFAULT_POSITIONS) {
                    const n = normalizePosisi(name);
                    if (!n || isPositionHidden(n)) continue;
                    const key = posisiNameKey(n);
                    if (deleted.includes(key)) continue;
                    await setDoc(doc(db, COL_POSITIONS, positionDocId(n)), {
                        name: n,
                        createdAt: serverTimestamp()
                    });
                }
            } catch (e) {
                console.warn('ensureDefaultPositions', e);
            }
        }

        function renderPosisiCheckboxes() {
            const host = $('f-posisi-multi');
            const hint = $('f-posisi-hint');
            const submitBtn = document.querySelector('#form-lamaran button[type="submit"]');
            if (!host) return;
            const selected = new Set(getSelectedPosisi().map((n) => n.toLowerCase()));
            const names = getPositionNamesForUI();
            if (!names.length) {
                host.innerHTML = '<p class="text-xs text-amber-700 font-semibold">Lowongan belum tersedia. Hubungi HRD Sencha.</p>';
                if (hint) hint.classList.add('hidden');
                if (submitBtn) submitBtn.disabled = true;
                return;
            }
            if (submitBtn) submitBtn.disabled = false;
            if (hint) hint.classList.remove('hidden');
            host.innerHTML = names.map((n) => {
                const on = selected.has(n.toLowerCase()) ? ' checked' : '';
                return `<label class="inline-flex items-center gap-2 px-3 py-2 rounded-xl border border-[#e8ebe0] bg-[#faf9f5] text-sm cursor-pointer hover:border-[#9CAF88]">
                    <input type="checkbox" value="${escapeHtml(n)}" class="posisi-chk rounded text-[#7A9168] focus:ring-[#9CAF88]"${on}>
                    <span>${escapeHtml(n)}</span>
                </label>`;
            }).join('');
            host.querySelectorAll('.posisi-chk').forEach((el) => {
                el.addEventListener('change', () => {
                    const cnt = host.querySelectorAll('.posisi-chk:checked').length;
                    if (cnt > MAX_POSISI_SELECT) {
                        el.checked = false;
                        Swal.fire('Maksimal 2 posisi', 'Anda hanya dapat memilih dua posisi.', 'info');
                    }
                });
            });
        }

        function getSelectedPosisi() {
            return [...document.querySelectorAll('#f-posisi-multi .posisi-chk:checked')]
                .map((el) => normalizePosisi(el.value)).filter(Boolean);
        }

        function isPdfMime(mime, name) {
            const m = String(mime || '').toLowerCase();
            const n = String(name || '').toLowerCase();
            return m.includes('pdf') || n.endsWith('.pdf');
        }

        function openPdfPreview(dataUrl, title) {
            const modal = $('pdf-preview-modal');
            const frame = $('pdf-preview-frame');
            if (!modal || !frame) return;
            $('pdf-preview-title').textContent = title || 'Pratinjau PDF';
            frame.src = dataUrl;
            modal.classList.add('is-open');
        }

        function closePdfPreview() {
            const modal = $('pdf-preview-modal');
            const frame = $('pdf-preview-frame');
            if (frame) frame.src = 'about:blank';
            modal?.classList.remove('is-open');
        }

        function getTodayYmdWib() {
            return new Intl.DateTimeFormat('en-CA', { timeZone: 'Asia/Jakarta', year: 'numeric', month: '2-digit', day: '2-digit' }).format(new Date());
        }

        function getWibMinutes(d = new Date()) {
            const fmt = new Intl.DateTimeFormat('en-GB', { timeZone: 'Asia/Jakarta', hour: '2-digit', minute: '2-digit', hour12: false });
            const parts = Object.fromEntries(fmt.formatToParts(d).filter((p) => p.type !== 'literal').map((p) => [p.type, p.value]));
            return parseInt(parts.hour, 10) * 60 + parseInt(parts.minute, 10);
        }

        function getBroadcastTimeSlot() {
            const mins = getWibMinutes();
            if (mins >= 1 && mins <= 12 * 60) return 'morning';
            if (mins >= 21 * 60 + 1) return 'evening';
            return null;
        }

        function isBroadcastScheduleActive(b, today) {
            const start = String(b?.scheduleStart || '').trim();
            const end = String(b?.scheduleEnd || '').trim();
            if (!start || !end) return false;
            return today >= start && today <= end;
        }

        function broadcastSortKey(p) {
            const u = p.updatedAt;
            if (u?.toMillis) return u.toMillis();
            if (u?.seconds) return u.seconds * 1000;
            return 0;
        }

        function wasBroadcastSlotShown(slot) {
            const day = getTodayYmdWib();
            try {
                const store = JSON.parse(localStorage.getItem(BROADCAST_SHOWN_KEY) || '{}');
                return !!store[day]?.[slot];
            } catch { return false; }
        }

        function markBroadcastSlotShown(slot, broadcastId) {
            const day = getTodayYmdWib();
            let store = {};
            try { store = JSON.parse(localStorage.getItem(BROADCAST_SHOWN_KEY) || '{}'); } catch { store = {}; }
            store[day] = store[day] || {};
            store[day][slot] = { at: Date.now(), broadcastId: broadcastId || null };
            localStorage.setItem(BROADCAST_SHOWN_KEY, JSON.stringify(store));
        }

        function getEligibleBroadcastsForPopup() {
            const today = getTodayYmdWib();
            return state.broadcastPosts
                .filter((p) => p.published === true && isBroadcastScheduleActive(p, today))
                .sort((a, b) => broadcastSortKey(b) - broadcastSortKey(a));
        }

        function renderBroadcastPopupPhotos(photos) {
            const gallery = $('broadcast-popup-photos');
            if (!gallery) return;
            const list = Array.isArray(photos) ? photos.filter(Boolean) : [];
            if (!list.length) {
                gallery.innerHTML = '';
                gallery.classList.add('view-hidden');
                return;
            }
            const cols = list.length === 1 ? 'grid-cols-1' : list.length === 2 ? 'grid-cols-2' : 'grid-cols-1 sm:grid-cols-3';
            gallery.className = `broadcast-gallery grid gap-0.5 bg-[#e8ebe0] mx-5 rounded-xl overflow-hidden ${cols}`;
            gallery.classList.remove('view-hidden');
            gallery.innerHTML = list.map((url) => `<div class="gallery-cell"><img src="${url}" alt=""></div>`).join('');
        }

        function closeBroadcastPopup() {
            $('broadcast-popup-modal')?.classList.remove('is-open');
            if (state.pendingBroadcastSlot) {
                markBroadcastSlotShown(state.pendingBroadcastSlot, state.pendingBroadcastId || null);
                state.pendingBroadcastSlot = null;
                state.pendingBroadcastId = null;
            }
            scheduleCheckinUiRefresh();
        }

        function openBroadcastPopup(item, slot) {
            if (!item) return;
            state.pendingBroadcastSlot = slot;
            state.pendingBroadcastId = item.id;
            $('broadcast-popup-title').textContent = item.title || 'Pengumuman';
            const body = $('broadcast-popup-body');
            if (body) {
                body.textContent = item.body || '';
                body.classList.toggle('view-hidden', !item.body);
            }
            renderBroadcastPopupPhotos(item.photos);
            $('broadcast-popup-modal')?.classList.add('is-open');
        }

        function clearBroadcastPopupTimer() {
            if (state.broadcastPopupTimer) {
                clearTimeout(state.broadcastPopupTimer);
                state.broadcastPopupTimer = null;
            }
        }

        function scheduleBroadcastPopup() {
            clearBroadcastPopupTimer();
            const slot = getBroadcastTimeSlot();
            if (!slot || wasBroadcastSlotShown(slot)) return;
            const eligible = getEligibleBroadcastsForPopup();
            if (!eligible.length) return;
            const pick = eligible[0];
            const delay = BROADCAST_DELAY_MIN_MS + Math.floor(Math.random() * (BROADCAST_DELAY_MAX_MS - BROADCAST_DELAY_MIN_MS + 1));
            state.broadcastPopupTimer = setTimeout(() => {
                if (document.hidden) return;
                if (wasBroadcastSlotShown(slot)) return;
                if (!getEligibleBroadcastsForPopup().some((x) => x.id === pick.id)) return;
                openBroadcastPopup(pick, slot);
            }, delay);
        }

        async function deleteActivityLogDocsById(docIds) {
            if (!db || !docIds?.length) return;
            for (let i = 0; i < docIds.length; i += ACTIVITY_LOG_DELETE_BATCH) {
                const batch = writeBatch(db);
                docIds.slice(i, i + ACTIVITY_LOG_DELETE_BATCH).forEach((id) => batch.delete(doc(db, COL_ACTIVITY, id)));
                await batch.commit();
            }
        }

        async function pruneActivityLogsForApplicant(applicantId) {
            if (!db || !applicantId) return;
            try {
                const snap = await getDocs(query(
                    collection(db, COL_ACTIVITY),
                    where('applicantId', '==', applicantId),
                    orderBy('at', 'desc'),
                    limit(ACTIVITY_LOG_MAX_PER_APPLICANT + 15)
                ));
                const excess = snap.docs.slice(ACTIVITY_LOG_MAX_PER_APPLICANT).map((d) => d.id);
                await deleteActivityLogDocsById(excess);
            } catch (e) {
                console.warn('pruneActivityLogsForApplicant', e);
            }
        }

        async function pruneActivityLogsGlobal() {
            if (!db) return;
            try {
                let guard = 0;
                while (guard++ < 30) {
                    const countSnap = await getCountFromServer(collection(db, COL_ACTIVITY));
                    const total = countSnap.data().count;
                    if (total <= ACTIVITY_LOG_MAX_GLOBAL) return;
                    const removeCount = Math.min(total - ACTIVITY_LOG_MAX_GLOBAL, ACTIVITY_LOG_DELETE_BATCH);
                    const snap = await getDocs(query(
                        collection(db, COL_ACTIVITY),
                        orderBy('at', 'asc'),
                        limit(removeCount)
                    ));
                    if (snap.empty) return;
                    const batch = writeBatch(db);
                    snap.docs.forEach((d) => batch.delete(d.ref));
                    await batch.commit();
                }
            } catch (e) {
                console.warn('pruneActivityLogsGlobal', e);
            }
        }

        async function runActivityLogRetentionAfterWrite(applicantId) {
            try {
                if (applicantId) await pruneActivityLogsForApplicant(applicantId);
                await pruneActivityLogsGlobal();
            } catch (e) {
                console.warn('runActivityLogRetentionAfterWrite', e);
            }
        }

        async function logActivity({ type, applicantId, applicantName, posisi, page, source }) {
            if (!db) return;
            try {
                await addDoc(collection(db, COL_ACTIVITY), {
                    type: type || 'kunjungan',
                    applicantId: applicantId || null,
                    applicantName: applicantName || '',
                    posisi: posisi || '',
                    page: page || '',
                    source: source || 'portal',
                    at: serverTimestamp()
                });
                void runActivityLogRetentionAfterWrite(applicantId || null);
            } catch (e) {
                console.warn('logActivity', e);
            }
        }

        function pushActivityToast(text, sub) {
            const host = $('activity-toast-host');
            if (!host) return;
            const el = document.createElement('div');
            el.className = 'activity-toast';
            el.innerHTML = `<div>${escapeHtml(text)}</div>${sub ? `<div class="activity-toast-sub">${escapeHtml(sub)}</div>` : ''}`;
            host.appendChild(el);
            while (host.children.length > 3) host.removeChild(host.firstChild);
            setTimeout(() => el.remove(), 7500);
        }

        function buildFakeActivityMessage() {
            const positions = state.positions.map((p) => normalizePosisi(p.name)).filter(Boolean);
            if (!positions.length) return null;
            const posisi = positions[Math.floor(Math.random() * positions.length)];
            const nama = FAKE_ACTIVITY_NAMES[Math.floor(Math.random() * FAKE_ACTIVITY_NAMES.length)];
            const n = 1 + Math.floor(Math.random() * 4);
            const hours = [1, 2, 2, 3, 4, 5][Math.floor(Math.random() * 6)];
            return {
                text: `${nama} dan ${n} orang lain melamar ${posisi}`,
                sub: `sekitar ${hours} jam lalu`
            };
        }

        function startFakeActivityFeed() {
            if (state.activityTimer) clearInterval(state.activityTimer);
            if (!state.fakeActivityEnabled) return;
            const tick = () => {
                if (!state.fakeActivityEnabled || document.hidden) return;
                const msg = buildFakeActivityMessage();
                if (msg) pushActivityToast(msg.text, msg.sub);
            };
            setTimeout(tick, 8000);
            state.activityTimer = setInterval(tick, ACTIVITY_INTERVAL_MS);
        }

        function teardownApplicantsSearch() {
            state.applicants = [];
        }

        /** Cek status: cari lewat applicant_login_index (prefix nama), bukan baca seluruh koleksi pelamar */
        async function searchApplicantsByLoginIndex(queryText) {
            const raw = String(queryText || '').trim();
            const waDigits = raw.replace(/\D/g, '');
            const looksLikeWa = waDigits.length >= 10 && waDigits.length <= 15;

            if (looksLikeWa) {
                const waNorm = normalizeWhatsapp(raw);
                const idxSnap = await getDoc(doc(db, COL_LOGIN_INDEX, waNorm));
                if (!idxSnap.exists()) return [];
                const idx = idxSnap.data();
                const appSnap = await getDoc(doc(db, COL_APPLICANTS, idx.applicantId));
                if (!appSnap.exists()) return [];
                const data = appSnap.data();
                return [{
                    id: appSnap.id,
                    nama: data.nama || idx.nama,
                    status: data.status,
                    posisi: data.posisi,
                    posisiList: data.posisiList
                }];
            }

            const prefix = normalizeNameForLogin(raw);
            if (prefix.length < 2) {
                throw new Error('Ketik minimal 2 huruf awal nama (atau nomor WhatsApp lengkap).');
            }

            const idxSnap = await getDocs(query(
                collection(db, COL_LOGIN_INDEX),
                where('namaNormalized', '>=', prefix),
                where('namaNormalized', '<=', prefix + '\uf8ff'),
                limit(25)
            ));

            const rows = [];
            const seen = new Set();
            for (const d of idxSnap.docs) {
                const idx = d.data();
                const aid = idx.applicantId;
                if (!aid || seen.has(aid)) continue;
                seen.add(aid);
                const appSnap = await getDoc(doc(db, COL_APPLICANTS, aid));
                if (!appSnap.exists()) continue;
                const data = appSnap.data();
                const nama = data.nama || idx.nama || '';
                const norm = normalizeNameForLogin(nama);
                if (!norm.includes(prefix) && !nama.toLowerCase().includes(prefix)) continue;
                rows.push({
                    id: appSnap.id,
                    nama,
                    status: data.status,
                    posisi: data.posisi,
                    posisiList: data.posisiList
                });
            }
            if (!rows.length) {
                const legacySnap = await getDocs(query(
                    collection(db, COL_APPLICANTS),
                    where('namaNormalized', '>=', prefix),
                    where('namaNormalized', '<=', prefix + '\uf8ff'),
                    limit(15)
                ));
                for (const d of legacySnap.docs) {
                    if (seen.has(d.id)) continue;
                    const data = d.data();
                    rows.push({
                        id: d.id,
                        nama: data.nama,
                        status: data.status,
                        posisi: data.posisi,
                        posisiList: data.posisiList
                    });
                }
            }
            return rows;
        }

        async function searchApplicants() {
            state.searchPerformed = true;
            const q = ($('search-nama')?.value || '').trim();
            if (!q) {
                clearSearchResults();
                return;
            }
            setCariSearchBusy(true);
            try {
                state.applicants = await searchApplicantsByLoginIndex(q);
                renderSearchResults(q);
            } catch (e) {
                Swal.fire('Gagal', firestoreErrHint(e), 'error');
                clearSearchResults();
            } finally {
                setCariSearchBusy(false);
            }
        }
        function renderSearchGuestHint(htmlMsg) {
            const box = $('search-results');
            if (!box) return;
            const msg = htmlMsg || 'Belum mengirim lamaran? Buka tab <strong>Lamaran</strong> untuk mendaftar. Sudah mendaftar? Gunakan tombol <strong>Login</strong> di pojok kanan atas.';
            box.innerHTML = `<div class="bg-white rounded-2xl p-5 md:p-6 border border-[#e8ebe0] shadow-sm">
                <p class="text-sm text-[#5c5c5c] leading-relaxed">${msg}</p>
            </div>`;
        }
        function clearSearchResults() {
            const box = $('search-results');
            if (box) box.innerHTML = '';
        }
        function renderSearchResults(query) {
            const box = $('search-results');
            if (!box || state.session) return;
            const q = String(query || '').trim().toLowerCase().replace(/\s+/g, ' ');
            if (!state.searchPerformed || !q) {
                clearSearchResults();
                return;
            }
            const matches = state.applicants.slice(0, 25);
            if (!matches.length) {
                box.innerHTML = `<div class="bg-white rounded-2xl p-5 border border-[#e8ebe0] shadow-sm space-y-3">
                    <p class="text-sm text-[#5c5c5c]">Nama tidak ditemukan. Ketik <strong>awal nama</strong> (min. 2 huruf) atau nomor WhatsApp lengkap. Untuk akun penuh gunakan <strong>Login</strong>.</p>
                    <p class="text-xs text-[#7A9168]">Belum pernah melamar? Isi formulir di tab <strong>Lamaran</strong> terlebih dahulu.</p>
                    <button type="button" class="text-sm font-bold text-[#7A9168] underline" data-open-login>Login sekarang</button>
                    </div>`;
                box.querySelector('[data-open-login]')?.addEventListener('click', () => openLoginModal(q));
                return;
            }
            box.innerHTML = matches.map((a) => {
                const pos = getPosisiList(a).join(', ') || '—';
                return `<div class="bg-white rounded-2xl p-4 md:p-5 border border-[#e8ebe0] shadow-sm">
                    <div class="flex flex-wrap justify-between gap-2 items-start">
                        <h3 class="font-bold text-base">${escapeHtml(a.nama)}</h3>
                        <span class="${statusClass(a.status)}">${statusLabel(a.status)}</span>
                    </div>
                    <p class="text-sm text-[#5c5c5c] mt-1">${escapeHtml(pos)}</p>
                </div>`;
            }).join('');
        }

        // --- File helpers: foto → kompres JPEG base64 (terima ukuran HP apa pun) ---
        function readFileAsDataURL(file) {
            return new Promise((resolve, reject) => {
                const r = new FileReader();
                r.onload = (e) => resolve(e.target.result);
                r.onerror = () => reject(new Error('READ_FAIL'));
                r.readAsDataURL(file);
            });
        }
        function estimateBase64Bytes(dataUrl) {
            const s = String(dataUrl || '');
            const i = s.indexOf(',');
            const b64 = i >= 0 ? s.slice(i + 1) : s;
            return Math.ceil(b64.length * 0.75);
        }
        function isLikelyImageFile(file) {
            if (!file) return false;
            const t = String(file.type || '').toLowerCase();
            if (t.startsWith('image/')) return true;
            return /\.(jpe?g|png|webp|gif|heic|heif|bmp)$/i.test(file.name || '');
        }
        function loadImageFromFile(file, timeoutMs = IMAGE_LOAD_TIMEOUT_MS) {
            if (!isLikelyImageFile(file)) return Promise.reject(new Error('NOT_IMAGE'));
            const url = URL.createObjectURL(file);
            return new Promise((resolve, reject) => {
                const img = new Image();
                const t = setTimeout(() => {
                    URL.revokeObjectURL(url);
                    reject(new Error('TIMEOUT'));
                }, timeoutMs);
                img.onload = () => {
                    clearTimeout(t);
                    URL.revokeObjectURL(url);
                    resolve(img);
                };
                img.onerror = () => {
                    clearTimeout(t);
                    URL.revokeObjectURL(url);
                    reject(new Error('DECODE'));
                };
                img.src = url;
            });
        }
        function canvasToJpegDataUrl(img, maxDim, quality) {
            let w = img.naturalWidth || img.width;
            let h = img.naturalHeight || img.height;
            if (!w || !h) throw new Error('DECODE');
            if (w > h && w > maxDim) {
                h = Math.round(h * maxDim / w);
                w = maxDim;
            } else if (h > maxDim) {
                w = Math.round(w * maxDim / h);
                h = maxDim;
            }
            const c = document.createElement('canvas');
            c.width = w;
            c.height = h;
            const ctx = c.getContext('2d', { alpha: false });
            ctx.fillStyle = '#ffffff';
            ctx.fillRect(0, 0, w, h);
            ctx.drawImage(img, 0, 0, w, h);
            return c.toDataURL('image/jpeg', quality);
        }
        async function prepareImageFileForCompress(file) {
            if (typeof senchaPrepareImageFile === 'function') return senchaPrepareImageFile(file);
            if (typeof senchaNormalizeImageFile === 'function') return senchaNormalizeImageFile(file);
            if (typeof senchaIsHeicOrHeifFile === 'function' && senchaIsHeicOrHeifFile(file)) throw new Error('HEIC_LIB');
            return file;
        }
        async function compressImageFromFile(file, targetBytes, steps) {
            const ready = await prepareImageFileForCompress(file);
            const img = await loadImageFromFile(ready);
            let last = null;
            for (const { maxDim, q } of steps) {
                last = canvasToJpegDataUrl(img, maxDim, q);
                if (estimateBase64Bytes(last) <= targetBytes) return last;
            }
            return last;
        }
        const PHOTO_COMPRESS_STEPS = [
            { maxDim: 2048, q: 0.88 },
            { maxDim: 1600, q: 0.82 },
            { maxDim: 1200, q: 0.76 },
            { maxDim: 1000, q: 0.72 },
            { maxDim: 800, q: 0.65 },
            { maxDim: 640, q: 0.58 },
            { maxDim: 480, q: 0.5 },
            { maxDim: 360, q: 0.42 }
        ];
        const DOC_COMPRESS_STEPS = [
            { maxDim: 1600, q: 0.8 },
            { maxDim: 1200, q: 0.74 },
            { maxDim: 1000, q: 0.68 },
            { maxDim: 800, q: 0.62 },
            { maxDim: 640, q: 0.55 },
            { maxDim: 480, q: 0.48 },
            { maxDim: 360, q: 0.4 }
        ];
        async function processPhoto(file) {
            return compressImageFromFile(file, PHOTO_TARGET_BYTES, PHOTO_COMPRESS_STEPS);
        }
        async function processDocPhoto(file) {
            return compressImageFromFile(file, DOC_PHOTO_TARGET_BYTES, DOC_COMPRESS_STEPS);
        }
        function imageProcessErrorMessage(err) {
            if (typeof senchaImageProcessErrorMessage === 'function') return senchaImageProcessErrorMessage(err);
            return 'Foto tidak bisa diproses. Coba unggah ulang dari galeri (format JPG/PNG).';
        }
        function pickImageFile(onFile) {
            const input = document.createElement('input');
            input.type = 'file';
            input.accept = 'image/jpeg,image/png,image/webp,image/heic,image/heif,image/*';
            input.onchange = async () => {
                const file = input.files?.[0];
                if (!file) return;
                await onFile(file);
            };
            input.click();
        }

        function showUploadFailurePopup(kind) {
            const pdfHtml = 'PDF tidak bisa diunggah (ukuran melebihi batas ~800 KB).<br><br><strong>Solusi:</strong><ul style="text-align:left;margin:8px 0 0 18px"><li>Ambil <strong>screenshot 1 halaman</strong> CV utama, unggah di slot <strong>Foto CV</strong> (hingga 4 halaman).</li><li>Tulis pengalaman &amp; skill lengkap di kolom <strong>Kelebihan / skill</strong>.</li><li>Jangan unggah PDF dan foto CV sekaligus.</li></ul>';
            const totalHtml = 'Total data lamaran terlalu besar (mendekati batas Firestore 1 MB).<br><br><strong>Solusi:</strong><ul style="text-align:left;margin:8px 0 0 18px"><li>Hapus PDF — gunakan foto CV saja, atau sebaliknya.</li><li>Kurangi jumlah / ukuran foto CV.</li><li>Pastikan kolom skill sudah diisi dengan lengkap.</li></ul>';
            Swal.fire({
                icon: 'warning',
                title: kind === 'pdf_size' ? 'PDF terlalu besar' : 'Data terlalu besar',
                html: kind === 'pdf_size' ? pdfHtml : totalHtml,
                confirmButtonColor: '#9CAF88',
                width: 480
            });
        }

        function attachDocFieldsToPayload(payload, cvMode, cvFile, docPhotos) {
            const docs = (docPhotos || []).filter(Boolean);
            if (cvMode === 'pdf' && cvFile) {
                payload.cvMode = 'pdf';
                payload.cvFile = cvFile;
                payload.cvFiles = [cvFile];
                payload.docPhotos = [];
            } else if (cvMode === 'images' && docs.length) {
                payload.cvMode = 'images';
                payload.docPhotos = docs;
                payload.cvFile = null;
                payload.cvFiles = [];
            } else {
                payload.cvMode = null;
                payload.cvFile = null;
                payload.cvFiles = [];
                payload.docPhotos = [];
            }
        }

        function buildDraftPayloadForSize() {
            const photos = state.formPhotos.filter(Boolean);
            const kelebihan = ($('f-kelebihan')?.value || '').trim();
            const payload = {
                nama: $('f-nama')?.value || 'x',
                tanggalLahir: $('f-tgl')?.value || '2000-01-01',
                whatsapp: '6280000000000',
                masihBekerja: true,
                posisi: 'x',
                posisiList: ['x'],
                photos,
                catatanList: kelebihan ? [{ judul: 'Kelebihan & Skill', isi: kelebihan }] : []
            };
            attachDocFieldsToPayload(payload, state.cvMode, state.formCvFile, state.formDocPhotos.filter(Boolean));
            return payload;
        }

        function refreshPayloadSizeHint() {
            const el = $('lamaran-size-hint');
            if (!el) return;
            const n = JSON.stringify(buildDraftPayloadForSize()).length;
            const pct = Math.min(100, Math.round((n / FIRESTORE_PAYLOAD_MAX) * 100));
            el.textContent = `Perkiraan ukuran lamaran: ${Math.round(n / 1024)} KB (${pct}% batas)`;
            el.className = n > FIRESTORE_PAYLOAD_MAX * 0.9 ? 'text-red-600 font-semibold' : 'text-[#7A9168] font-semibold';
        }

        function applyCvModeUi() {
            const pdfSlot = document.querySelector('#form-lamaran [data-cv-pdf]');
            const docSlots = document.querySelectorAll('#form-lamaran .doc-photo-slot');
            const pdfOn = state.cvMode === 'pdf';
            const imgOn = state.cvMode === 'images';
            pdfSlot?.classList.toggle('disabled', imgOn);
            docSlots.forEach((s) => s.classList.toggle('disabled', pdfOn));
        }

        function clearDocImages() {
            state.formDocPhotos = [null, null, null, null];
            for (let i = 0; i < MAX_DOC_PHOTOS; i++) resetDocPhotoSlot(i);
        }

        function syncCvModeFromForm() {
            if (state.formCvFile) state.cvMode = 'pdf';
            else if (state.formDocPhotos.some(Boolean)) state.cvMode = 'images';
            else state.cvMode = null;
            applyCvModeUi();
        }

        function renderPhotoSlot(i, url) {
            const slot = document.querySelector(`#form-lamaran [data-photo-idx="${i}"]`);
            if (!slot) return;
            if (url) {
                slot.innerHTML = `<img src="${url}" alt=""><button type="button" class="absolute top-1 right-1 w-6 h-6 rounded-full bg-red-600 text-white text-xs photo-rm" data-i="${i}">×</button>`;
                slot.classList.add('relative');
                slot.querySelector('.photo-rm')?.addEventListener('click', (e) => {
                    e.stopPropagation();
                    state.formPhotos[i] = null;
                    resetPhotoSlot(i);
                    refreshPayloadSizeHint();
                });
            } else resetPhotoSlot(i);
        }
        function resetPhotoSlot(i) {
            const slot = document.querySelector(`#form-lamaran [data-photo-idx="${i}"]`);
            if (!slot) return;
            slot.classList.remove('relative');
            slot.innerHTML = '<i class="fa-solid fa-camera text-2xl mb-1 text-[#9CAF88]"></i><span class="text-[10px] font-bold">Foto diri *</span>';
        }

        function renderDocPhotoSlot(i, url) {
            const slot = document.querySelector(`#form-lamaran .doc-photo-slot[data-doc-idx="${i}"]`);
            if (!slot) return;
            if (url) {
                slot.innerHTML = `<img src="${url}" alt=""><button type="button" class="absolute top-1 right-1 w-6 h-6 rounded-full bg-red-600 text-white text-xs doc-rm" data-i="${i}">×</button>`;
                slot.classList.add('relative');
                slot.querySelector('.doc-rm')?.addEventListener('click', (e) => {
                    e.stopPropagation();
                    state.formDocPhotos[i] = null;
                    resetDocPhotoSlot(i);
                    syncCvModeFromForm();
                    refreshPayloadSizeHint();
                });
            } else resetDocPhotoSlot(i);
        }
        function resetDocPhotoSlot(i) {
            const slot = document.querySelector(`#form-lamaran .doc-photo-slot[data-doc-idx="${i}"]`);
            if (!slot) return;
            slot.classList.remove('relative');
            slot.innerHTML = `<i class="fa-solid fa-file-image text-xl mb-1 text-[#9CAF88]"></i><span class="text-[10px] font-bold">CV ${i + 1}</span>`;
        }

        function renderPdfSlot() {
            const slot = document.querySelector('#form-lamaran [data-cv-pdf]');
            if (!slot) return;
            const file = state.formCvFile;
            const label = slot.querySelector('.cv-slot-label');
            if (file) {
                slot.classList.add('has-file');
                const previewBtn = isPdfMime(file.mime, file.name)
                    ? ' <button type="button" class="cv-preview-btn text-[10px] font-bold text-[#7A9168] underline ml-1">Lihat PDF</button>'
                    : '';
                label.innerHTML = `${escapeHtml(file.name)} <button type="button" class="cv-rm text-red-600 font-bold text-[10px] ml-1">Hapus</button>${previewBtn}`;
                slot.querySelector('.cv-preview-btn')?.addEventListener('click', (e) => {
                    e.stopPropagation();
                    openPdfPreview(file.data, file.name);
                });
                slot.querySelector('.cv-rm')?.addEventListener('click', (e) => {
                    e.stopPropagation();
                    state.formCvFile = null;
                    syncCvModeFromForm();
                    renderPdfSlot();
                    refreshPayloadSizeHint();
                });
            } else {
                slot.classList.remove('has-file');
                label.textContent = 'Klik untuk unggah PDF';
            }
        }

        function bindPhotos() {
            document.querySelectorAll('#form-lamaran .photo-slot').forEach((slot) => {
                slot.addEventListener('click', () => {
                    const i = parseInt(slot.dataset.photoIdx, 10);
                    pickImageFile(async (file) => {
                        try {
                            Swal.fire({ title: 'Mengompres foto...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
                            state.formPhotos[i] = await processPhoto(file);
                            Swal.close();
                            renderPhotoSlot(i, state.formPhotos[i]);
                            refreshPayloadSizeHint();
                        } catch (err) {
                            Swal.close();
                            Swal.fire('Gagal', imageProcessErrorMessage(err), 'error');
                        }
                    });
                });
            });
        }

        function bindDocPhotos() {
            document.querySelectorAll('#form-lamaran .doc-photo-slot').forEach((slot) => {
                slot.addEventListener('click', () => {
                    if (state.cvMode === 'pdf') {
                        return Swal.fire('Mode PDF aktif', 'Hapus PDF dulu jika ingin mengunggah foto CV.', 'info');
                    }
                    const i = parseInt(slot.dataset.docIdx, 10);
                    pickImageFile(async (file) => {
                        try {
                            Swal.fire({ title: 'Mengompres gambar...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
                            state.formDocPhotos[i] = await processDocPhoto(file);
                            state.cvMode = 'images';
                            state.formCvFile = null;
                            renderPdfSlot();
                            Swal.close();
                            renderDocPhotoSlot(i, state.formDocPhotos[i]);
                            applyCvModeUi();
                            refreshPayloadSizeHint();
                        } catch (err) {
                            Swal.close();
                            Swal.fire('Gagal', imageProcessErrorMessage(err), 'error');
                        }
                    });
                });
            });
        }

        function bindPdfSlot() {
            const slot = document.querySelector('#form-lamaran [data-cv-pdf]');
            if (!slot) return;
                slot.addEventListener('click', (e) => {
                    if (e.target.closest('.cv-rm') || e.target.closest('.cv-preview-btn')) return;
                if (state.cvMode === 'images') {
                    return Swal.fire('Mode foto CV aktif', 'Hapus semua foto CV dulu jika ingin mengunggah PDF.', 'info');
                }
                    const input = document.createElement('input');
                    input.type = 'file';
                input.accept = '.pdf,application/pdf';
                    input.onchange = async () => {
                        const file = input.files?.[0];
                        if (!file) return;
                    if (!isPdfMime(file.type, file.name)) {
                        return Swal.fire('Format', 'Hanya file PDF yang didukung di slot ini. Untuk foto, gunakan slot Foto CV.', 'warning');
                    }
                    if (file.size > CV_MAX_BYTES) return showUploadFailurePopup('pdf_size');
                    try {
                        Swal.fire({ title: 'Membaca PDF...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
                        const data = await readFileAsDataURL(file);
                        Swal.close();
                        if (data.length * 0.75 > CV_MAX_BYTES) return showUploadFailurePopup('pdf_size');
                        clearDocImages();
                        state.formCvFile = { name: file.name, mime: file.type || 'application/pdf', data };
                        state.cvMode = 'pdf';
                        renderPdfSlot();
                        applyCvModeUi();
                        refreshPayloadSizeHint();
                    } catch {
                        Swal.close();
                        Swal.fire('Gagal', 'PDF tidak bisa dibaca.', 'error');
                    }
                    };
                    input.click();
                });
            renderPdfSlot();
        }

        async function submitLamaran(e) {
            e.preventDefault();
            const nama = $('f-nama').value.trim();
            const tanggalLahir = $('f-tgl').value;
            const whatsapp = normalizeWhatsapp($('f-wa').value);
            const posisiList = getSelectedPosisi();
            const kelebihan = ($('f-kelebihan').value || '').trim();
            const masihBekerja = getMasihBekerjaFromForm();
            const photos = state.formPhotos.filter(Boolean);

            if (!nama || !tanggalLahir || !whatsapp || !posisiList.length) {
                return Swal.fire('Lengkapi data', 'Nama, tanggal lahir, WhatsApp, dan posisi wajib.', 'warning');
            }
            if (masihBekerja === null) {
                return Swal.fire('Lengkapi data', 'Pilih apakah Anda masih bekerja (Ya/Tidak).', 'warning');
            }
            if (!photos.length) {
                return Swal.fire('Foto', 'Foto diri (wajib) belum diunggah.', 'warning');
            }
            if (!kelebihan) {
                return Swal.fire('Lengkapi data', 'Kolom kelebihan / skill wajib diisi.', 'warning');
            }
            if (posisiList.length > MAX_POSISI_SELECT) {
                return Swal.fire('Posisi', 'Maksimal 2 posisi.', 'warning');
            }
            syncCvModeFromForm();

            const catatanList = [{ judul: 'Kelebihan & Skill', isi: kelebihan }];

            const waNorm = normalizeWhatsapp(whatsapp);
            const namaNorm = normalizeNameForLogin(nama);
            const idxSnap = await getDoc(doc(db, COL_LOGIN_INDEX, waNorm));
            if (idxSnap.exists()) {
                return Swal.fire('Sudah terdaftar', 'Nomor WhatsApp ini sudah digunakan. Gunakan Login di pojok kanan atas.', 'info');
            }
            const accessToken = generateAccessToken();
            const payload = {
                nama,
                namaNormalized: namaNorm,
                whatsapp,
                whatsappNormalized: waNorm,
                accessToken,
                tanggalLahir,
                umurSaatInput: calcAge(tanggalLahir),
                masihBekerja,
                posisi: posisiList.join(', '),
                posisiList,
                photos,
                catatanList,
                catatan: '',
                status: 'belum_dinilai',
                source: 'public',
                createdAt: serverTimestamp(),
                updatedAt: serverTimestamp()
            };
            attachDocFieldsToPayload(payload, state.cvMode, state.formCvFile, state.formDocPhotos.filter(Boolean));

            if (JSON.stringify(payload).length > FIRESTORE_PAYLOAD_MAX) {
                return showUploadFailurePopup('total_size');
            }

            Swal.fire({ title: 'Mengirim...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
            try {
                const ref = await addDoc(collection(db, COL_APPLICANTS), payload);
                await logActivity({
                    type: 'lamaran_baru',
                    applicantId: ref.id,
                    applicantName: nama,
                    posisi: posisiList.join(', '),
                    page: 'daftar',
                    source: 'portal'
                });
                await setDoc(doc(db, COL_LOGIN_INDEX, waNorm), {
                    applicantId: ref.id,
                    accessToken,
                    namaNormalized: namaNorm,
                    nama,
                    updatedAt: serverTimestamp()
                });
                saveSession({ applicantId: ref.id, accessToken, nama });
                setEverRegistered();
                subscribeMyApplicant();
                Swal.fire({
                    icon: 'success',
                    title: 'Lamaran terkirim',
                    html: 'Akun Anda aktif di perangkat ini. Lihat status di <strong>Akun Saya</strong>.',
                    confirmButtonColor: '#9CAF88'
                });
                e.target.reset();
                state.formPhotos = [null];
                state.formCvFile = null;
                state.formDocPhotos = [null, null, null, null];
                state.cvMode = null;
                resetPhotoSlot(0);
                clearDocImages();
                renderPdfSlot();
                applyCvModeUi();
                refreshPayloadSizeHint();
                teardownApplicantsSearch();
                renderPosisiCheckboxes();
                updateAuthUi();
                showTab('akun');
                logPortalVisit('akun');
            } catch (err) {
                Swal.fire('Gagal', err.message || 'Coba lagi nanti.', 'error');
            }
        }

        let db;
        async function boot() {
            try {
            window.addEventListener('hashchange', () => {
                if (state.blogPosts.length) syncInfoFromHash();
            });
            document.querySelectorAll('.nav-tab').forEach((btn) => {
                btn.addEventListener('click', () => {
                    if (parseInfoRoute().view !== 'preview') showInfoPreview();
                    showTab(btn.dataset.tab);
                });
            });
            $('btn-logout')?.addEventListener('click', doLogout);
            $('btn-login-open')?.addEventListener('click', () => window.__SENCHA__.openLoginModal('pelamar'));
            $('login-cancel')?.addEventListener('click', closeLoginModal);
            window.__SENCHA__.registerPelamarLogin(submitLogin);
            $('form-login')?.addEventListener('submit', submitLogin);
            $('form-chat-reply')?.addEventListener('submit', sendPelamarMessage);
            $('form-chat-float')?.addEventListener('submit', sendPelamarMessage);
            const onRsvpClick = async (e) => {
                const btn = e.target.closest('.btn-rsvp-undangan');
                if (!btn || btn.disabled) return;
                e.preventDefault();
                e.stopPropagation();
                const wrap = btn.closest('[data-invite-key]');
                const key = wrap?.dataset?.inviteKey || '';
                const rsvp = btn.dataset.rsvp || '';
                if (!key || !rsvp) return;
                btn.disabled = true;
                try {
                    await submitRsvpUndangan(key, rsvp);
                } finally {
                    btn.disabled = false;
                }
            };
            $('chat-thread')?.addEventListener('click', onRsvpClick);
            $('chat-float-thread')?.addEventListener('click', onRsvpClick);
            $('btn-notif-open')?.addEventListener('click', openNotifDrawer);
            $('notif-drawer-close')?.addEventListener('click', closeNotifDrawer);
            $('notif-backdrop')?.addEventListener('click', closeNotifDrawer);
            $('btn-notif-drawer-chat')?.addEventListener('click', () => { closeNotifDrawer(); openPelamarChat(); });
            $('chat-fab')?.addEventListener('click', () => {
                if (isMobileChatViewport()) {
                    const onPesan = document.body.classList.contains('tab-pesan');
                    if (onPesan) showTab(state.chatReturnTab || 'akun');
                    else openPelamarChat();
                } else if (state.chatFloatOpen) {
                    closeChatFloat();
                } else {
                    openChatFloat();
                }
            });
            $('btn-chat-back')?.addEventListener('click', () => showTab(state.chatReturnTab || 'akun'));
            $('chat-float-close')?.addEventListener('click', closeChatFloat);
            $('chat-float-backdrop')?.addEventListener('click', closeChatFloat);
            $('login-modal')?.addEventListener('click', (e) => { if (e.target.id === 'login-modal') closeLoginModal(); });
            $('btn-walkin-open')?.addEventListener('click', openWalkinModal);
            $('walkin-cancel')?.addEventListener('click', closeWalkinModal);
            $('walkin-modal')?.addEventListener('click', (e) => { if (e.target.id === 'walkin-modal') closeWalkinModal(); });
            $('form-walkin')?.addEventListener('submit', performWalkInCheckIn);
            $('btn-checkin-lokasi')?.addEventListener('click', () => {
                const ready = getCheckinReadySessions();
                if (!ready.length) return;
                const sel = $('checkin-session-select');
                let sid = sel?.value;
                if (!sid) sid = ready[0]?.id;
                if (sid) performCheckInPelamar(sid);
            });
            $('checkin-float-cta')?.addEventListener('click', () => onCheckinFloatTap());
            $('checkin-float-cta')?.addEventListener('keydown', (e) => {
                if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); onCheckinFloatTap(); }
            });
            $('checkin-popup-later')?.addEventListener('click', () => {
                sessionStorage.setItem('sencha_checkin_dismiss', todayYmdLocal());
                $('checkin-popup-modal')?.classList.remove('is-open');
                updateCheckinFloatCta();
            });
            $('checkin-popup-modal')?.addEventListener('click', (e) => {
                if (e.target.id === 'checkin-popup-modal') {
                    sessionStorage.setItem('sencha_checkin_dismiss', todayYmdLocal());
                    $('checkin-popup-modal')?.classList.remove('is-open');
                    updateCheckinFloatCta();
                }
            });
            $('btn-search')?.addEventListener('click', searchApplicants);
            $('search-nama')?.addEventListener('keydown', (e) => { if (e.key === 'Enter') { e.preventDefault(); searchApplicants(); } });
            $('f-tgl')?.addEventListener('input', () => {
                const a = calcAge($('f-tgl').value);
                $('f-umur').textContent = a != null ? String(a) : '—';
            });
            $('form-lamaran')?.addEventListener('submit', submitLamaran);
            $('form-edit-cv')?.addEventListener('submit', submitEditCv);
            $('btn-akun-edit-batal')?.addEventListener('click', () => showAkunEditMode(false));
            $('ef-tgl')?.addEventListener('input', () => {
                const a = calcAge($('ef-tgl').value);
                $('ef-umur').textContent = a != null ? String(a) : '—';
                refreshEditSizeHint();
            });
            ['ef-nama', 'ef-wa', 'ef-kelebihan'].forEach((id) => {
                $(id)?.addEventListener('input', refreshEditSizeHint);
            });
            bindEditCvUploads();
            $('btn-info-back')?.addEventListener('click', () => {
                if (state.blogBackView === 'list') location.hash = '#informasi';
                else showInfoPreview();
            });
            $('btn-info-list-back')?.addEventListener('click', showInfoPreview);
            $('btn-lihat-semua-informasi')?.addEventListener('click', () => {
                location.hash = '#informasi';
            });
            $('blog-carousel-prev')?.addEventListener('click', () => scrollBlogCarousel(-1));
            $('blog-carousel-next')?.addEventListener('click', () => scrollBlogCarousel(1));
            const onBlogCardClick = (e) => {
                const card = e.target.closest('.blog-card');
                if (card?.dataset?.id) showInfoDetail(card.dataset.id);
            };
            $('blog-carousel-track')?.addEventListener('click', onBlogCardClick);
            $('blog-public-list')?.addEventListener('click', onBlogCardClick);
            bindPhotos();
            bindPdfSlot();
            bindDocPhotos();
            applyCvModeUi();
            refreshPayloadSizeHint();
            ['f-nama', 'f-tgl', 'f-wa', 'f-kelebihan'].forEach((id) => {
                $(id)?.addEventListener('input', refreshPayloadSizeHint);
            });
            $('pdf-preview-close')?.addEventListener('click', closePdfPreview);
            $('pdf-preview-modal')?.addEventListener('click', (e) => {
                if (e.target.id === 'pdf-preview-modal') closePdfPreview();
            });
            $('broadcast-popup-close')?.addEventListener('click', closeBroadcastPopup);
            $('broadcast-popup-ok')?.addEventListener('click', closeBroadcastPopup);
            $('broadcast-popup-modal')?.addEventListener('click', (e) => {
                if (e.target.id === 'broadcast-popup-modal') closeBroadcastPopup();
            });
            document.addEventListener('keydown', (e) => {
                if (e.key === 'Escape' && $('broadcast-popup-modal')?.classList.contains('is-open')) {
                    closeBroadcastPopup();
                }
            });

                const sencha = await window.__SENCHA__.ready();
                db = sencha.db;
                await ensureDefaultPositions(db);
                await migrateBroadcastToBlogOnce(db);
                subscribeInterviewSessionsPelamar();

                onSnapshot(doc(db, COL_META, META_DOC), (snap) => {
                    const data = snap.exists() ? snap.data() : {};
                    const enabled = data?.fakeActivityFeed?.enabled;
                    state.fakeActivityEnabled = enabled !== false;
                    state.deletedPositionKeys = Array.isArray(data?.deletedPositionKeys)
                        ? data.deletedPositionKeys.filter(Boolean)
                        : [];
                    renderPosisiCheckboxes();
                    renderEditPosisiCheckboxes();
                    renderLowonganPanel();
                    startFakeActivityFeed();
                }, (err) => console.error('meta', err));

                onSnapshot(collection(db, COL_POSITIONS), (snap) => {
                    state.positions = snap.docs.map((d) => ({ id: d.id, ...d.data() }))
                        .sort((a, b) => (a.name || '').localeCompare(b.name || '', 'id'));
                    renderPosisiCheckboxes();
                    renderEditPosisiCheckboxes();
                });

                onSnapshot(collection(db, COL_JOB_VACANCIES), (snap) => {
                    state.jobVacancies = snap.docs.map((d) => ({ id: d.id, ...d.data() }));
                    renderLowonganPanel();
                    renderPosisiCheckboxes();
                    renderEditPosisiCheckboxes();
                }, (err) => console.error('job_vacancies', err));

                maybeResetSimulationGuest();
                restoreSessionFromStorage();
                updateAuthUi();
                let initialTab = document.querySelector('.nav-tab.active')?.dataset.tab || (state.session ? 'akun' : 'lowongan');
                if (isWalkInMode()) {
                    subscribeInterviewQueuePelamar(state.walkInSession.sessionId);
                    initialTab = 'interview';
                }
                showTab(initialTab);
                if (state.session) {
                    subscribeMyApplicant();
                    scheduleCheckinUiRefresh();
                }

                onSnapshot(collection(db, COL_BLOG), (snap) => {
                    state.blogPosts = snap.docs.map((d) => ({ id: d.id, ...d.data() }));
                    renderPublicBlogList();
                    syncInfoFromHash();
                });

                onSnapshot(collection(db, COL_BROADCAST), (snap) => {
                    state.broadcastPosts = snap.docs.map((d) => ({ id: d.id, ...d.data() }));
                    scheduleBroadcastPopup();
                }, (err) => console.error('broadcast', err));

                renderLowonganPanel();
                scheduleBroadcastPopup();
                document.addEventListener('visibilitychange', () => {
                    if (!document.hidden && state.session) {
                        logPortalVisit('kunjungan');
                        void refreshMyApplicant();
                    }
                });
            } catch (err) {
                console.error('boot pelamar', err);
                const bt = $('boot-text');
                if (bt) bt.textContent = 'Gagal terhubung. Muat ulang halaman (Ctrl+Shift+R) atau cek koneksi Firebase.';
            } finally {
                hideBoot();
            }
        }

        document.addEventListener('DOMContentLoaded', boot);
    
</script>
<script type="module">


                import {
            collection, doc, onSnapshot, addDoc, updateDoc, deleteDoc,
            serverTimestamp, getDoc, getDocs, setDoc, writeBatch, increment, arrayUnion, arrayRemove,
            runTransaction, deleteField, query, where, limit, orderBy, getCountFromServer, Timestamp,
            signInAnonymously, listLight
        } from '/public/assets/js/sencha-local-db.js';
        const FULL_BACKUP_VERSION = 2;
        const COL_INTERVIEW_SESSIONS = 'interview_sessions';
        const COL_INTERVIEW_PERIODS = 'interview_periods';
        const SUB_BOOKINGS = 'bookings';
        const SUB_INTERVIEW_QUEUE = 'queue';
        const QUEUE_STATUS = { MENUNGGU: 'menunggu', DIPANGGIL: 'dipanggil', SELESAI: 'selesai' };
        function todayYmdLocal() {
            const d = new Date();
            return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
        }
        function interviewSessionDocId(tanggal, slot) { return `${tanggal}_${slot}`; }
        function generateInterviewPin() { return String(1000 + Math.floor(Math.random() * 9000)); }
        function normalizePosisiInterview(name) { return String(name || '').replace(/\s+/g, ' ').trim().toUpperCase(); }
        function getApplicantPosisiList(a) {
            if (Array.isArray(a?.posisiList) && a.posisiList.length) return a.posisiList.map(normalizePosisiInterview).filter(Boolean);
            const one = normalizePosisiInterview(a?.posisi);
            return one ? [one] : [];
        }
        function applicantMatchesSessionPositions(a, sessionPosisiList) {
            const appPos = getApplicantPosisiList(a);
            const sess = (sessionPosisiList || []).map(normalizePosisiInterview);
            if (!sess.length) return false;
            return appPos.some((p) => sess.includes(p));
        }
        function getUndanganMap(a) {
            const raw = a?.undanganByPosisi;
            return raw && typeof raw === 'object' ? raw : {};
        }
        function hasRsvpHadirForSession(a, sessionPosisiList) {
            const sess = new Set((sessionPosisiList || []).map(normalizePosisiInterview));
            const map = getUndanganMap(a);
            for (const [key, entry] of Object.entries(map)) {
                const pk = normalizePosisiInterview(key);
                if (!sess.has(pk)) continue;
                if (entry?.rsvp === 'hadir') return true;
            }
            for (const p of getApplicantPosisiList(a)) {
                if (!sess.has(p)) continue;
                const key = Object.keys(map).find((k) => normalizePosisiInterview(k) === p);
                if (key && map[key]?.rsvp === 'hadir') return true;
            }
            return false;
        }
        function parseTimeToMinutes(hhmm) {
            const s = String(hhmm || '').trim();
            if (!s) return null;
            const parts = s.split(':');
            const h = parseInt(parts[0], 10);
            const m = parseInt(parts[1], 10) || 0;
            return Number.isNaN(h) ? null : h * 60 + m;
        }
        function nowMinutesLocal() { const d = new Date(); return d.getHours() * 60 + d.getMinutes(); }
        function isSessionCheckInOpen(session) {
            if (!session || session.checkInClosed === true || session.tanggal !== todayYmdLocal()) return false;
            const start = parseTimeToMinutes(session.jamMulai);
            const end = parseTimeToMinutes(session.jamSelesai);
            if (start != null && end != null) {
                const now = nowMinutesLocal();
                if (now < start || now >= end) return false;
            }
            return true;
        }
        function isSessionBeforeStart(session) {
            if (!session || session.tanggal !== todayYmdLocal()) return false;
            const start = parseTimeToMinutes(session.jamMulai);
            return start != null && nowMinutesLocal() < start;
        }
        function isSessionEndedBySchedule(session) {
            if (!session) return false;
            if (session.tanggal < todayYmdLocal()) return true;
            if (session.tanggal > todayYmdLocal()) return false;
            const end = parseTimeToMinutes(session.jamSelesai);
            return end != null && nowMinutesLocal() >= end;
        }
        function formatInterviewDateId(tanggal) {
            if (!tanggal) return '—';
            try {
                const [y, m, d] = tanggal.split('-').map(Number);
                return new Date(y, m - 1, d).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' });
            } catch { return tanggal; }
        }
        function formatJamRange(jamMulai, jamSelesai) {
            const a = String(jamMulai || '').trim().slice(0, 5);
            const b = String(jamSelesai || '').trim().slice(0, 5);
            if (a && b) return `${a}—${b}`;
            if (a) return `mulai ${a}`;
            return '';
        }
        function getSessionCheckInStatusText(session) {
            if (!session) return '';
            if (session.checkInClosed === true) return 'Check-in ditutup (manual)';
            if (session.tanggal > todayYmdLocal()) return 'Jadwal mendatang';
            if (session.tanggal < todayYmdLocal()) return 'Sesi lalu';
            if (isSessionBeforeStart(session)) return `Belum jam mulai (${session.jamMulai || ''})`;
            if (isSessionEndedBySchedule(session)) return 'Selesai otomatis (lewat jam akhir)';
            if (isSessionCheckInOpen(session)) return 'Check-in aktif';
            return 'Tidak aktif';
        }
        function formatQueueTime(ts) {
            if (!ts) return '—';
            try {
                const d = ts.toDate ? ts.toDate() : new Date(ts);
                return d.toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' });
            } catch { return '—'; }
        }
        function queueStatusLabel(st) {
            if (st === QUEUE_STATUS.DIPANGGIL) return 'Dipanggil';
            if (st === QUEUE_STATUS.SELESAI) return 'Selesai';
            return 'Menunggu';
        }

