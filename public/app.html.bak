        const $ = (id) => {
            if (id === 'boot-loader' || id === 'boot-loader-text' || id === 'boot-text') {
                if (id === 'boot-loader-text') return document.getElementById('boot-text');
                return document.getElementById(id);
            }
            if (id === 'view-app') return document.getElementById('view-hrd-app');
            if (id.startsWith('hrd-')) return document.getElementById(id);
            return document.getElementById('hrd-' + id);
        };
        const escapeHtml = (s) => String(s ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/"/g, '&quot;');

        function resetListPage(key) {
            if (key && Object.prototype.hasOwnProperty.call(listPageVisible, key)) {
                listPageVisible[key] = LIST_PAGE_SIZE;
                return;
            }
            Object.keys(listPageVisible).forEach((k) => { listPageVisible[k] = LIST_PAGE_SIZE; });
        }

        function sliceForListPage(key, rows) {
            const total = rows.length;
            const limit = Math.min(listPageVisible[key] || LIST_PAGE_SIZE, total);
            return { items: rows.slice(0, limit), total, visible: limit };
        }

        function updateListPaginationUi(prefix, total, visible) {
            const foot = $(`${prefix}-list-footer`);
            const countEl = $(`${prefix}-list-count`);
            const btn = $(`btn-${prefix}-load-more`);
            if (foot) foot.classList.toggle('hidden', total === 0);
            if (countEl) {
                countEl.textContent = total
                    ? `Menampilkan ${visible} dari ${total} data`
                    : '';
            }
            if (btn) btn.classList.toggle('hidden', visible >= total);
        }

        function loadMoreListPage(key, renderFn) {
            listPageVisible[key] = (listPageVisible[key] || LIST_PAGE_SIZE) + LIST_PAGE_SIZE;
            renderFn();
        }

        function normalizeStatus(st) {
            const raw = String(st || 'belum_dinilai').trim();
            return STATUS_LEGACY[raw] || raw;
        }
        function getStatusMeta(st) {
            const id = normalizeStatus(st);
            return STATUS_OPTIONS.find((o) => o.id === id) || STATUS_OPTIONS[0];
        }
        function statusLabel(st) { return getStatusMeta(st).label; }
        function statusClass(st) { return 'status-pill status-' + normalizeStatus(st); }
        function rowStatusClass(st) { return 'row-status-' + normalizeStatus(st); }

        function buildStatusSelectOptions(selected) {
            const sel = normalizeStatus(selected);
            return STATUS_OPTIONS.map((o) =>
                '<option value="' + o.id + '"' + (o.id === sel ? ' selected' : '') + '>' + o.label + '</option>'
            ).join('');
        }
        function syncStatusFilterOptions() {
            const el = $('filter-status');
            if (!el) return;
            const cur = el.value;
            el.innerHTML = '<option value="">Semua penilaian</option>' +
                STATUS_OPTIONS.map((o) => '<option value="' + o.id + '">' + o.label + '</option>').join('');
            if (STATUS_OPTIONS.some((o) => o.id === cur) || cur === '') el.value = cur;
        }
        function renderStatusLegend() {
            const el = $('status-legend');
            if (!el) return;
