        } from '/public/assets/js/sencha-local-db.js';
        const COL_INTERVIEW_SESSIONS = 'interview_sessions';
        const SUB_BOOKINGS = 'bookings';
        const SUB_INTERVIEW_QUEUE = 'queue';
        const QUEUE_STATUS = { MENUNGGU: 'menunggu', DIPANGGIL: 'dipanggil', SELESAI: 'selesai' };
        function todayYmdLocal() {
            const d = new Date();
            return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
        }
        function firestoreErrHint(err) {
            const m = String(err?.message || err || '');
            if (/quota exceeded|resource.exhausted|resource-exhausted/i.test(m)) {
                return 'Kuota Firebase (Firestore) hari ini sudah habis. Tutup tab HRD yang terbuka, tunggu reset harian (biasanya tengah malam Waktu Pasifik), atau upgrade paket Blaze di Firebase Console. Coba lagi besok jika masih gagal.';
            }
            return m || 'Operasi gagal';
        }
        function normalizePosisiInterview(name) { return String(name || '').replace(/\s+/g, ' ').trim().toUpperCase(); }
        function getApplicantPosisiList(a) {
            if (Array.isArray(a?.posisiList) && a.posisiList.length) return a.posisiList.map(normalizePosisiInterview).filter(Boolean);
            const one = normalizePosisiInterview(a?.posisi);
            return one ? [one] : [];
        }
        function applicantMatchesSessionPositions(a, sessionPosisiList) {
            const appPos = getApplicantPosisiList(a);
            const sess = (sessionPosisiList || []).map(normalizePosisiInterview).filter(Boolean);
            if (!sess.length) return true;
            if (!appPos.length) return false;
            return appPos.some((p) => sess.includes(p));
        }
        function getUndanganMap(a) {
            const raw = a?.undanganByPosisi;
            return raw && typeof raw === 'object' ? raw : {};
        }
        function hasRsvpHadirForSession(a, sessionPosisiList) {
            const sess = new Set((sessionPosisiList || []).map(normalizePosisiInterview));
            const map = getUndanganMap(a);
            for (const [key, entry] of Object.entries(map)) {
                if (sess.has(normalizePosisiInterview(key)) && entry?.rsvp === 'hadir') return true;
            }
            for (const p of getApplicantPosisiList(a)) {
                if (!sess.has(p)) continue;
                const key = Object.keys(map).find((k) => normalizePosisiInterview(k) === p);
                if (key && map[key]?.rsvp === 'hadir') return true;
            }
            return false;
        }
        function parseTimeToMinutes(hhmm) {
            const s = String(hhmm || '').trim();
            if (!s) return null;
            const parts = s.split(':');
            const h = parseInt(parts[0], 10);
            const m = parseInt(parts[1], 10) || 0;
            return Number.isNaN(h) ? null : h * 60 + m;
        }
        function nowMinutesLocal() { const d = new Date(); return d.getHours() * 60 + d.getMinutes(); }
        function isSessionCheckInOpen(session) {
            if (!session || session.checkInClosed === true || session.tanggal !== todayYmdLocal()) return false;
            const start = parseTimeToMinutes(session.jamMulai);
            const end = parseTimeToMinutes(session.jamSelesai);
            if (start != null && end != null) {
                const now = nowMinutesLocal();
                if (now < start || now >= end) return false;
            }
            return true;
        }
        /** Sesi interview hari ini yang relevan untuk posisi pelamar (check-in belum ditutup HRD). */
        function getOpenSessionsToday() { return []; }
        function getApplicantInterviewSessionsToday() { return []; }
        function getCheckinReadySessions() { return []; }
        function getMyActiveSessionId() { return state.myApplicant?.interviewBooking?.sessionId || null; }
        function subscribeInterviewQueuePelamar() {}
        function unsubscribeInterviewQueuePelamar() {}
        function scheduleCheckinUiRefresh() { hideCheckinFloatCta(); }
        async function performCheckInPelamar() {
            return Swal.fire('Info', 'Konfirmasi jadwal wawancara lewat tab Pesan (tombol Saya hadir).', 'info');
        }
        async function performWalkInCheckIn(e) {
            e?.preventDefault?.();
            return Swal.fire('Walk-in', 'Walk-in dilakukan langsung di lokasi Sencha House.', 'info');
        }
        function openWalkinModal() {}
        function closeWalkinModal() {
            $('walkin-modal')?.classList.remove('is-open');
        }
        function hideCheckinFloatCta() {
            $('checkin-float-cta')?.classList.remove('is-visible');
        }
        function configureCheckinPopupUi(sessions, mode) {
            const ready = mode === 'ready';
            const descEl = $('checkin-popup-desc');
            const btn = $('btn-checkin-lokasi');
            const laterBtn = $('checkin-popup-later');
            const sel = $('checkin-session-select');
            if (sessions.length > 1 && sel) {
                sel.classList.remove('hidden');
                sel.innerHTML = sessions.map((s) =>
                    `<option value="${s.id}">${escapeHtml(s.label || s.slot)}</option>`
                ).join('');
            } else if (sel) {
                sel.classList.add('hidden');
                sel.innerHTML = sessions[0] ? `<option value="${sessions[0].id}"></option>` : '';
            }
            const jamInfo = sessions.map((s) => `${s.label || 'Interview'} (${formatJamRange(s.jamMulai, s.jamSelesai)})`).join(' / ');
            if (ready) {
                if (descEl) descEl.textContent = `Hari interview · ${jamInfo}. Tekan tombol jika sudah tiba di ${UNDANGAN_LOKASI}.`;
                if (btn) {
                    btn.textContent = 'Ambil nomor antrian sekarang';
                    btn.classList.remove('hidden');
                    btn.disabled = false;
                }
                if (laterBtn) laterBtn.textContent = 'Nanti';
            } else {
                if (descEl) descEl.textContent = `Hari interview · ${jamInfo}. Nomor antrian bisa diambil pada jam check-in di atas.`;
                if (btn) btn.classList.add('hidden');
                if (laterBtn) laterBtn.textContent = 'Mengerti';
            }
        }
        function openCheckinPopupModal(sessions, mode = 'ready') {
            if (!sessions?.length) return;
            configureCheckinPopupUi(sessions, mode);
            hideCheckinFloatCta();
            $('checkin-popup-modal')?.classList.add('is-open');
        }
        function updateCheckinFloatCta() {
            hideCheckinFloatCta();
        }
        function onCheckinFloatTap() {
            if (!state.session || !state.myApplicant) {
                return Swal.fire('Login', 'Login dengan nama dan WhatsApp lamaran Anda.', 'info');
            }
            const ready = getCheckinReadySessions();
            if (ready.length) {
                openCheckinPopupModal(ready, 'ready');
                return;
            }
            const todaySessions = getApplicantInterviewSessionsToday();
            if (todaySessions.length) {
                openCheckinPopupModal(todaySessions, 'wait');
                return;
            }
            Swal.fire('Belum ada sesi', 'Belum ada interview aktif untuk posisi Anda hari ini.', 'info');
        }
        function formatInterviewDateId(tanggal) {
            if (!tanggal) return '—';
            try {
                const [y, m, d] = tanggal.split('-').map(Number);
                return new Date(y, m - 1, d).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' });
            } catch { return tanggal; }
        }
        function formatJamRange(jamMulai, jamSelesai) {
            const a = String(jamMulai || '').trim().slice(0, 5);
            const b = String(jamSelesai || '').trim().slice(0, 5);
            if (a && b) return `${a}—${b}`;
